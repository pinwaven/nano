<view class="login-screen">
  <view class="login-glow" />

  <view class="login-brand">
    <view class="login-logo-ring">
      <text class="login-logo-letter">W</text>
    </view>
    <text class="login-title">NANO</text>
    <text class="login-subtitle">您的精准健康伴侣</text>
  </view>

  <view wx:if="{{loading}}" class="status-wrap">
    <view class="spinner" />
    <text class="status-text">正在登录…</text>
  </view>

  <view wx:elif="{{error}}" class="status-wrap">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="retry">
      <text>重试</text>
    </view>
  </view>

  <view class="login-footer">
    <text>哈佛大学创新实验室</text>
    <text class="login-footer-dot">·</text>
    <text>成员企业</text>
  </view>
</view>
