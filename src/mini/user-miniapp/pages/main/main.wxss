/* ── Layout ── */

.main {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: radial-gradient(ellipse at 50% 0%, #142847 0%, #0B1C2E 70%);
  overflow: hidden;
}

.tab-hidden { display: none !important; }

/* ── App Header ── */

.status-bar-spacer {
  flex-shrink: 0;
  background: rgba(11, 28, 46, 0.85);
}

.app-header {
  background: rgba(11, 28, 46, 0.85);
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 0rpx 36rpx 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-logo-img {
  width: 44rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.header-title {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #EEF2FF;
  flex-shrink: 0;
}

.header-divider {
  width: 1rpx;
  height: 28rpx;
  background: rgba(99, 117, 236, 0.25);
  flex-shrink: 0;
}

.header-user {
  font-size: 24rpx;
  color: #A6C4E5;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.header-logo-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

/* ── Logo menu ── */

.menu-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
}

.menu-dropdown {
  position: absolute;
  left: 24rpx;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
  min-width: 240rpx;
}

.menu-divider {
  height: 1rpx;
  background: rgba(99, 117, 236, 0.15);
  margin: 0 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
}

.menu-item-icon {
  font-size: 28rpx;
  color: #A6C4E5;
}

.menu-item-label {
  font-size: 28rpx;
  color: #EEF2FF;
  font-weight: 500;
}

/* ── Tab content container ── */

.tab-content {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-height: 0;
}

.chat-tab,
.health-tab,
.dots-tab,
.store-tab {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
}

/* ── Tab bar ── */

.tab-bar {
  flex-shrink: 0;
  display: flex;
  background: rgba(8, 18, 32, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0 24rpx;
  position: relative;
}

.tab-line {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6375EC, #8B9FFF);
  border-radius: 0 0 6rpx 6rpx;
}

.tab-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.35;
}
.tab-active .tab-icon-img { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: rgba(166, 196, 229, 0.4);
}

.tab-active .tab-label { color: #6375EC; }

/* ── Chat messages ── */

.chat-messages {
  flex: 1;
  height: 0;
}

.chat-inner {
  padding: 24rpx 28rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.msg-row { display: flex; }
.msg-row-user { justify-content: flex-end; }
.msg-row-ai   { justify-content: flex-start; }

.message-bubble {
  max-width: 90%;
  padding: 18rpx 24rpx;
  border-radius: 28rpx;
}

.message-user {
  background: linear-gradient(135deg, #6375EC 0%, #7B8FFF 100%);
  color: #fff;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 117, 236, 0.45);
}

.message-ai {
  background: #162E4A;
  color: #EEF2FF;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-bottom-left-radius: 6rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

/* Typing indicator */

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 26rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6375EC;
  opacity: 0.6;
  animation: dot-bounce 1.2s infinite ease-in-out;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dot-bounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.35; }
  40%            { transform: scale(1.2); opacity: 1; }
}

/* ── Onboarding bars ── */

.ob-bar {
  flex-shrink: 0;
  padding: 24rpx 28rpx;
  background: rgba(11, 28, 46, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.name-bar {
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.ob-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  border-radius: 24rpx;
  color: #EEF2FF;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 80rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
}

.ob-ph { color: rgba(166, 196, 229, 0.4); }

.ob-confirm {
  background: #6375EC;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 36rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.ob-confirm-off { opacity: 0.35; box-shadow: none; }

.conditions-bar { gap: 20rpx; }

.cond-other-input { width: 100%; box-sizing: border-box; }

.cond-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.cond-chip {
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.08);
  color: rgba(166, 196, 229, 0.7);
  font-size: 26rpx;
  font-weight: 500;
}

.cond-chip-on {
  border-color: #6375EC;
  background: rgba(99, 117, 236, 0.28);
  color: #EEF2FF;
}

.health-cond-chip {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  background: rgba(99, 117, 236, 0.1);
  color: #A6C4E5;
  font-size: 24rpx;
  font-weight: 500;
}

.gender-bar {
  flex-direction: row;
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  background: rgba(99, 117, 236, 0.12);
  color: #EEF2FF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.birthday-bar { gap: 16rpx; }

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  border-radius: 24rpx;
  padding: 22rpx 28rpx;
}

.picker-val  { font-size: 28rpx; color: #EEF2FF; }
.picker-arrow { font-size: 36rpx; color: rgba(166, 196, 229, 0.4); }

.body-bar { gap: 24rpx; }

.slider-row { display: flex; flex-direction: column; gap: 12rpx; }

.slider-labels {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.slider-key {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.slider-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #EEF2FF;
}

.slider-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(166, 196, 229, 0.4);
}

/* ── Chat input area ── */

.input-container {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}

.toolbox-panel {
  background: rgba(11, 28, 46, 0.96);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 24rpx 16rpx;
}

.toolbox-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  border-radius: 20rpx;
  padding: 18rpx 28rpx;
  min-width: 148rpx;
}

.tool-item-icon {
  font-size: 30rpx;
  color: #6375EC;
  line-height: 1;
}

.tool-item-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #EEF2FF;
  text-align: center;
}

.plus-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(99, 117, 236, 0.12);
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus-btn-open {
  background: rgba(99, 117, 236, 0.3);
  border-color: #6375EC;
}

.plus-icon {
  font-size: 40rpx;
  color: #A6C4E5;
  line-height: 1;
}

.plus-btn-open .plus-icon {
  color: #8B9FFF;
}

.input-area {
  flex-shrink: 0;
  background: rgba(11, 28, 46, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.chat-textarea {
  flex: 1;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.22);
  border-radius: 24rpx;
  font-size: 28rpx;
  padding: 18rpx 24rpx;
  color: #EEF2FF;
  min-height: 80rpx;
  max-height: 200rpx;
  line-height: 1.45;
}

.textarea-ph { color: rgba(166, 196, 229, 0.4); }

.send-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(99, 117, 236, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-active {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.send-icon {
  font-size: 36rpx;
  color: #fff;
}

/* ── Health tab ── */

.health-scroll {
  flex: 1;
  height: 0;
}

.center-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 80rpx 0;
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6375EC;
  animation: pulse-dot 1.2s ease-in-out infinite;
}

.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse-dot { 0%, 80%, 100% { opacity: 0.2; } 40% { opacity: 1; } }

/* Health hero */

.health-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 40rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.1);
  gap: 16rpx;
  overflow: hidden;
}

.health-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(99, 117, 236, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.health-avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6375EC, #8B9FFF);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(99, 117, 236, 0.45);
  margin-bottom: 8rpx;
  position: relative;
}

.avatar-letter {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.health-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #EEF2FF;
  position: relative;
}

.bio-row {
  display: flex;
  gap: 24rpx;
  position: relative;
}

.bio-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 20rpx 36rpx 16rpx;
  min-width: 160rpx;
}

.bio-chip-dim {
  background: rgba(11, 28, 46, 0.5);
}

.bio-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.bio-num-sub { color: #A6C4E5; }

.bio-unit {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.75);
  margin-top: 8rpx;
}

/* Sub-age grid */

.sub-age-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
  position: relative;
}

.sub-age-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 20rpx 24rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  text-align: center;
}

.sub-age-val {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.1;
}

.sub-age-label {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1.2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.75);
  margin-top: 4rpx;
}

.sub-age-desc {
  font-size: 18rpx;
  color: rgba(166, 196, 229, 0.4);
  line-height: 1.35;
  margin-top: 6rpx;
}

/* Health sections */

.health-section {
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.health-section:last-child { border-bottom: none; }

.section-title {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
  margin-bottom: 28rpx;
  display: block;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.section-title-row .section-title { margin-bottom: 0; }

.section-badge {
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(99, 117, 236, 0.12);
  color: #A6C4E5;
  border: 1rpx solid rgba(99, 117, 236, 0.2);
  border-radius: 40rpx;
  padding: 4rpx 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 16rpx 24rpx;
}

.info-key { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }
.info-val { font-size: 24rpx; color: #EEF2FF; font-weight: 500; }

.health-empty { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }

/* Biomarker list */

.bm-list { display: flex; flex-direction: column; }

.bm-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.07);
}

.bm-row:last-child { border-bottom: none; }

.bm-dot  { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.bm-label { font-size: 26rpx; color: #A6C4E5; flex: 1; }
.bm-val  { font-size: 30rpx; font-weight: 700; }
.bm-unit { font-size: 20rpx; color: rgba(166, 196, 229, 0.4); min-width: 96rpx; text-align: right; }

/* Trend grid */

.trend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.trend-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 24rpx 24rpx 20rpx;
}

.trend-label {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  color: rgba(166, 196, 229, 0.4);
  text-transform: uppercase;
  margin-bottom: 8rpx;
  display: block;
}

.trend-val-row { display: flex; align-items: baseline; gap: 6rpx; }
.trend-val     { font-size: 32rpx; font-weight: 800; }
.trend-unit    { font-size: 18rpx; color: rgba(166, 196, 229, 0.4); }

.spark-row {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 36rpx;
  margin-top: 14rpx;
}

.spark-bar {
  flex: 1;
  border-radius: 4rpx;
  opacity: 0.55;
  min-height: 6rpx;
}

.spark-bar-empty {
  opacity: 0.15;
}

/* ── Dots tab ── */

.dots-header {
  flex-shrink: 0;
  padding: 36rpx 36rpx 20rpx;
}

.dots-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.dots-scroll {
  flex: 1;
  height: 0;
}

.dots-days {
  padding: 0 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.day-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
}

.day-today {
  border-color: rgba(99, 117, 236, 0.55);
  background: rgba(99, 117, 236, 0.08);
}

.day-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #A6C4E5;
  margin-bottom: 20rpx;
  display: block;
}

.day-today .day-label { color: #6375EC; }

.meal-slot { margin-bottom: 16rpx; }
.meal-slot:last-child { margin-bottom: 0; }

.meal-name {
  font-size: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  color: rgba(166, 196, 229, 0.4);
  display: block;
  margin-bottom: 10rpx;
}

.dot-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dot-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 6rpx 16rpx 6rpx 10rpx;
}

.dot-swatch {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-key   { font-size: 20rpx; font-weight: 700; color: #EEF2FF; letter-spacing: 0.5rpx; }
.dot-count { font-size: 20rpx; color: rgba(166, 196, 229, 0.4); }

.dots-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 56rpx;
  font-size: 26rpx;
  color: rgba(166, 196, 229, 0.4);
  line-height: 1.6;
  text-align: center;
}

/* ── Store tab ── */

.store-header {
  flex-shrink: 0;
  padding: 36rpx 36rpx 20rpx;
}

.store-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.store-scroll {
  flex: 1;
  height: 0;
}

.store-list {
  padding: 8rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.store-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  position: relative;
  overflow: hidden;
}

.store-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #6375EC, #8B9FFF);
  border-bottom-left-radius: 16rpx;
  padding: 8rpx 20rpx;
}

.store-tag-text {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #fff;
}

.store-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #EEF2FF;
  display: block;
  margin-bottom: 12rpx;
  padding-right: 100rpx;
}

.store-card-desc {
  font-size: 24rpx;
  color: rgba(166, 196, 229, 0.55);
  line-height: 1.5;
  display: block;
  margin-bottom: 32rpx;
}

.store-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.store-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.store-price {
  font-size: 44rpx;
  font-weight: 800;
  color: #EEF2FF;
  line-height: 1;
}

.store-unit {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.4);
}

.store-buy-btn {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  border-radius: 24rpx;
  padding: 22rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.store-buy-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5rpx;
}

/* ── Store subtabs ── */

.store-subtab-row {
  flex-shrink: 0;
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx 20rpx;
}

.store-subtab-btn {
  padding: 14rpx 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.06);
  color: rgba(166, 196, 229, 0.5);
  font-size: 24rpx;
  font-weight: 600;
}

.store-subtab-active {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  border-color: transparent;
  color: #fff;
}

/* ── Order cards ── */

.order-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.order-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #EEF2FF;
  flex: 1;
}

.order-status {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.order-status-pending   { background: rgba(245,158,11,0.15); color: #f59e0b; }
.order-status-confirmed { background: rgba(59,130,246,0.15); color: #60a5fa; }
.order-status-shipped   { background: rgba(139,92,246,0.15); color: #a78bfa; }
.order-status-delivered { background: rgba(16,185,129,0.15); color: #34d399; }
.order-status-cancelled { background: rgba(100,116,139,0.12); color: #94a3b8; }

.order-card-mid {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.order-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #EEF2FF;
}

.order-meta {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.4);
}

.order-date {
  font-size: 20rpx;
  color: rgba(166, 196, 229, 0.3);
}

/* ── Kino chip scan ── */

.kino-scan-bar {
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.kino-scan-btn {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #6375EC;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 56rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 117, 236, 0.5);
}

.kino-scan-icon {
  font-size: 36rpx;
}

.kino-scan-label {
  font-size: 30rpx;
  font-weight: 600;
}

/* ── Kino Simulator Overlay ── */

.ksm-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: radial-gradient(ellipse at 50% 0%, #1a3155 0%, #0B1C2E 65%);
  display: flex;
  flex-direction: column;
}

.ksm-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.ksm-header {
  background: rgba(11, 28, 46, 0.7);
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.ksm-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #EEF2FF;
}

.ksm-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.1);
  color: #A6C4E5;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* scroll-view must not have flex/gap — use an inner wrapper instead */
.ksm-body {
  flex: 1;
}

.ksm-body-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 44rpx 48rpx;
}

/* ── Device ring ── */

.ksm-ring-row {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
}

.ksm-device-wrap {
  position: relative;
  width: 340rpx;
  height: 340rpx;
  flex-shrink: 0;
}

.ksm-ring-track {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  background: conic-gradient(
    #6375EC 0deg,
    #A6C4E5 90deg,
    rgba(15, 37, 64, 0.6) 180deg,
    #6375EC 360deg
  );
  animation: ksm-ring-spin 10s linear infinite;
}

.ksm-state-analyzing .ksm-ring-track {
  animation-duration: 1.8s;
  background: conic-gradient(
    #6375EC 0deg,
    #c0caff 60deg,
    #6375EC 120deg,
    rgba(15, 37, 64, 0.3) 200deg,
    #6375EC 360deg
  );
}

.ksm-state-complete .ksm-ring-track {
  animation-duration: 5s;
  background: conic-gradient(
    #1A8A6A 0deg,
    #6FDFB8 80deg,
    rgba(15, 37, 64, 0.5) 180deg,
    #1A8A6A 360deg
  );
}

.ksm-state-failed .ksm-ring-track {
  animation: none;
  background: conic-gradient(
    #E86060 0deg,
    #FFB3B3 60deg,
    rgba(15, 37, 64, 0.5) 160deg,
    #E86060 360deg
  );
}

.ksm-ring-face {
  position: absolute;
  top: 16rpx; left: 16rpx; right: 16rpx; bottom: 16rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 24rpx rgba(99, 117, 236, 0.06),
              0 8rpx 48rpx rgba(99, 117, 236, 0.18);
}

.ksm-state-analyzing .ksm-ring-face {
  animation: ksm-face-pulse 1.8s ease-in-out infinite;
}

.ksm-face-static,
.ksm-face-slide {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ksm-face-slide {
  opacity: 0;
  transition: opacity 0.3s ease;
}

.ksm-slide-visible { opacity: 1; }

.ksm-face-label {
  font-size: 16rpx;
  letter-spacing: 6rpx;
  color: rgba(26, 62, 95, 0.4);
  margin-bottom: 4rpx;
}

.ksm-face-status {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3E5F;
}

.ksm-face-status-analyzing { color: #6375EC; animation: ksm-text-pulse 1.8s ease-in-out infinite; }
.ksm-face-status-complete  { color: #1A8A6A; }
.ksm-face-status-failed    { color: #E86060; }

.ksm-face-user {
  font-size: 22rpx;
  color: #6375EC;
  font-weight: 500;
  margin-top: 10rpx;
}

.ksm-slide-index {
  font-size: 16rpx;
  letter-spacing: 2rpx;
  color: rgba(26, 62, 95, 0.35);
  margin-bottom: 6rpx;
}

.ksm-slide-label {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(26, 62, 95, 0.5);
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.ksm-slide-val {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A8A6A;
  line-height: 1;
}

.ksm-slide-unit {
  font-size: 18rpx;
  color: rgba(26, 62, 95, 0.4);
  margin-top: 4rpx;
}

/* ── Results panel ── */

.ksm-results {
  width: 100%;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}

.ksm-tabs {
  display: flex;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
}

.ksm-tab {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(166, 196, 229, 0.4);
}

.ksm-tab-active {
  color: #6375EC;
  background: rgba(99, 117, 236, 0.06);
  border-bottom: 4rpx solid #6375EC;
}

.ksm-tab-content {
  padding: 24rpx 28rpx;
}

.ksm-bioage-row {
  display: flex;
  margin-bottom: 20rpx;
}

.ksm-bioage-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 18rpx;
  padding: 20rpx 8rpx 16rpx;
  margin-right: 14rpx;
}

.ksm-bioage-chip:last-child { margin-right: 0; }

.ksm-bioage-chip-dim { background: rgba(11, 28, 46, 0.5); }

.ksm-bioage-num {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.ksm-bioage-chip-label {
  font-size: 14rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: rgba(166, 196, 229, 0.4);
  margin-top: 10rpx;
}

.ksm-sub-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.ksm-sub-row:last-child { border-bottom: none; }

.ksm-sub-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.ksm-sub-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #A6C4E5;
  flex: 1;
}

.ksm-sub-val {
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ksm-bm-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.ksm-bm-row:last-child { border-bottom: none; }

.ksm-bm-label {
  font-size: 24rpx;
  color: #A6C4E5;
  flex: 1;
}

.ksm-bm-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #EEF2FF;
}

.ksm-bm-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: rgba(166, 196, 229, 0.4);
}

/* ── Action button ── */

.ksm-btn {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #6375EC 0%, #7B8FFF 100%);
  box-shadow: 0 8rpx 40rpx rgba(99, 117, 236, 0.45);
}

.ksm-btn-complete {
  background: linear-gradient(135deg, #1A8A6A 0%, #2DBF8A 100%);
  box-shadow: 0 8rpx 40rpx rgba(26, 138, 106, 0.45);
}

.ksm-btn-failed {
  background: linear-gradient(135deg, #C03030 0%, #E86060 100%);
  box-shadow: 0 8rpx 40rpx rgba(232, 96, 96, 0.45);
}

.ksm-btn-analyzing { opacity: 0.7; }

.ksm-quit-btn {
  margin-top: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(166, 196, 229, 0.5);
}

.ksm-dots-row {
  display: flex;
  align-items: center;
}

.ksm-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  animation: ksm-dot-bounce 1.2s ease-in-out infinite;
  margin-right: 10rpx;
}

.ksm-dot:last-child { margin-right: 0; }
.ksm-dot:nth-child(2) { animation-delay: 0.2s; }
.ksm-dot:nth-child(3) { animation-delay: 0.4s; }

/* ── Animations ── */

@keyframes ksm-ring-spin {
  to { transform: rotate(360deg); }
}

@keyframes ksm-face-pulse {
  0%, 100% { box-shadow: inset 0 4rpx 24rpx rgba(99,117,236,0.08), 0 8rpx 64rpx rgba(99,117,236,0.35); }
  50%       { box-shadow: inset 0 4rpx 24rpx rgba(99,117,236,0.08), 0 8rpx 100rpx rgba(99,117,236,0.35); }
}

@keyframes ksm-text-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.45; }
}

@keyframes ksm-dot-bounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%            { transform: scale(1.2); opacity: 1; }
}
