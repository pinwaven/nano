<view class="main">

  <!-- ── Status bar spacer ── -->
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- ── Header ── -->
  <view class="app-header" style="padding-right: {{capsuleRightPad}}px;" bindtap="toggleMenu">
    <view class="header-logo-btn">
      <image class="header-logo-img" src="/assets/waven-logo-icon.png" mode="aspectFit" />
      <text class="header-title">NANO</text>
    </view>
    <view class="header-divider"></view>
    <text class="header-user">{{user.nickname || 'User'}}</text>
  </view>

  <!-- ── Logo menu ── -->
  <view wx:if="{{menuOpen}}" class="menu-mask" bindtap="closeMenu">
    <view class="menu-dropdown" catchtap="noop" style="top: {{menuTop}}px;">
      <view class="menu-item" bindtap="toggleLang">
        <text class="menu-item-icon">{{lang === 'zh' ? '🇺🇸' : '🇨🇳'}}</text>
        <text class="menu-item-label">{{lang === 'zh' ? 'English' : '中文'}}</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="handleLogout">
        <text class="menu-item-icon">↪</text>
        <text class="menu-item-label">{{t.logout}}</text>
      </view>
    </view>
  </view>

  <!-- ── Tab Content ── -->
  <view class="tab-content">

    <!-- ════ CHAT ════ -->
    <view class="chat-tab{{tab !== 'chat' ? ' tab-hidden' : ''}}">

      <scroll-view
        class="chat-messages"
        scroll-y="true"
        scroll-into-view="{{scrollToId}}"
        scroll-with-animation="true"
        enhanced="true"
        bounces="false"
      >
        <view class="chat-inner">

          <view
            wx:for="{{messages}}"
            wx:key="id"
            id="msg{{index}}"
            class="msg-row {{item.role === 'user' ? 'msg-row-user' : 'msg-row-ai'}}"
          >
            <view class="message-bubble {{item.role === 'user' ? 'message-user' : 'message-ai'}}">
              <text class="msg-text" selectable="true">{{item.content}}</text>
            </view>
          </view>

          <view wx:if="{{typing}}" class="msg-row msg-row-ai">
            <view class="message-bubble message-ai typing-indicator">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
          </view>

          <view style="height: 16px;"></view>
        </view>
      </scroll-view>

      <!-- Onboarding: Name -->
      <view wx:if="{{obStep === 'name'}}" class="ob-bar name-bar">
        <input
          class="ob-input"
          placeholder="{{t.obNamePh}}"
          placeholder-class="ob-ph"
          value="{{obName}}"
          bindinput="onObNameInput"
          bindconfirm="handleSubmitName"
          focus="{{tab === 'chat' && obStep === 'name'}}"
          adjust-position="true"
        />
        <view class="ob-confirm" bindtap="handleSubmitName">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: Gender -->
      <view wx:if="{{obStep === 'gender' && !typing}}" class="ob-bar gender-bar">
        <view class="quick-btn" bindtap="handleSelectGender" data-gender="male">
          <text>{{t.male}}</text>
        </view>
        <view class="quick-btn" bindtap="handleSelectGender" data-gender="female">
          <text>{{t.female}}</text>
        </view>
      </view>

      <!-- Onboarding: Birthday -->
      <view wx:if="{{obStep === 'birthday'}}" class="ob-bar birthday-bar">
        <picker mode="date" value="{{obBirthday}}" start="1920-01-01" end="2010-12-31" bindchange="onBirthdayChange">
          <view class="picker-row">
            <text class="picker-val">{{obBirthday || t.selectBirthday}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
        <view class="ob-confirm {{obBirthday ? '' : 'ob-confirm-off'}}" bindtap="handleSubmitBirthday">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: Body Sliders -->
      <view wx:if="{{obStep === 'body'}}" class="ob-bar body-bar">
        <view class="slider-row">
          <view class="slider-labels">
            <text class="slider-key">{{t.bsHeight}}</text>
            <text class="slider-val">{{obHeight}} <text class="slider-unit">{{t.bsCm}}</text></text>
          </view>
          <slider
            min="100" max="220" value="{{obHeight}}" step="1"
            activeColor="#6375EC" backgroundColor="#162E4A" block-color="#6375EC"
            bindchange="onHeightChange" bindchanging="onHeightChange" block-size="20"
          />
        </view>
        <view class="slider-row">
          <view class="slider-labels">
            <text class="slider-key">{{t.bsWeight}}</text>
            <text class="slider-val">{{obWeightDisplay}} <text class="slider-unit">{{t.bsKg}}</text></text>
          </view>
          <slider
            min="30" max="150" value="{{obWeight}}" step="0.5"
            activeColor="#6375EC" backgroundColor="#162E4A" block-color="#6375EC"
            bindchange="onWeightChange" bindchanging="onWeightChange" block-size="20"
          />
        </view>
        <view class="ob-confirm" bindtap="handleSubmitBody">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: Conditions -->
      <view wx:if="{{obStep === 'conditions'}}" class="ob-bar conditions-bar">
        <view class="cond-chips">
          <view
            wx:for="{{obConditionList}}"
            wx:key="key"
            class="cond-chip {{item.selected ? 'cond-chip-on' : ''}}"
            bindtap="handleToggleCondition"
            data-key="{{item.key}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
        <input
          wx:if="{{obOtherSelected}}"
          class="ob-input cond-other-input"
          placeholder="{{t.obConditionsOtherPh}}"
          placeholder-class="ob-ph"
          value="{{obConditionsOther}}"
          bindinput="onObConditionsOtherInput"
          focus="{{obOtherSelected}}"
          adjust-position="true"
        />
        <view class="ob-confirm" bindtap="handleSubmitConditions">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Normal chat input -->
      <view wx:if="{{obStep === 'done'}}" class="input-container">
        <view wx:if="{{toolboxOpen}}" class="toolbox-panel">
          <view class="toolbox-grid">
            <view class="tool-item" bindtap="handleToolAction" data-action="formula_dots">
              <text class="tool-item-icon">◉</text>
              <text class="tool-item-label">{{t.toolFormulaDots}}</text>
            </view>
            <view class="tool-item" bindtap="handleToolAction" data-action="test_chip">
              <text class="tool-item-icon">⬡</text>
              <text class="tool-item-label">{{t.toolTestChip}}</text>
            </view>
          </view>
        </view>
        <view class="input-area">
          <view class="plus-btn {{toolboxOpen ? 'plus-btn-open' : ''}}" bindtap="toggleToolbox">
            <text class="plus-icon">+</text>
          </view>
          <textarea
            class="chat-textarea"
            placeholder="{{t.inputPh}}"
            placeholder-class="textarea-ph"
            value="{{chatInput}}"
            bindinput="onChatInput"
            auto-height="true"
            maxlength="500"
            adjust-position="true"
            fixed="true"
            cursor-spacing="12"
            show-confirm-bar="false"
          />
          <view class="send-btn {{chatInput ? 'send-active' : ''}}" bindtap="handleSend">
            <text class="send-icon">↑</text>
          </view>
        </view>
      </view>

    </view>
    <!-- end CHAT -->

    <!-- ════ HEALTH ════ -->
    <view class="health-tab{{tab !== 'health' ? ' tab-hidden' : ''}}">
      <scroll-view class="health-scroll" scroll-y="true">

        <view wx:if="{{bioLoading}}" class="center-wrap">
          <view class="pulse-dot"></view>
          <view class="pulse-dot"></view>
          <view class="pulse-dot"></view>
        </view>

        <block wx:else>

          <!-- Hero -->
          <view class="health-hero">
            <view class="health-hero-bg"></view>
            <view class="health-avatar">
              <text class="avatar-letter">{{user.nickname ? user.nickname[0] : 'U'}}</text>
            </view>
            <text class="health-name">{{user.nickname || 'User'}}</text>

            <view wx:if="{{bAge || cAge}}" class="bio-row">
              <view class="bio-chip bio-chip-dim">
                <text class="bio-num bio-num-sub">{{cAge || '—'}}</text>
                <text class="bio-unit">{{t.chronoAge}}</text>
              </view>
              <view class="bio-chip">
                <text class="bio-num" style="color: {{bAgeColor}}">{{bAge || '—'}}</text>
                <text class="bio-unit">{{t.bioAge}}</text>
              </view>
            </view>

            <view wx:if="{{subAgeList.length > 0}}" class="sub-age-grid">
              <view wx:for="{{subAgeList}}" wx:key="key" class="sub-age-card">
                <text class="sub-age-val" style="color: {{item.color}}">{{item.value}}</text>
                <text class="sub-age-label">{{item.label}}</text>
                <text class="sub-age-desc">{{item.desc}}</text>
              </view>
            </view>
          </view>

          <!-- Profile -->
          <view class="health-section">
            <text class="section-title">{{t.profile}}</text>
            <view class="info-grid">
              <block wx:for="{{profileInfo}}" wx:key="label">
                <text class="info-key">{{item.label}}</text>
                <text class="info-val">{{item.val}}</text>
              </block>
            </view>
          </view>

          <!-- Health Conditions -->
          <view wx:if="{{hasConditionsData}}" class="health-section">
            <text class="section-title">{{t.healthConditions}}</text>
            <view wx:if="{{healthConditionsList.length > 0}}" class="cond-chips">
              <view wx:for="{{healthConditionsList}}" wx:key="key" class="health-cond-chip">
                <text>{{item.label}}</text>
              </view>
            </view>
            <text wx:else class="health-empty">{{t.noConditions}}</text>
          </view>

          <!-- Latest Biomarkers -->
          <view class="health-section">
            <text class="section-title">{{t.latestBm}}</text>
            <view wx:if="{{hasBm}}" class="bm-list">
              <view wx:for="{{bmList}}" wx:key="key" class="bm-row">
                <view class="bm-dot" style="background: {{item.color}}"></view>
                <text class="bm-label">{{item.label}}</text>
                <text class="bm-val" style="color: {{item.color}}">{{item.value !== null ? item.value : '—'}}</text>
                <text class="bm-unit">{{item.unit}}</text>
              </view>
            </view>
            <text wx:else class="health-empty">{{t.noBmData}}</text>
          </view>

          <!-- Trends -->
          <view class="health-section">
            <view class="section-title-row">
              <text class="section-title">{{t.trends}}</text>
              <view wx:if="{{recordCount > 0}}" class="section-badge">
                <text>{{recordCount}} {{t.tests}}</text>
              </view>
            </view>
            <view wx:if="{{recordCount > 0}}" class="trend-grid">
              <view wx:for="{{trendList}}" wx:key="key" class="trend-card">
                <text class="trend-label">{{item.label}}</text>
                <view class="trend-val-row">
                  <text class="trend-val" style="color: {{item.color}}">{{item.lastVal !== null ? item.lastVal : '—'}}</text>
                  <text class="trend-unit">{{item.unit}}</text>
                </view>
                <view wx:if="{{item.sparkBars.length > 1}}" class="spark-row">
                  <view
                    wx:for="{{item.sparkBars}}"
                    wx:for-item="bar"
                    wx:key="index"
                    class="spark-bar {{bar.empty ? 'spark-bar-empty' : ''}}"
                    style="height: {{bar.h}}rpx; background: {{bar.color}};"
                  ></view>
                </view>
              </view>
            </view>
            <text wx:else class="health-empty">{{t.noHistory}}</text>
          </view>

          <view style="height: 32px;"></view>
        </block>

      </scroll-view>
    </view>
    <!-- end HEALTH -->

    <!-- ════ DOTS ════ -->
    <view class="dots-tab{{tab !== 'dots' ? ' tab-hidden' : ''}}">

      <view class="dots-header">
        <text class="dots-title">{{t.dotsTitle}}</text>
      </view>

      <view wx:if="{{dotsLoading}}" class="center-wrap">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>

      <scroll-view wx:elif="{{dotsDays.length > 0}}" class="dots-scroll" scroll-y="true">
        <view class="dots-days">
          <view
            wx:for="{{dotsDays}}"
            wx:key="label"
            class="day-card {{item.isToday ? 'day-today' : ''}}"
          >
            <text class="day-label">{{item.label}}</text>

            <view wx:if="{{item.morning.length > 0}}" class="meal-slot">
              <text class="meal-name">{{t.morning}}</text>
              <view class="dot-chips">
                <view
                  wx:for="{{item.morning}}"
                  wx:key="displayKey"
                  wx:for-item="dot"
                  class="dot-chip"
                >
                  <view class="dot-swatch" style="background: {{dot.color}}"></view>
                  <text class="dot-key">{{dot.displayKey}}</text>
                  <text class="dot-count">×{{dot.count}}</text>
                </view>
              </view>
            </view>

            <view wx:if="{{item.evening.length > 0}}" class="meal-slot">
              <text class="meal-name">{{t.evening}}</text>
              <view class="dot-chips">
                <view
                  wx:for="{{item.evening}}"
                  wx:key="displayKey"
                  wx:for-item="dot"
                  class="dot-chip"
                >
                  <view class="dot-swatch" style="background: {{dot.color}}"></view>
                  <text class="dot-key">{{dot.displayKey}}</text>
                  <text class="dot-count">×{{dot.count}}</text>
                </view>
              </view>
            </view>
          </view>
          <view style="height: 32px;"></view>
        </view>
      </scroll-view>

      <view wx:else class="dots-empty">
        <text>{{t.noPlan}}</text>
      </view>

    </view>
    <!-- end DOTS -->

    <!-- ════ STORE ════ -->
    <view class="store-tab{{tab !== 'store' ? ' tab-hidden' : ''}}">

      <view class="store-header">
        <text class="store-title">{{t.storeTitle}}</text>
      </view>

      <!-- Subtab toggle -->
      <view wx:if="{{!storeLoading}}" class="store-subtab-row">
        <view class="store-subtab-btn{{storeSubTab === 'products' ? ' store-subtab-active' : ''}}" bindtap="switchStoreTab" data-tab="products">
          <text>{{t.storeSubProducts}}</text>
        </view>
        <view class="store-subtab-btn{{storeSubTab === 'orders' ? ' store-subtab-active' : ''}}" bindtap="switchStoreTab" data-tab="orders">
          <text>{{t.storeSubOrders}}</text>
        </view>
      </view>

      <!-- Loading -->
      <view wx:if="{{storeLoading}}" class="center-wrap">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>

      <!-- Products subtab -->
      <scroll-view wx:elif="{{storeSubTab === 'products' && storeItems.length > 0}}" class="store-scroll" scroll-y="true">
        <view class="store-list">
          <view wx:for="{{storeItems}}" wx:key="id" class="store-card">
            <view wx:if="{{item.tagLabel}}" class="store-tag">
              <text class="store-tag-text">{{item.tagLabel}}</text>
            </view>
            <text class="store-card-name">{{item.name}}</text>
            <text class="store-card-desc">{{item.desc}}</text>
            <view class="store-card-footer">
              <view class="store-price-wrap">
                <text class="store-price">{{item.price}}</text>
                <text class="store-unit">/ {{item.unit}}</text>
              </view>
              <view class="store-buy-btn" bindtap="handleBuyItem" data-item="{{item}}">
                <text class="store-buy-label">{{t.storeBuy}}</text>
              </view>
            </view>
          </view>
          <view style="height: 32px;"></view>
        </view>
      </scroll-view>

      <view wx:elif="{{storeSubTab === 'products'}}" class="dots-empty">
        <text>{{t.storeEmpty}}</text>
      </view>

      <!-- Orders subtab -->
      <scroll-view wx:elif="{{storeSubTab === 'orders' && storeOrders.length > 0}}" class="store-scroll" scroll-y="true">
        <view class="store-list">
          <view wx:for="{{storeOrders}}" wx:key="id" class="order-card">
            <view class="order-card-top">
              <text class="order-name">{{item.name}}</text>
              <view class="order-status order-status-{{item.status}}">
                <text>{{t.orderStatus[item.status] || item.status}}</text>
              </view>
            </view>
            <view class="order-card-mid">
              <text class="order-price">{{item.price}}</text>
              <text class="order-meta"> · {{item.unit}} · ×{{item.quantity}}</text>
            </view>
            <text class="order-date">{{item.createdAt}}</text>
          </view>
          <view style="height: 32px;"></view>
        </view>
      </scroll-view>

      <view wx:elif="{{storeSubTab === 'orders'}}" class="dots-empty">
        <text>{{t.noOrders}}</text>
      </view>

    </view>
    <!-- end STORE -->

  </view>
  <!-- end tab-content -->

  <!-- ── Bottom Tab Bar ── -->
  <view class="tab-bar">
    <view class="tab-btn {{tab === 'chat' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="chat">
      <view wx:if="{{tab === 'chat'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/chat.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabChat}}</text>
    </view>
    <view class="tab-btn {{tab === 'health' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="health">
      <view wx:if="{{tab === 'health'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/health.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabHealth}}</text>
    </view>
    <view class="tab-btn {{tab === 'dots' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="dots">
      <view wx:if="{{tab === 'dots'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/dots.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabDots}}</text>
    </view>
    <view class="tab-btn {{tab === 'store' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="store">
      <view wx:if="{{tab === 'store'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/store.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabStore}}</text>
    </view>
  </view>

</view>
