:host {
  flex: 1;
  min-height: 0;
}

.uh-root {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* ── Loading / empty ── */

.health-scroll {
  flex: 1;
  height: 0;
}

.center-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 80rpx 0;
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6375EC;
  animation: pulse-dot 1.2s ease-in-out infinite;
}

.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse-dot { 0%, 80%, 100% { opacity: 0.2; } 40% { opacity: 1; } }

/* ── Health hero ── */

.health-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 40rpx 72rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.1);
  gap: 36rpx;
  overflow: hidden;
}

.health-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(99, 117, 236, 0.18) 0%, transparent 70%);
  pointer-events: none;
}

.health-avatar-container {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.health-avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  opacity: 0;
  z-index: 1;
}

.health-avatar-btn::after { border: none; }

.health-avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  border: 5rpx solid transparent;
  border-top-color: #6375EC;
  border-right-color: #6375EC;
  box-sizing: border-box;
  animation: avatar-spin 0.8s linear infinite;
  pointer-events: none;
}

@keyframes avatar-spin { to { transform: rotate(360deg); } }

.health-avatar-wrap {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(99, 117, 236, 0.45);
  box-shadow: 0 0 28rpx rgba(99, 117, 236, 0.22);
}

.health-avatar-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
}

.health-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: #0F2540;
  display: flex;
  align-items: center;
  justify-content: center;
}

.health-avatar-letter {
  font-size: 88rpx;
  font-weight: 700;
  color: #A6C4E5;
}

.bio-row {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  position: relative;
  width: 100%;
}

.bio-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 28rpx;
  padding: 28rpx 24rpx 22rpx;
}

.bio-chip-primary {
  border-color: rgba(99, 117, 236, 0.55);
  box-shadow: 0 0 40rpx rgba(99, 117, 236, 0.18);
  flex: 1.4;
}

.bio-chip-dim {
  background: rgba(11, 28, 46, 0.5);
  flex: 1;
}

.bio-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.bio-num-primary {
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1;
}

.bio-num-chrono {
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
  color: #A6C4E5;
}

.bio-unit {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.65);
  margin-top: 10rpx;
}

.bio-bars {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bio-bar-item { width: 100%; }

.bio-bar-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.bio-bar-label {
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.4rpx;
  color: rgba(166, 196, 229, 0.6);
}

.bio-bar-val {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.bio-bar-track {
  height: 10rpx;
  background: rgba(15, 37, 64, 0.9);
  border-radius: 5rpx;
  position: relative;
  overflow: visible;
}

.bio-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: 5rpx;
  opacity: 0.75;
}

.bio-bar-ref {
  position: absolute;
  left: 50%;
  top: -6rpx;
  height: calc(100% + 12rpx);
  width: 2rpx;
  background: rgba(166, 196, 229, 0.35);
  transform: translateX(-50%);
}

.sub-age-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  width: 100%;
  position: relative;
}

.sub-age-card {
  background: rgba(15, 37, 64, 0.6);
  border: 1rpx solid rgba(99, 117, 236, 0.12);
  border-radius: 20rpx;
  padding: 16rpx 16rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  text-align: center;
}

.sub-age-val {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.1;
}

.sub-age-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.6);
  margin-top: 4rpx;
}

.sub-age-desc {
  font-size: 17rpx;
  color: rgba(166, 196, 229, 0.35);
  line-height: 1.35;
  margin-top: 4rpx;
}

/* ── Health sections ── */

.health-section {
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.health-section:last-child { border-bottom: none; }

.section-title {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
  margin-bottom: 28rpx;
  display: block;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.section-title-row .section-title { margin-bottom: 0; }

.section-badge {
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(99, 117, 236, 0.12);
  color: #A6C4E5;
  border: 1rpx solid rgba(99, 117, 236, 0.2);
  border-radius: 40rpx;
  padding: 4rpx 16rpx;
}

.profile-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(99, 117, 236, 0.08);
  border: 1rpx solid rgba(99, 117, 236, 0.18);
}

.profile-toggle-text { font-size: 22rpx; color: #A6C4E5; font-weight: 600; }
.profile-toggle-arrow { font-size: 18rpx; color: rgba(166, 196, 229, 0.5); }

.info-grid {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 16rpx 24rpx;
}

.info-grid-extra { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(99, 117, 236, 0.08); }

.info-key { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }
.info-val { font-size: 24rpx; color: #EEF2FF; font-weight: 500; }

.weight-val-row { display: flex; align-items: center; gap: 16rpx; }
.weight-sparkline { width: 80rpx; height: 28rpx; flex-shrink: 0; }

/* ── Weight chart modal ── */

.wchart-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 120;
  background: rgba(6, 15, 25, 0.75);
  display: flex;
  align-items: flex-end;
}

.wchart-sheet {
  width: 100%;
  background: #0D1E35;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 20rpx 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wchart-handle {
  width: 64rpx; height: 6rpx;
  border-radius: 3rpx;
  background: rgba(166, 196, 229, 0.2);
  margin-bottom: 24rpx;
}

.wchart-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.wchart-title { font-size: 30rpx; font-weight: 600; color: #EEF2FF; }
.wchart-close { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; color: rgba(166, 196, 229, 0.5); font-size: 28rpx; }
.weight-chart-full { width: 100%; height: 200px; }

/* ── Health conditions ── */

.cond-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.health-cond-chip {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  background: rgba(99, 117, 236, 0.1);
  color: #A6C4E5;
  font-size: 24rpx;
  font-weight: 500;
}

/* ── Biomarker list ── */

.health-empty { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }

.bm-list { display: flex; flex-direction: column; }

.bm-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.07);
}

.bm-row:last-child { border-bottom: none; }

.bm-dot  { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.bm-label { font-size: 26rpx; color: #A6C4E5; flex: 1; }
.bm-val  { font-size: 30rpx; font-weight: 700; }
.bm-unit { font-size: 20rpx; color: rgba(166, 196, 229, 0.4); min-width: 96rpx; text-align: right; }

/* ── Trend grid ── */

.trend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.trend-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 24rpx 24rpx 20rpx;
}

.trend-label {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  color: rgba(166, 196, 229, 0.4);
  text-transform: uppercase;
  margin-bottom: 8rpx;
  display: block;
}

.trend-val-row { display: flex; align-items: baseline; gap: 6rpx; }
.trend-val     { font-size: 32rpx; font-weight: 800; }
.trend-unit    { font-size: 18rpx; color: rgba(166, 196, 229, 0.4); }

.spark-row {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 36rpx;
  margin-top: 14rpx;
}

.spark-bar {
  flex: 1;
  border-radius: 4rpx;
  opacity: 0.55;
  min-height: 6rpx;
}

.spark-bar-empty { opacity: 0.15; }

/* ── Guest lock ── */

.guest-lock-card {
  margin: 64rpx 32rpx 32rpx;
  padding: 64rpx 48rpx;
  background: rgba(15, 37, 64, 0.5);
  border: 1rpx solid rgba(99, 117, 236, 0.15);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 28rpx;
}

.guest-lock-icon { font-size: 72rpx; }

.guest-lock-title {
  font-size: 28rpx;
  color: rgba(166, 196, 229, 0.7);
  line-height: 1.7;
  padding: 0 16rpx;
}

.guest-lock-btn {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 72rpx;
  border-radius: 100rpx;
  box-shadow: 0 8rpx 40rpx rgba(99, 117, 236, 0.4);
}

/* ── Theme-light overrides ── */

.theme-light .health-hero         { border-bottom-color: rgba(201, 149, 106, 0.1); }
.theme-light .health-hero-bg      { background: var(--bg-hero); }
.theme-light .health-avatar-wrap  { border-color: rgba(201, 149, 106, 0.55); box-shadow: 0 0 28rpx rgba(201, 149, 106, 0.15); }
.theme-light .health-avatar-placeholder { background: rgba(250, 247, 242, 0.9); }
.theme-light .health-avatar-letter { color: var(--text-sub); }
.theme-light .bio-chip            { background: var(--navy-card); border-color: rgba(201, 149, 106, 0.25); }
.theme-light .bio-chip-primary    { border-color: rgba(201, 149, 106, 0.55); box-shadow: 0 0 40rpx rgba(201, 149, 106, 0.15); }
.theme-light .bio-chip-dim        { background: rgba(250, 247, 242, 0.6); }
.theme-light .bio-unit            { color: var(--text-muted); }
.theme-light .bio-num-chrono      { color: var(--text-sub); }
.theme-light .bio-bar-track       { background: rgba(201, 149, 106, 0.1); }
.theme-light .bio-bar-label       { color: var(--text-muted); }
.theme-light .bio-bar-ref         { background: rgba(139, 110, 78, 0.3); }
.theme-light .sub-age-card        { background: rgba(255, 255, 255, 0.7); border-color: rgba(201, 149, 106, 0.15); }
.theme-light .sub-age-label       { color: var(--text-muted); }
.theme-light .sub-age-desc        { color: var(--text-muted); }
.theme-light .health-section      { border-bottom-color: rgba(201, 149, 106, 0.08); }
.theme-light .section-title       { color: var(--text-muted); }
.theme-light .section-badge       { background: rgba(201, 149, 106, 0.1); color: var(--text-sub); border-color: rgba(201, 149, 106, 0.2); }
.theme-light .profile-toggle      { background: rgba(201, 149, 106, 0.08); border-color: rgba(201, 149, 106, 0.18); }
.theme-light .profile-toggle-text { color: var(--text-sub); }
.theme-light .profile-toggle-arrow { color: var(--text-muted); }
.theme-light .info-grid-extra     { border-top-color: rgba(201, 149, 106, 0.08); }
.theme-light .info-key            { color: var(--text-muted); }
.theme-light .info-val            { color: var(--text); }
.theme-light .bm-label            { color: var(--text-sub); }
.theme-light .bm-unit             { color: var(--text-muted); }
.theme-light .bm-row              { border-bottom-color: rgba(201, 149, 106, 0.08); }
.theme-light .trend-card          { background: var(--navy-card); border-color: rgba(201, 149, 106, 0.18); }
.theme-light .trend-label         { color: var(--text-muted); }
.theme-light .trend-unit          { color: var(--text-muted); }
.theme-light .health-empty        { color: var(--text-muted); }
.theme-light .health-cond-chip    { border-color: rgba(201, 149, 106, 0.35); background: rgba(201, 149, 106, 0.08); color: var(--text-sub); }
.theme-light .wchart-sheet        { background: var(--bg-sheet); }
.theme-light .wchart-handle       { background: rgba(139, 110, 78, 0.2); }
.theme-light .wchart-title        { color: var(--text); }
.theme-light .wchart-close        { color: var(--text-muted); }
.theme-light .pulse-dot           { background: var(--blue); }
