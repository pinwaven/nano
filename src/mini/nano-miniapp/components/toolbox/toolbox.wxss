.toolbox-panel {
  background: rgba(11, 28, 46, 0.96);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 24rpx 16rpx;
}

.toolbox-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  border-radius: 20rpx;
  padding: 18rpx 28rpx;
  min-width: 148rpx;
}

.tool-item-icon {
  font-size: 30rpx;
  color: #6375EC;
  line-height: 1;
}

.tool-item-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #EEF2FF;
  text-align: center;
}
