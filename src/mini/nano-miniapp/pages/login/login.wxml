<view class="login-screen">
  <view class="login-glow" />

  <view class="login-brand">
    <image class="login-logo-img" src="/assets/waven-logo-icon.png" mode="aspectFit" />
    <text class="login-title">NANO</text>
    <text class="login-subtitle">您的精准健康伴侣</text>
  </view>

  <!-- Checking / auto-login -->
  <view wx:if="{{step === 'checking'}}" class="status-wrap">
    <view class="spinner" />
    <text class="status-text">正在登录…</text>
  </view>

  <!-- Phone binding for new invite-code users -->
  <view wx:elif="{{step === 'phone'}}" class="login-card">
    <text class="login-card-label">最后一步</text>
    <text class="phone-step-desc">绑定手机号，让您的健康顾问可以随时联系到您。</text>
    <button
      class="login-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="handleGetPhone"
      disabled="{{phoneLoading}}"
    ><text>📱 授权手机号</text></button>
    <view class="phone-skip-btn" bindtap="skipPhone">
      <text>稍后再说</text>
    </view>
  </view>

  <!-- Error -->
  <view wx:elif="{{step === 'error'}}" class="status-wrap">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="retry">
      <text>重试</text>
    </view>
  </view>

  <view class="login-footer">
    <text>哈佛大学创新实验室</text>
    <text class="login-footer-dot">·</text>
    <text>成员企业</text>
  </view>
</view>
