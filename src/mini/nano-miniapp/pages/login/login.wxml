<view class="login-screen">
  <view class="login-glow" />

  <view class="login-brand">
    <image class="login-logo-img" src="{{channel.logo_url || '/assets/waven-logo-icon.png'}}" mode="aspectFit" />
    <text class="login-title">{{channel.name || 'NANO'}}</text>
    <text class="login-subtitle">您的精准健康伴侣</text>
  </view>

  <!-- Checking / auto-login -->
  <view wx:if="{{step === 'checking'}}" class="status-wrap">
    <view class="spinner" />
    <text class="status-text">正在登录…</text>
  </view>

  <!-- Code entry for users without an invite link -->
  <view wx:elif="{{step === 'code'}}" class="login-card">
    <text class="login-card-label">输入邀请码</text>
    <text class="login-card-hint">请输入好友分享的6位邀请码</text>
    <input class="code-input" value="{{codeInput}}" bindinput="onCodeInput"
      placeholder="6位邀请码" maxlength="6" type="number" />
    <view class="login-btn {{codeLoading ? 'disabled' : ''}}" bindtap="submitCode">
      <text>{{codeLoading ? '验证中…' : '确认加入'}}</text>
    </view>
  </view>

  <!-- Phone binding for new invite-code users -->
  <view wx:elif="{{step === 'phone'}}" class="login-card">
    <text class="login-card-label">最后一步</text>

    <!-- Avatar picker -->
    <view class="avatar-pick-wrap">
      <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image wx:if="{{pendingAvatar}}" class="avatar-pick-img" src="{{pendingAvatar}}" mode="aspectFill" />
        <view wx:else class="avatar-pick-default">
          <text class="avatar-pick-icon">+</text>
        </view>
      </button>
      <text class="avatar-pick-hint">点击设置头像</text>
    </view>

    <text class="phone-step-desc">绑定手机号，让您的健康教练可以随时联系到您。</text>
    <button
      class="login-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="handleGetPhone"
      disabled="{{phoneLoading}}"
    ><text>📱 授权手机号</text></button>
  </view>

  <!-- Error -->
  <view wx:elif="{{step === 'error'}}" class="status-wrap">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="retry">
      <text>重试</text>
    </view>
  </view>

  <view class="login-footer">
    <text>哈佛大学创新实验室</text>
    <text class="login-footer-dot">·</text>
    <text>成员企业</text>
  </view>
</view>
