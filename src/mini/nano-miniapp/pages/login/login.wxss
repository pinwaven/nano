.login-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 96rpx 64rpx 80rpx;
  background: radial-gradient(ellipse at 50% 20%, #1a3155 0%, #0B1C2E 65%);
  gap: 64rpx;
  position: relative;
  overflow: hidden;
  padding-top: calc(96rpx + env(safe-area-inset-top));
}

.login-glow {
  position: absolute;
  top: -120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(99, 117, 236, 0.25) 0%, transparent 70%);
  pointer-events: none;
}

.login-top-bar {
  position: absolute;
  top: calc(40rpx + env(safe-area-inset-top));
  right: 40rpx;
}

.lang-toggle {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.lang-active { color: #6375EC; }
.lang-dim    { color: rgba(166, 196, 229, 0.4); }
.lang-sep    { opacity: 0.3; font-weight: 400; color: rgba(166, 196, 229, 0.4); }

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.login-logo-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(99, 117, 236, 0.25), rgba(99, 117, 236, 0.05));
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(99, 117, 236, 0.25);
}

.login-logo-letter {
  font-size: 64rpx;
  font-weight: 800;
  color: #EEF2FF;
  opacity: 0.9;
}

.login-title {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 16rpx;
  color: #EEF2FF;
}

.login-subtitle {
  font-size: 24rpx;
  color: rgba(166, 196, 229, 0.4);
  letter-spacing: 1rpx;
  text-align: center;
}

.login-card {
  width: 100%;
  background: rgba(15, 37, 64, 0.6);
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 40rpx;
  padding: 48rpx 44rpx 44rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.login-card-label {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
  text-align: center;
}

.login-field {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.login-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3.6rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.login-input {
  width: 100%;
  padding: 30rpx 32rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  background: #162E4A;
  color: #EEF2FF;
  font-size: 34rpx;
}

.login-input-ph {
  color: rgba(166, 196, 229, 0.4);
  font-size: 28rpx;
}

.login-error {
  font-size: 24rpx;
  line-height: 1.5;
  color: #fca5a5;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
}

.login-btn {
  width: 100%;
  padding: 32rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 40rpx rgba(99, 117, 236, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.login-btn-disabled {
  opacity: 0.35;
  box-shadow: none;
}

.login-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  flex-shrink: 0;
}

@keyframes spin { to { transform: rotate(360deg); } }

.status-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(99, 117, 236, 0.25);
  border-top-color: #6375EC;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.status-text {
  font-size: 26rpx;
  color: rgba(166, 196, 229, 0.6);
}

.error-text {
  font-size: 26rpx;
  color: #fca5a5;
  text-align: center;
  line-height: 1.5;
  padding: 0 40rpx;
}

.retry-btn {
  background: #6375EC;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.login-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.4);
  letter-spacing: 1rpx;
}

.login-footer-dot { opacity: 0.4; }
