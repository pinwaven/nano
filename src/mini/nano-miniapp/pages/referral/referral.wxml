<view class="referral-page {{theme === 'light' ? 'theme-light' : ''}}">
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="app-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
      <text class="back-label">{{t.back}}</text>
    </view>
    <text class="header-title">{{t.title}}</text>
  </view>

  <!-- Referral Code Card -->
  <view class="card">
    <text class="card-label">{{t.yourCode}}</text>
    <view class="code-row">
      <text class="code-value">{{referralCode}}</text>
    </view>
    <view class="btn-row">
      <view class="btn btn-outline" bindtap="copyCode">
        <text>{{t.copyCode}}</text>
      </view>
      <button class="btn btn-primary" open-type="share">
        <text>{{t.shareCard}}</text>
      </button>
    </view>
  </view>

  <!-- How it works -->
  <view class="card how-card">
    <text class="card-label">{{t.howTitle}}</text>
    <view class="how-row"><text class="how-num">1</text><text class="how-text">{{t.how1}}</text></view>
    <view class="how-row"><text class="how-num">2</text><text class="how-text">{{t.how2}}</text></view>
    <view class="how-row"><text class="how-num">3</text><text class="how-text">{{t.how3}}</text></view>
  </view>

  <view class="bottom-safe"></view>
</view>
