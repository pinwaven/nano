.coach-page {
  min-height: 100vh;
  background: #0B1C2E;
  color: #E8F0F8;
}

.status-bar-spacer { width: 100%; }

.coach-header {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #0F2540;
  border-bottom: 1rpx solid #1E3A5F;
}

.header-back, .header-refresh {
  width: 44px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow { font-size: 28px; color: #A6C4E5; }
.refresh-icon { font-size: 20px; color: #A6C4E5; }

.header-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #E8F0F8;
}

.loading-row {
  display: flex;
  justify-content: center;
  padding: 48px 0;
}

.loading-text { color: #7A9ABF; font-size: 14px; }

.client-list { padding: 12px 16px; }

.empty-state {
  display: flex;
  justify-content: center;
  padding: 64px 0;
}

.empty-text { color: #7A9ABF; font-size: 14px; }

.client-card {
  background: #0F2540;
  border-radius: 12px;
  margin-bottom: 12px;
  padding: 16px;
  border: 1rpx solid #1E3A5F;
}

.client-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}

.client-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter { font-size: 18px; font-weight: 700; color: #A6C4E5; }

.client-info { flex: 1; min-width: 0; }

.client-name {
  font-size: 16px;
  font-weight: 600;
  color: #E8F0F8;
  display: block;
  margin-bottom: 6px;
}

.client-ages { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }

.age-chip {
  padding: 2px 8px;
  border-radius: 20px;
  border: 1rpx solid #1E3A5F;
}

.age-chip-text { font-size: 11px; }

.client-joined { font-size: 12px; color: #7A9ABF; }

.client-actions { display: flex; justify-content: flex-end; }

.action-btn {
  padding: 8px 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
}

.send-btn { background: #1E3A5F; border: 1rpx solid #6375EC; }

.action-btn-text { font-size: 13px; color: #A0B4FF; font-weight: 500; }

/* Overlay */
.overlay-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.overlay-panel {
  width: 100%;
  max-height: 80vh;
  background: #0F2540;
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
}

.overlay-header {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1rpx solid #1E3A5F;
}

.overlay-title { flex: 1; font-size: 16px; font-weight: 600; color: #E8F0F8; }

.overlay-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-x { font-size: 16px; color: #7A9ABF; }

.overlay-scroll { flex: 1; overflow: hidden; }

.bm-section { padding: 16px; }

.section-label {
  font-size: 13px;
  color: #7A9ABF;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 12px;
}

.bm-loading, .bm-empty { padding: 24px 0; text-align: center; }

.bm-grid { display: flex; flex-direction: column; gap: 10px; }

.bm-item { display: flex; align-items: center; gap: 10px; }

.bm-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

.bm-info { flex: 1; }

.bm-label { font-size: 13px; color: #A6C4E5; display: block; }
.bm-value { font-size: 14px; color: #E8F0F8; font-weight: 500; }

/* Instruction */
.instr-body { padding: 16px; display: flex; flex-direction: column; gap: 12px; }

.instr-textarea {
  width: 100%;
  min-height: 120px;
  background: #1A2F4A;
  border-radius: 10px;
  padding: 12px;
  font-size: 14px;
  color: #E8F0F8;
  box-sizing: border-box;
}

.instr-send-btn {
  background: #6375EC;
  border-radius: 10px;
  padding: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.instr-send-btn.btn-busy { opacity: 0.6; }

.instr-send-text { font-size: 15px; font-weight: 600; color: #fff; }
