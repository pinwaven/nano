.coach-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0B1C2E;
  color: #E8F0F8;
  overflow: hidden;
}

.swipe-back-hint {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 20rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(232, 240, 248, 0.35);
  pointer-events: none;
  z-index: 10;
}

.status-bar-spacer { width: 100%; flex-shrink: 0; }

/* ── Header (matches user panel exactly) ─────────────────────────────────── */
.app-header {
  background: rgba(11, 28, 46, 0.85);
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 16rpx 36rpx 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-logo-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.header-logo-img {
  width: 56rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.header-title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #EEF2FF;
  flex-shrink: 0;
}

.header-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(99, 117, 236, 0.25);
  flex-shrink: 0;
}

.header-user {
  font-size: 28rpx;
  color: #A6C4E5;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

/* ── Menu dropdown (same as user panel) ─────────────────────────────────── */
.menu-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
}

.menu-dropdown {
  position: absolute;
  left: 24rpx;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
  min-width: 240rpx;
}

.menu-divider {
  height: 1rpx;
  background: rgba(99, 117, 236, 0.15);
  margin: 0 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
}

.menu-item-icon { font-size: 18px; }
.menu-item-label { font-size: 14px; color: #A6C4E5; font-weight: 500; }

/* ── Scrollable content area ─────────────────────────────────────────────── */
.coach-content {
  flex: 1;
  overflow: hidden;
}

/* ── Bottom tab bar (mirrors main page exactly) ──────────────────────────── */
.tab-bar {
  flex-shrink: 0;
  display: flex;
  background: rgba(8, 18, 32, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0 24rpx;
  position: relative;
}

.tab-line {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6375EC, #8B9FFF);
  border-radius: 0 0 6rpx 6rpx;
}

.tab-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.35;
}
.tab-active .tab-icon-img { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: rgba(166, 196, 229, 0.4);
}

.tab-active .tab-label { color: #6375EC; }

.loading-row {
  display: flex;
  justify-content: center;
  padding: 48px 0;
}

.loading-text { color: #7A9ABF; font-size: 14px; }

/* ── Client list ─────────────────────────────────────────────────────────── */
.client-list { padding: 12px 16px; }

.empty-state {
  display: flex;
  justify-content: center;
  padding: 64px 0;
}

.empty-text { color: #7A9ABF; font-size: 14px; }

.client-card {
  background: #0F2540;
  border-radius: 12px;
  margin-bottom: 12px;
  padding: 16px;
  border: 1rpx solid #1E3A5F;
}

.client-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}

.client-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.client-avatar-img {
  width: 44px;
  height: 44px;
  border-radius: 50%;
}

.avatar-letter { font-size: 18px; font-weight: 700; color: #A6C4E5; }

.client-info { flex: 1; min-width: 0; }

.client-name {
  font-size: 16px;
  font-weight: 600;
  color: #E8F0F8;
  display: block;
  margin-bottom: 6px;
}

.client-ages { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }

.age-chip {
  padding: 2px 8px;
  border-radius: 20px;
  border: 1rpx solid #1E3A5F;
}

.age-chip-text { font-size: 11px; }

.client-meta { font-size: 12px; color: #7A9ABF; display: block; margin-top: 2px; }
.client-meta-dim { color: #4A6A8A; }

/* Last user message preview strip */
.last-msg-strip {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin: 10px 0 12px;
  padding: 8px 12px;
  background: #0A1F36;
  border-radius: 8px;
}

.last-msg-time { font-size: 11px; color: #4A6A8A; flex-shrink: 0; }

.last-msg-text {
  font-size: 13px;
  color: #7A9ABF;
  line-height: 1.4;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.client-actions { display: flex; justify-content: flex-end; gap: 8px; }

.action-btn {
  padding: 8px 14px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-btn { background: #1E3A5F; border: 1rpx solid #6375EC; }
.action-btn-text { font-size: 13px; color: #A0B4FF; font-weight: 500; }

.remind-icon-btn { background: transparent; border: 1rpx solid #1E3A5F; padding: 8px 10px; }

/* ── Invite tab ──────────────────────────────────────────────────────────── */
.invite-generate-btn {
  background: #1E3A5F;
  border: 1rpx solid #6375EC;
  border-radius: 10px;
  padding: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.invite-generate-text { font-size: 14px; color: #A0B4FF; font-weight: 600; }

.invite-code-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
}

.invite-code {
  font-family: monospace;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #A0B4FF;
}

.invite-status { padding: 3px 10px; border-radius: 20px; }
.invite-active { background: rgba(99,117,236,0.2); }
.invite-inactive { background: rgba(120,120,120,0.15); }
.invite-status-text { font-size: 11px; font-weight: 600; color: #A0B4FF; }
.invite-inactive .invite-status-text { color: #4A6A8A; }
.invite-uses { font-size: 12px; color: #7A9ABF; }

.deact-btn { background: transparent; border: 1rpx solid rgba(239,68,68,0.3); }
.deact-text { color: #ef4444; }

/* ── Overlay shell ───────────────────────────────────────────────────────── */
.overlay-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.overlay-panel {
  width: 100%;
  height: 82vh;
  background: #0F2540;
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.overlay-header {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1rpx solid #1E3A5F;
  flex-shrink: 0;
}

.overlay-title { flex: 1; font-size: 16px; font-weight: 600; color: #E8F0F8; }

.overlay-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-x { font-size: 16px; color: #7A9ABF; }

/* scrollable content area for health + chat tabs */
.overlay-scroll { flex: 1; overflow: hidden; }

/* ── Detail inner tabs (3-tab) ───────────────────────────────────────────── */
.detail-tabs {
  display: flex;
  border-bottom: 1rpx solid #1E3A5F;
  background: #0A1F36;
  flex-shrink: 0;
}

.detail-tab {
  flex: 1;
  padding: 10px 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-tab-text { font-size: 13px; color: #7A9ABF; font-weight: 500; }
.detail-tab-active .detail-tab-text { color: #A0B4FF; font-weight: 700; }

.panel-center { display: flex; justify-content: center; padding: 36px 0; }

/* ── Health tab ──────────────────────────────────────────────────────────── */
.health-section { padding: 14px 16px 0; }

.section-label {
  font-size: 11px;
  color: #7A9ABF;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 10px;
}

/* Bio Age Trend */
.trend-row {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.trend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 48px;
}

.trend-value { font-size: 16px; font-weight: 700; color: #A0B4FF; }
.trend-date { font-size: 10px; color: #4A6A8A; margin-top: 2px; }

/* Sub-Ages grid */
.sub-age-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.sub-age-card {
  background: #162B45;
  border-radius: 10px;
  padding: 12px 14px;
  border: 1rpx solid #1E3A5F;
}

.sub-age-value { font-size: 20px; font-weight: 700; display: block; margin-bottom: 2px; }
.sub-age-label { font-size: 11px; color: #7A9ABF; }

/* Biomarkers list */
.bm-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-bottom: 20px;
}

.bm-item { display: flex; align-items: center; gap: 10px; }
.bm-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.bm-info { flex: 1; }
.bm-label { font-size: 13px; color: #A6C4E5; display: block; }
.bm-value { font-size: 14px; color: #E8F0F8; font-weight: 500; }

/* ── Unified chat panel (3-way: user + AI + coach) ───────────────────────── */
.chat-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-history { flex: 1; overflow: hidden; }

.chat-section { padding: 12px 16px; }

.chat-list { display: flex; flex-direction: column; gap: 14px; padding-bottom: 16px; }

.chat-row { display: flex; flex-direction: column; }
.chat-row-user  { align-items: flex-end; }
.chat-row-ai    { align-items: flex-start; }
.chat-row-coach { align-items: flex-start; }

.chat-role-label {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}

.chat-role-text { font-size: 11px; color: #7A9ABF; font-weight: 600; }
.chat-time { font-size: 10px; color: #4A6A8A; }

.chat-bubble {
  max-width: 80%;
  padding: 10px 12px;
  border-radius: 12px;
}

.bubble-user  { background: #1E3A5F; border-bottom-right-radius: 4px; }
.bubble-ai    { background: #162B45; border: 1rpx solid #1E3A5F; border-bottom-left-radius: 4px; }
.bubble-coach {
  background: rgba(16, 185, 129, 0.15);
  border: 1rpx solid rgba(16, 185, 129, 0.35);
  border-bottom-left-radius: 4px;
}

.chat-content { font-size: 13px; color: #D0E4F7; line-height: 1.5; }

/* Compose area */
.msg-compose {
  flex-shrink: 0;
  border-top: 1rpx solid #1E3A5F;
  padding: 10px 14px 16px;
  background: #0A1F36;
}

.reminder-trigger {
  padding: 6px 0 8px;
}

.reminder-trigger-text {
  font-size: 12px;
  color: #6375EC;
  font-weight: 500;
}

.compose-row {
  display: flex;
  align-items: flex-end;
  gap: 10px;
}

.compose-input {
  flex: 1;
  min-height: 36px;
  max-height: 100px;
  background: #1A2F4A;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 14px;
  color: #E8F0F8;
  box-sizing: border-box;
}

.compose-send-btn {
  background: #6375EC;
  border-radius: 10px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.compose-send-btn.btn-busy { opacity: 0.5; }
.compose-send-text { font-size: 14px; font-weight: 600; color: #fff; }

/* ── Reminder overlay ────────────────────────────────────────────────────── */
.reminder-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding-bottom: 32px;
}

.instr-textarea {
  width: 100%;
  min-height: 100px;
  background: #1A2F4A;
  border-radius: 10px;
  padding: 12px;
  font-size: 14px;
  color: #E8F0F8;
  box-sizing: border-box;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1rpx solid #1E3A5F;
}

.picker-label { font-size: 14px; color: #A6C4E5; }

.picker-value {
  background: #1A2F4A;
  border-radius: 8px;
  padding: 6px 14px;
}

.picker-value-text { font-size: 14px; color: #A0B4FF; font-weight: 500; }

/* Recurrence toggle chips */
.recurrence-opts { display: flex; gap: 8px; }

.recurrence-opt {
  padding: 5px 12px;
  border-radius: 20px;
  border: 1rpx solid #1E3A5F;
  background: transparent;
}

.recurrence-active { background: rgba(99,117,236,0.2); border-color: #6375EC; }
.recurrence-opt-text { font-size: 12px; color: #7A9ABF; }
.recurrence-active .recurrence-opt-text { color: #A0B4FF; font-weight: 600; }

.instr-send-btn {
  background: #6375EC;
  border-radius: 10px;
  padding: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
}

.instr-send-btn.btn-busy { opacity: 0.6; }
.instr-send-text { font-size: 15px; font-weight: 600; color: #fff; }

/* ── Questionnaires tab ──────────────────────────────────────────────────── */
.q-card-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.q-card-info { flex: 1; min-width: 0; }

.q-card-name {
  font-size: 15px;
  font-weight: 600;
  color: #E8F0F8;
  display: block;
  margin-bottom: 4px;
}

.q-card-desc {
  font-size: 12px;
  color: #7A9ABF;
  display: block;
  margin-bottom: 8px;
  line-height: 1.4;
}

.q-type-badge { display: inline-flex; margin-bottom: 0; }

.q-assign-btn { flex-shrink: 0; align-self: center; }

/* ── Assign overlay ──────────────────────────────────────────────────────── */
.q-assign-quest-banner {
  padding: 10px 20px;
  background: rgba(99,117,236,0.12);
  border-bottom: 1rpx solid #1E3A5F;
  flex-shrink: 0;
}

.q-assign-quest-text { font-size: 13px; color: #A0B4FF; font-weight: 600; }

.q-assign-list { padding: 8px 0; }

.q-assign-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 20px;
  border-bottom: 1rpx solid #1E3A5F;
}

.q-check {
  width: 22px;
  height: 22px;
  border-radius: 6px;
  border: 1rpx solid #4A6A8A;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.q-check-on { background: #6375EC; border-color: #6375EC; }
.q-check-mark { font-size: 13px; color: #fff; font-weight: 700; }

.q-assign-name { font-size: 14px; color: #E8F0F8; }

.q-assign-footer {
  padding: 12px 16px 24px;
  border-top: 1rpx solid #1E3A5F;
  flex-shrink: 0;
}

/* ── Responses overlay ───────────────────────────────────────────────────── */
.q-resp-list { padding: 12px 16px; }

.q-resp-group { margin-bottom: 20px; }

.q-resp-item {
  background: #162B45;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
  border: 1rpx solid #1E3A5F;
}

.q-resp-prompt {
  font-size: 11px;
  color: #7A9ABF;
  display: block;
  margin-bottom: 4px;
}

.q-resp-answer {
  font-size: 14px;
  color: #E8F0F8;
  font-weight: 500;
  display: block;
}

.q-resp-time {
  font-size: 10px;
  color: #4A6A8A;
  display: block;
  margin-top: 4px;
}

.earnings-cards { display: flex; gap: 12px; padding: 16px 16px 0; }
.earnings-card {
  flex: 1;
  background: rgba(30,58,95,0.5);
  border: 1rpx solid #1E3A5F;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.earnings-card-green { border-color: #10b981; background: rgba(16,185,129,0.08); }
.earnings-card-label { font-size: 11px; color: #7A9ABF; }
.earnings-card-value { font-size: 20px; font-weight: 700; color: #E8F0F8; }
.earnings-card-green .earnings-card-value { color: #10b981; }

/* ════════════════════════════════════════════════════════
   LIGHT THEME OVERRIDES
   Applied when .coach-page has class "theme-light"
   ════════════════════════════════════════════════════════ */

/* ── Layout ── */
.theme-light.coach-page {
  background: var(--bg-gradient);
  color: var(--text);
}
.theme-light .status-bar-spacer { background: var(--bg-surface); }

/* ── Header ── */
.theme-light .app-header {
  background: var(--bg-surface);
  border-bottom-color: var(--navy-border);
}
.theme-light .header-title  { color: var(--text); }
.theme-light .header-user   { color: var(--text-sub); }
.theme-light .header-divider { background: rgba(201, 149, 106, 0.25); }

/* ── Menu ── */
.theme-light .menu-dropdown {
  background: var(--navy-card);
  border-color: rgba(201, 149, 106, 0.25);
  box-shadow: 0 8rpx 40rpx rgba(44, 44, 44, 0.12);
}
.theme-light .menu-divider    { background: rgba(201, 149, 106, 0.15); }
.theme-light .menu-item-icon  { color: var(--text-sub); }
.theme-light .menu-item-label { color: var(--text); }

/* ── Tab bar ── */
.theme-light .tab-bar {
  background: var(--bg-tabbar);
  border-top-color: var(--navy-border);
}
.theme-light .tab-label              { color: var(--text-muted); }
.theme-light .tab-active .tab-label  { color: var(--blue); }
.theme-light .tab-icon-img           { filter: brightness(0); opacity: 0.3; }
.theme-light .tab-active .tab-icon-img { filter: brightness(0); opacity: 0.75; }

/* ── Client list ── */
.theme-light .client-card {
  background: var(--navy-card);
  border-color: var(--navy-border);
}
.theme-light .client-name     { color: var(--text); }
.theme-light .client-meta     { color: var(--text-muted); }
.theme-light .avatar-letter   { color: var(--text-sub); }
.theme-light .empty-text      { color: var(--text-muted); }
.theme-light .loading-text    { color: var(--text-muted); }
.theme-light .last-msg-strip  { background: var(--navy-lift); }
.theme-light .last-msg-text   { color: var(--text-muted); }
.theme-light .msg-btn         { background: var(--navy-lift); border-color: var(--blue); }
.theme-light .action-btn-text { color: var(--blue); }
.theme-light .remind-icon-btn { border-color: var(--navy-border); }
.theme-light .section-label   { color: var(--text-muted); }

/* ── Invites tab ── */
.theme-light .invite-generate-btn {
  background: var(--navy-lift);
  border-color: var(--blue);
}
.theme-light .invite-generate-text { color: var(--blue); }
.theme-light .invite-code          { color: var(--blue); }
.theme-light .invite-uses          { color: var(--text-muted); }

/* ── Earnings tab ── */
.theme-light .earnings-card {
  background: var(--navy-lift);
  border-color: var(--navy-border);
}
.theme-light .earnings-card-label { color: var(--text-muted); }
.theme-light .earnings-card-value { color: var(--text); }

/* ── Overlay shell ── */
.theme-light .overlay-panel         { background: var(--navy-card); }
.theme-light .overlay-header        { border-bottom-color: var(--navy-border); }
.theme-light .overlay-title         { color: var(--text); }
.theme-light .close-x               { color: var(--text-muted); }
.theme-light .detail-tabs           { background: var(--navy-lift); border-bottom-color: var(--navy-border); }
.theme-light .detail-tab-text       { color: var(--text-muted); }
.theme-light .detail-tab-active .detail-tab-text { color: var(--blue); }

/* ── Health tab (in overlay) ── */
.theme-light .trend-value   { color: var(--blue); }
.theme-light .trend-date    { color: var(--text-muted); }
.theme-light .sub-age-card  { background: var(--navy-lift); border-color: var(--navy-border); }
.theme-light .sub-age-label { color: var(--text-muted); }
.theme-light .bm-label      { color: var(--text-sub); }
.theme-light .bm-value      { color: var(--text); }

/* ── Unified chat tab (in overlay) ── */
.theme-light .chat-role-text { color: var(--text-muted); }
.theme-light .chat-time      { color: var(--text-muted); }
.theme-light .bubble-user    { background: var(--navy-lift); }
.theme-light .bubble-ai      { background: var(--navy-card); border-color: var(--navy-border); }
.theme-light .bubble-coach   { background: rgba(16, 185, 129, 0.08); border-color: rgba(16, 185, 129, 0.28); }
.theme-light .chat-content   { color: var(--text); }
.theme-light .msg-compose    { background: var(--bg-input); border-top-color: var(--navy-border); }
.theme-light .compose-input  { background: var(--navy-card); color: var(--text); }

/* ── Reminder overlay ── */
.theme-light .instr-textarea    { background: var(--navy-lift); color: var(--text); }
.theme-light .picker-row        { border-bottom-color: var(--navy-border); }
.theme-light .picker-label      { color: var(--text-sub); }
.theme-light .picker-value      { background: var(--navy-lift); }
.theme-light .picker-value-text { color: var(--blue); }
.theme-light .recurrence-opt    { border-color: var(--navy-border); }
.theme-light .recurrence-opt-text { color: var(--text-muted); }
.theme-light .recurrence-active .recurrence-opt-text { color: var(--blue); }

/* ── Questionnaires tab ── */
.theme-light .q-card-name         { color: var(--text); }
.theme-light .q-card-desc         { color: var(--text-muted); }
.theme-light .q-assign-quest-banner {
  background: rgba(201, 149, 106, 0.1);
  border-bottom-color: var(--navy-border);
}
.theme-light .q-assign-quest-text { color: var(--blue); }
.theme-light .q-assign-row        { border-bottom-color: var(--navy-border); }
.theme-light .q-check             { border-color: var(--text-muted); }
.theme-light .q-assign-name       { color: var(--text); }
.theme-light .q-assign-footer     { border-top-color: var(--navy-border); }
.theme-light .q-resp-item         { background: var(--navy-lift); border-color: var(--navy-border); }
.theme-light .q-resp-prompt       { color: var(--text-muted); }
.theme-light .q-resp-answer       { color: var(--text); }
.theme-light .q-resp-time         { color: var(--text-muted); }

