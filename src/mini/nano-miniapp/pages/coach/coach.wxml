        </view>
        <view class="detail-tab {{detailTab === 'plans' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="plans">
          <text class="detail-tab-text">{{t.tabPlans}}</text>
        </view>
        <view class="detail-tab {{detailTab === 'chat' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="chat">
          <text class="detail-tab-text">{{t.tabChat}}</text>
        </view>
        <view class="detail-tab {{detailTab === 'notes' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="notes">
