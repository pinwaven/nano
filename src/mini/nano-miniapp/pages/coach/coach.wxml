  <!-- ── Reminder Composer Overlay ────────────────────────────────────── -->
  <view wx:if="{{reminderOpen}}" class="overlay-mask" catchtouchmove="noop">
    <view class="overlay-panel" catchtap="noop">
      <view class="overlay-header">
        <text class="overlay-title">{{t.reminderTitle}}</text>
        <view class="overlay-close" bindtap="closeReminderComposer">
          <text class="close-x">✕</text>
        </view>
      </view>
      <scroll-view scroll-y class="overlay-scroll">
        <view class="reminder-body">
          <textarea
            class="instr-textarea"
            placeholder="{{t.reminderContentPh}}"
            value="{{reminderText}}"
            bindinput="onReminderTextInput"
            maxlength="300"
            auto-height
          />

          <!-- Date picker -->
          <view class="picker-row">
            <text class="picker-label">{{t.reminderDate}}</text>
            <picker mode="date" value="{{reminderDate}}" bindchange="onReminderDateChange">
              <view class="picker-value">
                <text class="picker-value-text">{{reminderDate || t.selectDate}}</text>
              </view>
            </picker>
          </view>

          <!-- Time picker -->
          <view class="picker-row">
            <text class="picker-label">{{t.reminderTime}}</text>
            <picker mode="time" value="{{reminderTime}}" bindchange="onReminderTimeChange">
              <view class="picker-value">
                <text class="picker-value-text">{{reminderTime || t.selectTime}}</text>
              </view>
            </picker>
          </view>

          <!-- Recurrence toggle -->
          <view class="picker-row">
            <text class="picker-label">{{t.recurrence}}</text>
            <view class="recurrence-opts">
              <view class="recurrence-opt {{reminderRecurrence === 'none' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="none">
                <text class="recurrence-opt-text">{{t.recurrenceNone}}</text>
              </view>
              <view class="recurrence-opt {{reminderRecurrence === 'daily' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="daily">
                <text class="recurrence-opt-text">{{t.recurrenceDaily}}</text>
              </view>
              <view class="recurrence-opt {{reminderRecurrence === 'weekly' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="weekly">
                <text class="recurrence-opt-text">{{t.recurrenceWeekly}}</text>
              </view>
            </view>
          </view>

          <view class="instr-send-btn {{reminderBusy ? 'btn-busy' : ''}}" bindtap="submitReminder">
            <text class="instr-send-text">{{reminderBusy ? t.sending : t.send}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
