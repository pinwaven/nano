      <!-- Unified 3-way chat panel: user + Nano AI + Coach -->
      <view wx:if="{{detailTab === 'chat'}}" class="chat-panel">
        <scroll-view scroll-y class="chat-history" scroll-into-view="{{chatScrollId}}">
          <view class="chat-section">
            <view wx:if="{{chatLoading}}" class="panel-center">
              <text class="loading-text">{{t.loading}}</text>
            </view>
            <view wx:elif="{{chatMessages.length === 0}}" class="panel-center">
              <text class="empty-text">{{t.noChatData}}</text>
            </view>
            <view wx:else class="chat-list">
              <view wx:for="{{chatMessages}}" wx:key="index"
                    id="cmsg{{index}}"
                    class="chat-row {{item._isUser ? 'chat-row-user' : item._isCoach ? 'chat-row-coach' : 'chat-row-ai'}}">
                <view class="chat-role-label">
                  <text class="chat-role-text">{{item._isUser ? t.you : item._isCoach ? t.coachLabel : t.ai}}</text>
                  <text class="chat-time">{{item._time}}</text>
                </view>
                <view class="chat-bubble {{item._isUser ? 'bubble-user' : item._isCoach ? 'bubble-coach' : 'bubble-ai'}}">
                  <text class="chat-content">{{item.content}}</text>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- Pinned compose area -->
        <view class="msg-compose">
          <toolbox wx:if="{{chatToolboxOpen}}" tools="{{chatToolList}}" disabled="{{chatToolBusy}}" bind:toolaction="handleChatToolAction" />
          <view class="reminder-trigger" bindtap="openReminderComposer">
            <text class="reminder-trigger-text">{{t.setReminder}}</text>
          </view>
          <view class="compose-row">
            <view class="chat-plus-btn {{chatToolboxOpen ? 'chat-plus-open' : ''}}" bindtap="toggleChatToolbox">
              <text class="chat-plus-icon">+</text>
            </view>
            <textarea
              class="compose-input"
              placeholder="{{t.msgPh}}"
              value="{{msgText}}"
              bindinput="onMsgInput"
              maxlength="500"
              auto-height
            />
            <view class="compose-send-btn {{msgBusy ? 'btn-busy' : ''}}" bindtap="sendMessage">
              <text class="compose-send-text">{{msgBusy ? '…' : t.send}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Notes panel -->
      <view wx:if="{{detailTab === 'notes'}}" class="overlay-scroll-full">
        <view wx:if="{{clientNotesLoading}}" class="panel-center">
          <text class="loading-text">{{t.loading}}</text>
        </view>
        <block wx:else>
          <view wx:if="{{clientNotes.length === 0}}" class="panel-center">
            <text class="empty-text">{{t.noNotes}}</text>
          </view>
          <view wx:for="{{clientNotes}}" wx:key="id" class="note-item {{item.is_pinned ? 'note-pinned' : ''}}">
            <text class="note-content">{{item.content}}</text>
            <view class="note-footer">
              <text class="note-date">{{item.created_at}}</text>
              <view class="note-actions">
                <text class="note-action-btn" catchtap="toggleNotePin" data-note="{{item}}">{{item.is_pinned ? t.noteUnpin : t.notePin}}</text>
                <text class="note-action-btn note-delete-btn" catchtap="deleteNote" data-id="{{item.id}}">{{t.noteDelete}}</text>
              </view>
            </view>
          </view>
        </block>
        <!-- Compose area -->
        <view class="note-compose">
          <textarea class="note-input" placeholder="{{t.addNotePh}}" value="{{noteText}}" bindinput="onNoteTextInput" maxlength="1000" auto-height />
          <view class="note-save-btn {{notesBusy ? 'btn-busy' : ''}}" bindtap="saveNote">
            <text class="note-save-text">{{notesBusy ? '…' : t.saveNote}}</text>
          </view>
        </view>
      </view>

      <!-- Goals panel -->
      <view wx:if="{{detailTab === 'goals'}}" class="overlay-scroll-full">
        <view wx:if="{{clientGoalsLoading}}" class="panel-center">
          <text class="loading-text">{{t.loading}}</text>
        </view>
        <block wx:else>
          <view class="goals-header">
            <view class="set-goal-btn" bindtap="openGoalForm">
              <text class="set-goal-text">{{t.setGoal}}</text>
            </view>
          </view>
          <view wx:if="{{clientGoals.length === 0}}" class="panel-center">
            <text class="empty-text">{{t.noGoals}}</text>
          </view>
          <view wx:for="{{clientGoals}}" wx:key="id" class="goal-item goal-{{item.status}}">
            <view class="goal-header-row">
              <text class="goal-title">{{item.title_zh}}</text>
              <text class="goal-status-badge goal-status-{{item.status}}">{{item.status === 'achieved' ? t.goalAchieved : item.status === 'missed' ? t.goalMissed : t.goalActive}}</text>
            </view>
            <view wx:if="{{item.baseline_value != null && item.target_value != null}}" class="goal-progress-row">
              <text class="goal-baseline">{{item.baseline_value}}</text>
              <view class="goal-bar-bg">
                <view class="goal-bar-fill" style="width: {{item._pct}}%;"></view>
              </view>
              <text class="goal-target">{{item.target_value}}</text>
            </view>
            <view class="goal-meta-row">
              <text wx:if="{{item.current_value != null}}" class="goal-current">当前: {{item.current_value}}</text>
              <text wx:if="{{item.target_date}}" class="goal-date">截止: {{item.target_date}}</text>
            </view>
          </view>
        </block>
        <!-- Goal form -->
        <view wx:if="{{goalFormOpen}}" class="goal-form-overlay">
          <view class="goal-form-card">
            <picker mode="selector" range="{{['bio_age','sub_age','weight','steps','sleep_score','hrv','custom']}}" bindchange="onGoalTypeChange">
              <view class="goal-form-row">
                <text class="goal-form-label">{{t.goalTypeLabel}}</text>
                <text class="goal-form-value">{{t.goalTypes[goalType] || goalType}}</text>
              </view>
            </picker>
            <view class="goal-form-row">
              <text class="goal-form-label">{{t.goalTargetLabel}}</text>
              <input class="goal-form-input" type="digit" placeholder="0" value="{{goalTargetValue}}" bindinput="onGoalTargetInput" />
            </view>
            <picker mode="date" value="{{goalTargetDate}}" bindchange="onGoalDateChange">
              <view class="goal-form-row">
                <text class="goal-form-label">{{t.goalDateLabel}}</text>
                <text class="goal-form-value">{{goalTargetDate || '—'}}</text>
              </view>
            </picker>
            <view class="goal-form-btns">
              <view class="goal-cancel-btn" bindtap="closeGoalForm"><text>取消</text></view>
              <view class="goal-submit-btn {{goalBusy ? 'btn-busy' : ''}}" bindtap="submitGoal"><text>{{goalBusy ? '…' : '保存'}}</text></view>
            </view>
          </view>
        </view>
      </view>

    </view>
