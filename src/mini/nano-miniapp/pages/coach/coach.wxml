<view class="coach-page {{theme === 'light' ? 'theme-light' : ''}}" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <view class="swipe-back-hint">›</view>
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="app-header" style="padding-right: {{capsuleRightPad}}px;" bindtap="openUserPanel">
    <view class="header-logo-btn">
      <image class="header-logo-img" src="{{channelLogo}}" mode="aspectFit" />
      <text class="header-title">{{channelName}}</text>
    </view>
    <view class="header-divider"></view>
    <text class="header-user">{{nickname}} ({{t.coachLabel}})</text>
  </view>

  <!-- Scrollable content area -->
  <scroll-view scroll-y class="coach-content"
    refresher-enabled="{{tab === 'clients'}}"
    refresher-triggered="{{clientsRefreshing}}"
    bindrefresherrefresh="onClientsRefresh">

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-row">
    <text class="loading-text">{{t.loading}}</text>
  </view>

  <!-- Client List -->
  <view wx:elif="{{tab === 'clients'}}" class="client-list">
    <view wx:if="{{clients.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.noClients}}</text>
    </view>
    <view wx:for="{{clients}}" wx:key="user_id" class="client-card">
      <!-- Top row: avatar + name/ages + delta badge -->
      <view class="client-row" bindtap="openClientDetail" data-client="{{item}}" data-tab="health">
        <view class="client-avatar" style="{{item.avatar_url ? '' : 'background: #1E3A5F;'}}">
          <image wx:if="{{item.avatar_url}}" class="client-avatar-img" src="{{item.avatar_url}}" mode="aspectFill" />
          <text wx:else class="avatar-letter">{{item._avatar}}</text>
        </view>
        <view class="client-info">
          <text class="client-name">{{item.nickname || '—'}}</text>
          <view class="client-ages">
            <view wx:if="{{item._cAge}}" class="age-chip">
              <text class="age-chip-text">{{t.chronoAge}} {{item._cAge}}</text>
            </view>
            <view wx:if="{{item.bio_age}}" class="age-chip" style="background: {{item._bioAgeColor}}20; border-color: {{item._bioAgeColor}};">
              <text class="age-chip-text" style="color: {{item._bioAgeColor}};">{{t.bioAge}} {{item.bio_age}}</text>
            </view>
          </view>
          <text wx:if="{{item._lastScanFmt}}" class="client-meta client-meta-dim">{{t.lastScan}}: {{item._lastScanFmt}}</text>
          <text wx:else class="client-meta client-meta-dim">{{t.joined}}: {{item._joinedFmt}}</text>
        </view>
      </view>

      <!-- Last user message preview -->
      <view wx:if="{{item._lastUserMsg}}" class="last-msg-strip">
        <text wx:if="{{item._lastMsgTimeFmt}}" class="last-msg-time">{{item._lastMsgTimeFmt}}</text>
        <text class="last-msg-text">{{item._lastUserMsg}}</text>
      </view>

      <!-- Actions -->
      <view class="client-actions">
        <view class="action-btn msg-btn" catchtap="openClientDetail" data-client="{{item}}" data-tab="chat">
          <text class="action-btn-text">{{t.openMessages}}</text>
        </view>
        <view class="action-btn remind-icon-btn" catchtap="openQResponses" data-client="{{item}}">
          <text class="action-btn-text">📋</text>
        </view>
        <view class="action-btn remind-icon-btn" catchtap="openReminderComposer" data-client="{{item}}">
          <text class="action-btn-text">⏰</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Invites Tab -->
  <view wx:elif="{{tab === 'invites'}}" class="client-list">
    <view class="invite-generate-btn" bindtap="generateInvite">
      <text class="invite-generate-text">+ {{t.invite.generate}}</text>
    </view>
    <view wx:if="{{invites.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.invite.noInvites}}</text>
    </view>
    <view wx:for="{{invites}}" wx:key="id" class="client-card">
      <view class="invite-code-row">
        <text class="invite-code">{{item.code}}</text>
        <view class="invite-status {{item.is_active ? 'invite-active' : 'invite-inactive'}}">
          <text class="invite-status-text">{{item.is_active ? t.invite.active : t.invite.inactive}}</text>
        </view>
      </view>
      <text class="invite-uses">{{t.invite.uses}}: {{item.use_count}}</text>
      <view class="client-actions" style="margin-top: 12px;">
        <view class="action-btn msg-btn" catchtap="copyInvite" data-invite="{{item}}">
          <text class="action-btn-text">{{t.invite.copy}}</text>
        </view>
        <view wx:if="{{item.is_active}}" class="action-btn deact-btn" catchtap="deactivateInvite" data-invite="{{item}}">
          <text class="action-btn-text deact-text">{{t.invite.deactivate}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Earnings Tab -->
  <view wx:elif="{{tab === 'earnings'}}" class="client-list">
    <view wx:if="{{earningsLoading}}" class="loading-row">
      <text class="loading-text">{{t.loading}}</text>
    </view>
    <block wx:else>
      <!-- Summary cards -->
      <view class="earnings-cards">
        <view class="earnings-card">
          <text class="earnings-card-label">{{t.earnings.thisMonth}}</text>
          <text class="earnings-card-value">{{earningsThisMonth || '¥0.00'}}</text>
        </view>
        <view class="earnings-card earnings-card-green">
          <text class="earnings-card-label">{{t.earnings.available}}</text>
          <text class="earnings-card-value">{{earningsAvailable || '¥0.00'}}</text>
        </view>
      </view>
      <!-- Payout history -->
      <text class="section-label" style="margin: 16px 16px 8px;">{{t.earnings.payoutHistory}}</text>
      <view wx:if="{{earningsPayouts.length === 0}}" class="empty-state">
        <text class="empty-text">{{t.earnings.noPayouts}}</text>
      </view>
      <view wx:for="{{earningsPayouts}}" wx:key="id" class="client-card">
        <view class="invite-code-row">
          <text class="invite-code">{{item.period}}</text>
          <view class="invite-status {{item.status === 'transferred' ? 'invite-active' : 'invite-inactive'}}">
            <text class="invite-status-text">
              {{item.status === 'draft' ? t.earnings.draft : item.status === 'approved' ? t.earnings.approved : t.earnings.transferred}}
            </text>
          </view>
        </view>
        <text class="invite-uses">{{t.earnings.amount}}: {{item._amountFmt}}</text>
      </view>
    </block>
  </view>

  <!-- Questionnaires Tab -->
  <view wx:elif="{{tab === 'questionnaires'}}" class="client-list">
    <view wx:if="{{questionnairesLoading}}" class="loading-row">
      <text class="loading-text">{{t.loading}}</text>
    </view>
    <view wx:elif="{{questionnaires.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.questionnaires.noQuestionnaires}}</text>
    </view>
    <view wx:else>
      <view wx:for="{{questionnaires}}" wx:key="id" class="client-card">
        <view class="q-card-header">
          <view class="q-card-info">
            <text class="q-card-name">{{lang === 'zh' ? (item.name_zh || item.name) : item.name}}</text>
            <text wx:if="{{item.description_zh || item.description}}" class="q-card-desc">
              {{lang === 'zh' ? (item.description_zh || item.description) : (item.description || item.description_zh)}}
            </text>
            <view class="invite-status invite-active q-type-badge">
              <text class="invite-status-text">
                {{item.type === 'onboarding' ? (lang === 'zh' ? '入门' : 'Onboarding') : (lang === 'zh' ? '自定义' : 'Custom')}}
              </text>
            </view>
          </view>
          <view class="action-btn msg-btn q-assign-btn" bindtap="openQAssign" data-q="{{item}}">
            <text class="action-btn-text">{{t.questionnaires.assign}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  </scroll-view>

  <!-- ── Bottom Tab Bar ── -->
  <view class="tab-bar">
    <view class="tab-btn {{tab === 'clients' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="clients">
      <view wx:if="{{tab === 'clients'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/clients.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabs.clients}}</text>
    </view>
    <view class="tab-btn {{tab === 'invites' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="invites">
      <view wx:if="{{tab === 'invites'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/invites.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabs.invites}}</text>
    </view>
    <view class="tab-btn {{tab === 'earnings' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="earnings">
      <view wx:if="{{tab === 'earnings'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/earnings.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabs.earnings}}</text>
    </view>
    <view class="tab-btn {{tab === 'questionnaires' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="questionnaires">
      <view wx:if="{{tab === 'questionnaires'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/questionnaires.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabs.questionnaires}}</text>
    </view>
  </view>

  <!-- ── Client Detail Sheet ───────────────────────────────────────────── -->
  <view wx:if="{{detailOpen}}" class="overlay-mask" catchtouchmove="noop">
    <view class="overlay-panel" catchtap="noop">

      <view class="overlay-header">
        <text class="overlay-title">{{detailClient.nickname || t.detailTitle}}</text>
        <view class="overlay-close" bindtap="closeClientDetail">
          <text class="close-x">✕</text>
        </view>
      </view>

      <!-- 2-tab inner bar -->
      <view class="detail-tabs">
        <view class="detail-tab {{detailTab === 'health' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="health">
          <text class="detail-tab-text">{{t.tabHealth}}</text>
        </view>
        <view class="detail-tab {{detailTab === 'plans' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="plans">
          <text class="detail-tab-text">{{t.tabPlans}}</text>
        </view>
        <view class="detail-tab {{detailTab === 'chat' ? 'detail-tab-active' : ''}}" bindtap="switchDetailTab" data-tab="chat">
          <text class="detail-tab-text">{{t.tabChat}}</text>
        </view>
      </view>

      <!-- Health panel -->
      <scroll-view wx:if="{{detailTab === 'health'}}" scroll-y class="overlay-scroll">
        <view wx:if="{{detailBmLoading}}" class="panel-center">
          <text class="loading-text">{{t.loading}}</text>
        </view>
        <view wx:elif="{{detailBmList.length === 0}}" class="panel-center">
          <text class="empty-text">{{t.noBmData}}</text>
        </view>
        <block wx:else>
          <!-- Bio Age Trend -->
          <view wx:if="{{detailBioAgeTrend.length > 0}}" class="health-section">
            <text class="section-label">{{t.bioAgeTrend}}</text>
            <view class="trend-row">
              <view wx:for="{{detailBioAgeTrend}}" wx:key="index" class="trend-item">
                <text class="trend-value">{{item.bioAge || '—'}}</text>
                <text class="trend-date">{{item.date}}</text>
              </view>
            </view>
          </view>
          <!-- Sub-Ages -->
          <view wx:if="{{detailSubAges.length > 0}}" class="health-section">
            <text class="section-label">{{t.subAges}}</text>
            <view class="sub-age-grid">
              <view wx:for="{{detailSubAges}}" wx:key="key" class="sub-age-card">
                <text class="sub-age-value" style="color: {{item.color}};">{{item.value || '—'}}</text>
                <text class="sub-age-label">{{item.label}}</text>
              </view>
            </view>
          </view>
          <!-- Raw Biomarkers -->
          <view class="health-section">
            <text class="section-label">{{t.biomarkers}}</text>
            <view class="bm-grid">
              <view wx:for="{{detailBmList}}" wx:key="key" class="bm-item">
                <view class="bm-dot" style="background: {{item.color}};"></view>
                <view class="bm-info">
                  <text class="bm-label">{{item.label}}</text>
                  <text class="bm-value">{{item.value !== null ? item.value : '—'}} {{item.unit}}</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>

      <!-- Plans panel -->
      <scroll-view wx:if="{{detailTab === 'plans'}}" scroll-y class="overlay-scroll">
        <view wx:if="{{detailPlansLoading}}" class="panel-center">
          <text class="loading-text">{{t.loading}}</text>
        </view>
        <block wx:else>
          <!-- Active plans list -->
          <view class="plans-coach-header">
            <text class="plans-coach-title">{{t.clientPlans}}</text>
          </view>
          <view wx:if="{{detailPlans.length === 0}}" class="panel-center">
            <text class="empty-text">{{t.noClientPlans}}</text>
          </view>
          <view wx:for="{{detailPlans}}" wx:key="id" class="coach-plan-card">
            <view class="coach-plan-badge coach-plan-{{item.plan_type}}">
              <text>{{item.plan_type === 'primary' ? t.planPrimary : t.planSecondary}}</text>
            </view>
            <text class="coach-plan-name">{{lang === 'zh' ? (item.name_zh || item.custom_name_zh) : (item.name_en || item.custom_name_en)}}</text>
            <text class="coach-plan-meta">{{item.checkin_count || 0}} {{t.planCheckins}} · {{item.duration_weeks}}{{t.planWeeks}}</text>
          </view>

          <!-- Actions -->
          <view class="plans-coach-actions">
            <view class="coach-action-btn" bindtap="openPlanRecommend">
              <text>{{t.recommendPlan}}</text>
            </view>
            <view class="coach-action-btn secondary" bindtap="openPlanCustom">
              <text>{{t.createCustomPlan}}</text>
            </view>
          </view>

          <!-- Recommend sheet -->
          <view wx:if="{{planRecommendOpen}}" class="plans-recommend-sheet">
            <view class="plans-recommend-header">
              <text class="plans-recommend-title">{{t.recommendPlan}}</text>
              <view bindtap="closePlanRecommend" class="close-x-btn"><text>✕</text></view>
            </view>
            <view wx:for="{{planTemplates}}" wx:key="id" class="recommend-tpl-card" bindtap="handleRecommendPlan" data-template-id="{{item.id}}">
              <text class="recommend-tpl-name">{{lang === 'zh' ? item.name_zh : item.name_en}}</text>
              <text class="recommend-tpl-meta">{{item.duration_weeks}}{{t.planWeeks}} · {{item.sub_ages_display}}</text>
            </view>
          </view>

          <!-- Custom plan form -->
          <view wx:if="{{planCustomOpen}}" class="plans-custom-form">
            <view class="plans-recommend-header">
              <text class="plans-recommend-title">{{t.createCustomPlan}}</text>
              <view bindtap="closePlanCustom" class="close-x-btn"><text>✕</text></view>
            </view>
            <view class="form-field">
              <text class="form-label">{{t.customPlanName}}</text>
              <input class="form-input" value="{{planCustomName}}" bindinput="onPlanCustomNameInput" placeholder="{{t.customPlanName}}" />
            </view>
            <view class="form-field">
              <text class="form-label">{{t.customPlanGoal}}</text>
              <input class="form-input" value="{{planCustomGoal}}" bindinput="onPlanCustomGoalInput" placeholder="{{t.customPlanGoal}}" />
            </view>
            <view class="coach-action-btn" bindtap="handleCreateCustomPlan">
              <text>{{planActionBusy ? t.loading : t.createCustomPlan}}</text>
            </view>
          </view>
        </block>
      </scroll-view>

      <!-- Unified 3-way chat panel: user + Nano AI + Coach -->
      <view wx:if="{{detailTab === 'chat'}}" class="chat-panel">
        <scroll-view scroll-y class="chat-history" scroll-into-view="{{chatScrollId}}">
          <view class="chat-section">
            <view wx:if="{{chatLoading}}" class="panel-center">
              <text class="loading-text">{{t.loading}}</text>
            </view>
            <view wx:elif="{{chatMessages.length === 0}}" class="panel-center">
              <text class="empty-text">{{t.noChatData}}</text>
            </view>
            <view wx:else class="chat-list">
              <view wx:for="{{chatMessages}}" wx:key="index"
                    id="cmsg{{index}}"
                    class="chat-row {{item._isUser ? 'chat-row-user' : item._isCoach ? 'chat-row-coach' : 'chat-row-ai'}}">
                <view class="chat-role-label">
                  <text class="chat-role-text">{{item._isUser ? t.you : item._isCoach ? t.coachLabel : t.ai}}</text>
                  <text class="chat-time">{{item._time}}</text>
                </view>
                <view class="chat-bubble {{item._isUser ? 'bubble-user' : item._isCoach ? 'bubble-coach' : 'bubble-ai'}}">
                  <text class="chat-content">{{item.content}}</text>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- Pinned compose area -->
        <view class="msg-compose">
          <toolbox wx:if="{{chatToolboxOpen}}" tools="{{chatToolList}}" disabled="{{chatToolBusy}}" bind:toolaction="handleChatToolAction" />
          <view class="reminder-trigger" bindtap="openReminderComposer">
            <text class="reminder-trigger-text">{{t.setReminder}}</text>
          </view>
          <view class="compose-row">
            <view class="chat-plus-btn {{chatToolboxOpen ? 'chat-plus-open' : ''}}" bindtap="toggleChatToolbox">
              <text class="chat-plus-icon">+</text>
            </view>
            <textarea
              class="compose-input"
              placeholder="{{t.msgPh}}"
              value="{{msgText}}"
              bindinput="onMsgInput"
              maxlength="500"
              auto-height
            />
            <view class="compose-send-btn {{msgBusy ? 'btn-busy' : ''}}" bindtap="sendMessage">
              <text class="compose-send-text">{{msgBusy ? '…' : t.send}}</text>
            </view>
          </view>
        </view>
      </view>

    </view>
  </view>

  <!-- ── Assign Questionnaire Overlay ─────────────────────────────────── -->
  <view wx:if="{{qAssignOpen}}" class="overlay-mask" catchtouchmove="noop">
    <view class="overlay-panel" catchtap="noop">
      <view class="overlay-header">
        <text class="overlay-title">{{t.questionnaires.assignTitle}}</text>
        <view class="overlay-close" bindtap="closeQAssign">
          <text class="close-x">✕</text>
        </view>
      </view>
      <view wx:if="{{qAssignQuestionnaire}}" class="q-assign-quest-banner">
        <text class="q-assign-quest-text">
          {{lang === 'zh' ? (qAssignQuestionnaire.name_zh || qAssignQuestionnaire.name) : qAssignQuestionnaire.name}}
        </text>
      </view>
      <scroll-view scroll-y class="overlay-scroll">
        <view wx:if="{{qAssignClients.length === 0}}" class="panel-center">
          <text class="empty-text">{{t.questionnaires.noClients}}</text>
        </view>
        <view wx:else class="q-assign-list">
          <view wx:for="{{qAssignClients}}" wx:key="user_id" class="q-assign-row" bindtap="toggleQUser" data-uid="{{item.user_id}}">
            <view class="q-check {{item._selected ? 'q-check-on' : ''}}">
              <text wx:if="{{item._selected}}" class="q-check-mark">✓</text>
            </view>
            <text class="q-assign-name">{{item.nickname || item.user_id}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="q-assign-footer">
        <view class="instr-send-btn {{qAssignBusy ? 'btn-busy' : ''}}" bindtap="submitQAssign">
          <text class="instr-send-text">{{qAssignBusy ? t.loading : t.questionnaires.assign}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ── Questionnaire Responses Overlay ───────────────────────────────── -->
  <view wx:if="{{qResponsesOpen}}" class="overlay-mask" catchtouchmove="noop">
    <view class="overlay-panel" catchtap="noop">
      <view class="overlay-header">
        <text class="overlay-title">{{qResponsesUser.nickname}} · {{t.questionnaires.responsesTitle}}</text>
        <view class="overlay-close" bindtap="closeQResponses">
          <text class="close-x">✕</text>
        </view>
      </view>
      <scroll-view scroll-y class="overlay-scroll">
        <view wx:if="{{qResponsesLoading}}" class="panel-center">
          <text class="loading-text">{{t.loading}}</text>
        </view>
        <view wx:elif="{{qResponsesList.length === 0}}" class="panel-center">
          <text class="empty-text">{{t.questionnaires.noResponses}}</text>
        </view>
        <view wx:else class="q-resp-list">
          <view wx:for="{{qResponsesList}}" wx:key="name" class="q-resp-group">
            <text class="section-label">{{item.name}}</text>
            <view wx:for="{{item.items}}" wx:key="index" wx:for-item="resp" class="q-resp-item">
              <text class="q-resp-prompt">{{resp.prompt}}</text>
              <text class="q-resp-answer">{{resp.answer_fmt}}</text>
              <text class="q-resp-time">{{resp.answered_at}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- ── Reminder Composer Overlay ────────────────────────────────────── -->
  <view wx:if="{{reminderOpen}}" class="overlay-mask" catchtouchmove="noop">
    <view class="overlay-panel" catchtap="noop">
      <view class="overlay-header">
        <text class="overlay-title">{{t.reminderTitle}}</text>
        <view class="overlay-close" bindtap="closeReminderComposer">
          <text class="close-x">✕</text>
        </view>
      </view>
      <scroll-view scroll-y class="overlay-scroll">
        <view class="reminder-body">
          <textarea
            class="instr-textarea"
            placeholder="{{t.reminderContentPh}}"
            value="{{reminderText}}"
            bindinput="onReminderTextInput"
            maxlength="300"
            auto-height
          />

          <!-- Date picker -->
          <view class="picker-row">
            <text class="picker-label">{{t.reminderDate}}</text>
            <picker mode="date" value="{{reminderDate}}" bindchange="onReminderDateChange">
              <view class="picker-value">
                <text class="picker-value-text">{{reminderDate || t.selectDate}}</text>
              </view>
            </picker>
          </view>

          <!-- Time picker -->
          <view class="picker-row">
            <text class="picker-label">{{t.reminderTime}}</text>
            <picker mode="time" value="{{reminderTime}}" bindchange="onReminderTimeChange">
              <view class="picker-value">
                <text class="picker-value-text">{{reminderTime || t.selectTime}}</text>
              </view>
            </picker>
          </view>

          <!-- Recurrence toggle -->
          <view class="picker-row">
            <text class="picker-label">{{t.recurrence}}</text>
            <view class="recurrence-opts">
              <view class="recurrence-opt {{reminderRecurrence === 'none' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="none">
                <text class="recurrence-opt-text">{{t.recurrenceNone}}</text>
              </view>
              <view class="recurrence-opt {{reminderRecurrence === 'daily' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="daily">
                <text class="recurrence-opt-text">{{t.recurrenceDaily}}</text>
              </view>
              <view class="recurrence-opt {{reminderRecurrence === 'weekly' ? 'recurrence-active' : ''}}" bindtap="setRecurrence" data-val="weekly">
                <text class="recurrence-opt-text">{{t.recurrenceWeekly}}</text>
              </view>
            </view>
          </view>

          <view class="instr-send-btn {{reminderBusy ? 'btn-busy' : ''}}" bindtap="submitReminder">
            <text class="instr-send-text">{{reminderBusy ? t.sending : t.send}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
