<view class="coach-page {{theme === 'light' ? 'theme-light' : ''}}" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <view class="swipe-back-hint">›</view>
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="app-header" style="padding-right: {{capsuleRightPad}}px;" bindtap="openUserPanel">
    <view class="header-logo-btn">
      <image class="header-logo-img" src="{{channelLogo}}" mode="aspectFit" />
      <text class="header-title">{{channelName}}</text>
    </view>
    <view class="header-divider"></view>
    <text class="header-user">{{nickname}} ({{t.coachLabel}})</text>
  </view>

  <!-- Scrollable content area -->
  <scroll-view scroll-y class="coach-content"
    refresher-enabled="{{tab === 'clients'}}"
    refresher-triggered="{{clientsRefreshing}}"
    bindrefresherrefresh="onClientsRefresh">

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-row">
    <text class="loading-text">{{t.loading}}</text>
  </view>

  <!-- Client List -->
  <view wx:elif="{{tab === 'clients'}}" class="client-list">
    <view wx:if="{{clients.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.noClients}}</text>
    </view>
    <view wx:for="{{clients}}" wx:key="user_id" class="client-card">
      <!-- Top row: avatar + name/ages + delta badge -->
      <view class="client-row" bindtap="openClientDetail" data-client="{{item}}" data-tab="health">
        <view class="client-avatar" style="{{item.avatar_url ? '' : 'background: #1E3A5F;'}}">
          <image wx:if="{{item.avatar_url}}" class="client-avatar-img" src="{{item.avatar_url}}" mode="aspectFill" />
          <text wx:else class="avatar-letter">{{item._avatar}}</text>
        </view>
        <view class="client-info">
          <text class="client-name">{{item.nickname || '—'}}</text>
          <view class="client-ages">
            <view wx:if="{{item._cAge}}" class="age-chip">
              <text class="age-chip-text">{{t.chronoAge}} {{item._cAge}}</text>
            </view>
            <view wx:if="{{item.bio_age}}" class="age-chip" style="background: {{item._bioAgeColor}}20; border-color: {{item._bioAgeColor}};">
              <text class="age-chip-text" style="color: {{item._bioAgeColor}};">{{t.bioAge}} {{item.bio_age}}</text>
            </view>
          </view>
          <text wx:if="{{item._lastScanFmt}}" class="client-meta client-meta-dim">{{t.lastScan}}: {{item._lastScanFmt}}</text>
          <text wx:else class="client-meta client-meta-dim">{{t.joined}}: {{item._joinedFmt}}</text>
        </view>
      </view>

      <!-- CRM Stage pill + tags -->
      <view wx:if="{{item._crmStagePill || item._crmTags.length}}" class="crm-meta-row">
        <view wx:if="{{item._crmStagePill}}" class="stage-pill" style="background: {{item._crmStagePill.color}}22; border-color: {{item._crmStagePill.color}};">
          <text class="stage-pill-text" style="color: {{item._crmStagePill.color}};">{{item._crmStagePill.label}}</text>
        </view>
        <view wx:for="{{item._crmTags}}" wx:key="id" class="tag-chip" style="background: {{item.color_hex}}22; border-color: {{item.color_hex}};">
          <text class="tag-chip-text" style="color: {{item.color_hex}};">{{item.name}}</text>
        </view>
      </view>

      <!-- Last user message preview -->
      <view wx:if="{{item._lastUserMsg}}" class="last-msg-strip">
        <text wx:if="{{item._lastMsgTimeFmt}}" class="last-msg-time">{{item._lastMsgTimeFmt}}</text>
        <text class="last-msg-text">{{item._lastUserMsg}}</text>
      </view>

      <!-- Actions -->
      <view class="client-actions">
        <view class="action-btn msg-btn" catchtap="openClientDetail" data-client="{{item}}" data-tab="chat">
          <text class="action-btn-text">{{t.openMessages}}</text>
        </view>
        <view class="action-btn remind-icon-btn" catchtap="openQResponses" data-client="{{item}}">
          <text class="action-btn-text">📋</text>
        </view>
        <view class="action-btn remind-icon-btn" catchtap="openReminderComposer" data-client="{{item}}">
          <text class="action-btn-text">⏰</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Invites Tab -->
  <view wx:elif="{{tab === 'invites'}}" class="client-list">
    <view class="invite-generate-btn" bindtap="generateInvite">
      <text class="invite-generate-text">+ {{t.invite.generate}}</text>
    </view>
    <view wx:if="{{invites.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.invite.noInvites}}</text>
    </view>
    <view wx:for="{{invites}}" wx:key="id" class="client-card">
      <view class="invite-code-row">
        <text class="invite-code">{{item.code}}</text>
        <view class="invite-status {{item.is_active ? 'invite-active' : 'invite-inactive'}}">
          <text class="invite-status-text">{{item.is_active ? t.invite.active : t.invite.inactive}}</text>
        </view>
      </view>
      <text class="invite-uses">{{t.invite.uses}}: {{item.use_count}}</text>
      <view class="client-actions" style="margin-top: 12px;">
        <view class="action-btn msg-btn" catchtap="copyInvite" data-invite="{{item}}">
          <text class="action-btn-text">{{t.invite.copy}}</text>
        </view>
        <view wx:if="{{item.is_active}}" class="action-btn deact-btn" catchtap="deactivateInvite" data-invite="{{item}}">
          <text class="action-btn-text deact-text">{{t.invite.deactivate}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Earnings Tab -->
  <view wx:elif="{{tab === 'earnings'}}" class="client-list">
    <view wx:if="{{earningsLoading}}" class="loading-row">
      <text class="loading-text">{{t.loading}}</text>
    </view>
    <block wx:else>
      <!-- Summary cards -->
      <view class="earnings-cards">
        <view class="earnings-card">
          <text class="earnings-card-label">{{t.earnings.thisMonth}}</text>
          <text class="earnings-card-value">{{earningsThisMonth || '¥0.00'}}</text>
        </view>
        <view class="earnings-card earnings-card-green">
          <text class="earnings-card-label">{{t.earnings.available}}</text>
          <text class="earnings-card-value">{{earningsAvailable || '¥0.00'}}</text>
        </view>
      </view>
      <!-- Payout history -->
      <text class="section-label" style="margin: 16px 16px 8px;">{{t.earnings.payoutHistory}}</text>
      <view wx:if="{{earningsPayouts.length === 0}}" class="empty-state">
        <text class="empty-text">{{t.earnings.noPayouts}}</text>
      </view>
      <view wx:for="{{earningsPayouts}}" wx:key="id" class="client-card">
        <view class="invite-code-row">
          <text class="invite-code">{{item.period}}</text>
          <view class="invite-status {{item.status === 'transferred' ? 'invite-active' : 'invite-inactive'}}">
            <text class="invite-status-text">
              {{item.status === 'draft' ? t.earnings.draft : item.status === 'approved' ? t.earnings.approved : t.earnings.transferred}}
            </text>
          </view>
        </view>
        <text class="invite-uses">{{t.earnings.amount}}: {{item._amountFmt}}</text>
      </view>
    </block>
  </view>

  <!-- Questionnaires Tab -->
  <view wx:elif="{{tab === 'questionnaires'}}" class="client-list">
    <view wx:if="{{questionnairesLoading}}" class="loading-row">
      <text class="loading-text">{{t.loading}}</text>
    </view>
    <view wx:elif="{{questionnaires.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.questionnaires.noQuestionnaires}}</text>
    </view>
    <view wx:else>
      <view wx:for="{{questionnaires}}" wx:key="id" class="client-card">
        <view class="q-card-header">
          <view class="q-card-info">
            <text class="q-card-name">{{lang === 'zh' ? (item.name_zh || item.name) : item.name}}</text>
            <text wx:if="{{item.description_zh || item.description}}" class="q-card-desc">
              {{lang === 'zh' ? (item.description_zh || item.description) : (item.description || item.description_zh)}}
            </text>
            <view class="invite-status invite-active q-type-badge">
              <text class="invite-status-text">
                {{item.type === 'onboarding' ? (lang === 'zh' ? '入门' : 'Onboarding') : (lang === 'zh' ? '自定义' : 'Custom')}}
              </text>
            </view>
          </view>
          <view class="action-btn msg-btn q-assign-btn" bindtap="openQAssign" data-q="{{item}}">
            <text class="action-btn-text">{{t.questionnaires.assign}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Training Tab -->
  <view wx:elif="{{tab === 'training'}}" class="training-tab">

    <!-- Loading -->
    <view wx:if="{{trainingLoading}}" class="loading-row">
      <text class="loading-text">{{t.loading}}</text>
    </view>

    <!-- LIST VIEW: dashboard + paths + courses + library + certs -->
    <block wx:elif="{{trainingView === 'list'}}">

      <!-- Credit Dashboard -->
      <view wx:if="{{trainingDashboard}}" class="training-dashboard">
        <view class="training-dashboard-credits">
          <text class="training-dashboard-credits-num">{{trainingDashboard.total_credits}}</text>
          <text class="training-dashboard-credits-label">{{lang === 'zh' ? '学分' : 'Credits'}}</text>
        </view>
        <view class="training-dashboard-stats">
          <view class="training-dashboard-tier">
            <text class="training-dashboard-tier-label">{{trainingDashboard.tier}}</text>
          </view>
          <text class="training-dashboard-stat">✅ {{trainingDashboard.completed_lessons}} {{lang === 'zh' ? '课' : 'lessons'}}</text>
          <text class="training-dashboard-stat">🏅 {{trainingDashboard.certifications_count}} {{lang === 'zh' ? '证书' : 'certs'}}</text>
        </view>
      </view>

      <!-- Learning Paths -->
      <view wx:if="{{trainingPaths.length > 0}}" class="training-section-header" style="margin-top: 24rpx;">
        <text class="training-section-title">{{lang === 'zh' ? '学习路径' : 'Learning Paths'}}</text>
      </view>
      <view wx:for="{{trainingPaths}}" wx:key="id" class="training-path-card" bindtap="trainingOpenCourse" data-course="{{item}}">
        <view class="training-path-header">
          <text class="training-path-title">{{item.title}}</text>
          <text class="training-path-tier">{{item.tier}}</text>
        </view>
        <view wx:if="{{item.description}}" class="training-path-desc"><text>{{item.description}}</text></view>
        <view class="training-path-progress-bar">
          <view class="training-path-progress-fill" style="width: {{item._total > 0 ? (item._done / item._total * 100) : 0}}%;" />
        </view>
        <text class="training-path-progress-label">{{item._done}}/{{item._total}} {{lang === 'zh' ? '课程' : 'courses'}}</text>
      </view>

      <!-- Courses -->
      <view class="training-section-header" style="margin-top: 28rpx;">
        <text class="training-section-title">{{t.training.courses}}</text>
      </view>
      <view wx:if="{{trainingCourses.length === 0}}" class="empty-state">
        <text class="empty-text">{{t.training.noTraining}}</text>
      </view>
      <view wx:for="{{trainingCourses}}" wx:key="id" class="training-course-card" bindtap="trainingOpenCourse" data-course="{{item}}">
        <view class="training-course-cover">
          <text class="training-course-cover-text">{{item.title}}</text>
          <view class="training-lesson-badge">
            <text class="training-lesson-badge-text">{{item._lessonCountLabel}}</text>
          </view>
        </view>
        <view class="training-course-body">
          <view class="training-course-meta">
            <text class="training-course-title">{{item.title}}</text>
            <text wx:if="{{item.description}}" class="training-course-desc">{{item.description}}</text>
            <view class="training-course-meta-row">
              <text class="training-course-level">{{item.level}}</text>
              <text class="training-course-credits">+{{item.credit_value}} {{lang === 'zh' ? '学分' : 'cr'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Certifications earned -->
      <view wx:if="{{trainingCertifications.length > 0}}" class="training-section-header" style="margin-top: 28rpx;">
        <text class="training-section-title">{{lang === 'zh' ? '我的证书' : 'My Certifications'}}</text>
      </view>
      <view wx:for="{{trainingCertifications}}" wx:key="id" class="training-cert-card">
        <text class="training-cert-icon">🏅</text>
        <view class="training-cert-info">
          <text class="training-cert-title">{{item.title}}</text>
          <text class="training-cert-tier">{{item.tier}}</text>
        </view>
      </view>

      <!-- Library -->
      <view class="training-section-header" style="margin-top: 28rpx;">
        <text class="training-section-title">{{t.training.library}}</text>
      </view>
      <view wx:if="{{trainingLibrary.length === 0}}" class="empty-state">
        <text class="empty-text">{{t.training.noLibrary}}</text>
      </view>
      <view wx:for="{{trainingLibrary}}" wx:key="id" class="training-library-row" bindtap="trainingOpenLibraryItem" data-item="{{item}}">
        <text class="training-library-icon">📄</text>
        <text class="training-library-title">{{item.title}}</text>
        <text class="training-library-chevron">›</text>
      </view>
    </block>

    <!-- LESSONS VIEW -->
    <block wx:elif="{{trainingView === 'lessons'}}">
      <view class="training-back-row" bindtap="trainingBackToList">
        <text class="training-back-text">{{t.training.backToCourses}}</text>
      </view>
      <view class="training-course-header">
        <text class="training-course-header-title">{{trainingCurrentCourse.title}}</text>
        <text wx:if="{{trainingCurrentCourse.description}}" class="training-course-header-desc">{{trainingCurrentCourse.description}}</text>
        <view class="training-course-meta-row" style="margin-top: 8rpx;">
          <text class="training-course-level">{{trainingCurrentCourse.level}}</text>
          <text class="training-course-credits">+{{trainingCurrentCourse.credit_value}} {{lang === 'zh' ? '学分' : 'cr'}}</text>
        </view>
      </view>
      <view wx:if="{{trainingLessons.length === 0}}" class="empty-state" style="margin-top: 40rpx;">
        <text class="empty-text">{{t.training.noLessons}}</text>
      </view>
      <view wx:for="{{trainingLessons}}" wx:key="id" class="training-lesson-row" bindtap="trainingOpenLesson" data-lesson="{{item}}">
        <view class="training-lesson-num">
          <text class="training-lesson-num-text">{{index + 1}}</text>
        </view>
        <view class="training-lesson-info">
          <text class="training-lesson-title">{{item.title}}</text>
          <text wx:if="{{item.description}}" class="training-lesson-desc">{{item.description}}</text>
          <view class="training-lesson-meta-row">
            <text class="training-lesson-type-badge">{{item.content_type === 'video' ? '🎬' : item.content_type === 'text' ? '📄' : '🧩'}}</text>
            <text class="training-lesson-credits-label">+{{item.credit_value}} {{lang === 'zh' ? '学分' : 'cr'}}</text>
            <text wx:if="{{item.has_quiz}}" class="training-lesson-quiz-badge">📝 {{lang === 'zh' ? '含测验' : 'Quiz'}}</text>
          </view>
        </view>
        <view wx:if="{{trainingCompletedIds.indexOf(item.id) !== -1}}" class="training-lesson-done">
          <text class="training-lesson-done-text">✓</text>
        </view>
        <text wx:else class="training-lesson-chevron">›</text>
      </view>
    </block>

    <!-- PLAYER VIEW (video / text / interactive) -->
    <block wx:elif="{{trainingView === 'player'}}">
      <view class="training-back-row" bindtap="trainingBackToLessons">
        <text class="training-back-text">{{t.training.backToLessons}}</text>
      </view>

      <!-- Video mode -->
      <block wx:if="{{trainingCurrentLesson.content_type === 'video' || !trainingCurrentLesson.content_type}}">
        <view class="training-video-container">
          <video wx:if="{{trainingVideoUrl}}" class="training-video" src="{{trainingVideoUrl}}"
            controls show-fullscreen-btn enable-progress-gesture object-fit="contain" />
          <view wx:else class="training-video-loading">
            <text class="training-video-loading-text">{{t.loading}}</text>
          </view>
        </view>
      </block>

      <!-- Text / Interactive mode -->
      <block wx:elif="{{trainingCurrentLesson.content_type === 'text' || trainingCurrentLesson.content_type === 'interactive'}}">
        <view class="training-text-content">
          <text class="training-text-body">{{trainingTextContent || t.loading}}</text>
        </view>
      </block>

      <!-- Lesson info -->
      <view class="training-lesson-detail">
        <text class="training-lesson-detail-title">{{trainingCurrentLesson.title}}</text>
        <text wx:if="{{trainingCurrentLesson.description}}" class="training-lesson-detail-desc">{{trainingCurrentLesson.description}}</text>

        <!-- Quiz section -->
        <view wx:if="{{trainingQuizQuestions.length > 0}}" class="training-quiz-section">
          <text class="training-quiz-title">{{lang === 'zh' ? '📝 课后测验' : '📝 Quiz'}}</text>

          <!-- Result shown after submit -->
          <view wx:if="{{trainingQuizResult}}" class="training-quiz-result {{trainingQuizResult.passed ? 'training-quiz-passed' : 'training-quiz-failed'}}">
            <text class="training-quiz-result-score">{{trainingQuizResult.score}}%</text>
            <text class="training-quiz-result-label">{{trainingQuizResult.passed ? (lang === 'zh' ? '通过！' : 'Passed!') : (lang === 'zh' ? '未通过，请重试' : 'Not passed, try again')}}</text>
            <text wx:if="{{trainingQuizResult.credits_earned > 0}}" class="training-quiz-result-credits">+{{trainingQuizResult.credits_earned}} {{lang === 'zh' ? '学分' : 'credits'}}</text>
          </view>

          <!-- Questions (shown if no result yet or failed) -->
          <block wx:if="{{!trainingQuizResult || !trainingQuizResult.passed}}">
            <view wx:for="{{trainingQuizQuestions}}" wx:key="id" class="training-quiz-question">
              <text wx:if="{{item.scenario}}" class="training-quiz-scenario">{{item.scenario}}</text>
              <text class="training-quiz-q-text">{{index + 1}}. {{item.question}}</text>
              <view wx:for="{{item.options}}" wx:for-item="opt" wx:for-index="oi" wx:key="oi"
                class="training-quiz-option {{trainingQuizAnswers[item.id] === oi ? 'training-quiz-option-selected' : ''}}"
                bindtap="trainingSelectAnswer" data-question-id="{{item.id}}" data-option-index="{{oi}}">
                <view class="training-quiz-option-radio {{trainingQuizAnswers[item.id] === oi ? 'training-quiz-option-radio-checked' : ''}}" />
                <text class="training-quiz-option-text">{{opt.text}}</text>
              </view>
            </view>
            <view class="training-quiz-submit-btn {{trainingQuizSubmitting ? 'training-mark-btn-busy' : ''}}" bindtap="trainingSubmitQuiz">
              <text class="training-mark-btn-text">{{trainingQuizSubmitting ? t.loading : (lang === 'zh' ? '提交答案' : 'Submit Answers')}}</text>
            </view>
          </block>
        </view>

        <!-- Mark complete / completed badge -->
        <view wx:if="{{trainingCompletedIds.indexOf(trainingCurrentLesson.id) !== -1}}" class="training-completed-badge">
          <text class="training-completed-badge-text">{{t.training.markedComplete}}</text>
        </view>
        <view wx:elif="{{trainingQuizQuestions.length === 0}}"
          class="training-mark-btn {{trainingMarkingComplete ? 'training-mark-btn-busy' : ''}}"
          bindtap="trainingMarkComplete">
          <text class="training-mark-btn-text">{{trainingMarkingComplete ? t.loading : t.training.markComplete}}</text>
        </view>
        <view wx:elif="{{trainingQuizResult && trainingQuizResult.passed}}"
          class="training-mark-btn {{trainingMarkingComplete ? 'training-mark-btn-busy' : ''}}"
          bindtap="trainingMarkComplete">
          <text class="training-mark-btn-text">{{trainingMarkingComplete ? t.loading : t.training.markComplete}}</text>
        </view>
      </view>
    </block>

    <!-- LIBRARY VIEWER -->
    <block wx:elif="{{trainingView === 'library-viewer'}}">
      <view class="training-back-row" bindtap="trainingBackToList">
        <text class="training-back-text">{{t.training.backToCourses}}</text>
      </view>
      <view class="training-library-header">
        <text class="training-library-header-title">{{trainingCurrentLibraryItem.title}}</text>
      </view>
      <view class="training-library-content-scroll">
        <text class="training-library-content-text">{{trainingLibraryContent || t.loading}}</text>
      </view>
    </block>

  </view>

  <!-- CRM Tab -->
  <view wx:elif="{{tab === 'crm'}}" class="crm-tab">
    <view wx:if="{{crmLoading}}" class="panel-center">
      <text class="loading-text">{{t.loading}}</text>
    </view>
    <block wx:else>
      <!-- Section: Pipeline Kanban -->
      <view class="crm-section-header">
        <text class="crm-section-title">{{t.crmPipeline}}</text>
      </view>
      <scroll-view scroll-x class="pipeline-kanban">
        <view wx:for="{{crmPipelineColumns}}" wx:key="stage" class="pipeline-col">
          <view class="pipeline-col-header" style="border-color: {{item.color}};">
            <text class="pipeline-col-title" style="color: {{item.color}};">{{item.label}}</text>
            <view class="pipeline-col-badge" style="background: {{item.color}}33;">
              <text class="pipeline-col-count" style="color: {{item.color}};">{{item.clients.length}}</text>
            </view>
          </view>
          <view wx:for="{{item.clients}}" wx:key="user_id" wx:for-item="client" class="pipeline-card"
                catchtap="openClientDetail" data-client="{{client}}" data-tab="health">
            <text class="pipeline-card-name">{{client.nickname || '—'}}</text>
            <text wx:if="{{client.bio_age && client._cAge}}" class="pipeline-card-delta {{client.bio_age <= client._cAge ? 'delta-good' : 'delta-bad'}}">
              {{client.bio_age <= client._cAge ? '-' : '+'}}{{Math.abs(client.bio_age - client._cAge).toFixed(1)}}yr
            </text>
          </view>
        </view>
      </scroll-view>

      <!-- Section: Upcoming Appointments -->
      <view class="crm-section-header">
        <text class="crm-section-title">{{t.crmAppointments}}</text>
        <view class="crm-section-btn" catchtap="openApptForm" data-client="{{null}}">
          <text class="crm-section-btn-text">{{t.newAppt}}</text>
        </view>
      </view>
      <view wx:if="{{crmUpcomingAppts.length === 0}}" class="panel-center-sm">
        <text class="empty-text-sm">{{t.noAppointments}}</text>
      </view>
      <view wx:for="{{crmUpcomingAppts}}" wx:key="id" class="appt-card">
        <view class="appt-format-badge">
          <text class="appt-format-text">{{t.apptFormats[item.format] || item.format}}</text>
        </view>
        <view class="appt-info">
          <text class="appt-title">{{item.title}}</text>
          <text class="appt-client">{{item.nickname}}</text>
          <text class="appt-time">{{item._timeFmt}}</text>
        </view>
      </view>

      <!-- Section: Activity Feed -->
      <view class="crm-section-header">
        <text class="crm-section-title">{{t.crmActivity}}</text>
      </view>
      <view wx:if="{{crmActivityFeed.length === 0}}" class="panel-center-sm">
        <text class="empty-text-sm">{{t.noActivity}}</text>
      </view>
      <view wx:for="{{crmActivityFeed}}" wx:key="id" class="activity-item">
        <view class="activity-dot"></view>
        <view class="activity-content">
          <text class="activity-label">{{item.nickname}} · {{item._label}}</text>
          <text class="activity-time">{{item._timeFmt}}</text>
        </view>
      </view>

      <!-- Section: KPIs -->
      <view class="crm-section-header" style="margin-top: 24rpx;">
        <text class="crm-section-title">{{t.kpiTitle}}</text>
      </view>
      <view wx:if="{{kpiLoading}}" class="panel-center-sm">
        <text class="loading-text">{{t.loading}}</text>
      </view>
      <block wx:elif="{{kpiData}}">
        <view class="kpi-grid">
