              <text>{{t.createCustomPlan}}</text>
            </view>
          </view>

          <!-- Recommend sheet -->
          <view wx:if="{{planRecommendOpen}}" class="plans-recommend-sheet">
            <view class="plans-recommend-header">
              <text class="plans-recommend-title">{{t.recommendPlan}}</text>
              <view bindtap="closePlanRecommend" class="close-x-btn"><text>✕</text></view>
            </view>
            <view wx:for="{{planTemplates}}" wx:key="id" class="recommend-tpl-card" bindtap="handleRecommendPlan" data-template-id="{{item.id}}">
              <text class="recommend-tpl-name">{{lang === 'zh' ? item.name_zh : item.name_en}}</text>
              <text class="recommend-tpl-meta">{{item.duration_weeks}}{{t.planWeeks}} · {{item.sub_ages_display}}</text>
            </view>
          </view>

          <!-- Custom plan form -->
          <view wx:if="{{planCustomOpen}}" class="plans-custom-form">
            <view class="plans-recommend-header">
              <text class="plans-recommend-title">{{t.createCustomPlan}}</text>
              <view bindtap="closePlanCustom" class="close-x-btn"><text>✕</text></view>
            </view>
            <view class="form-field">
              <text class="form-label">{{t.customPlanName}}</text>
              <input class="form-input" value="{{planCustomName}}" bindinput="onPlanCustomNameInput" placeholder="{{t.customPlanName}}" />
            </view>
            <view class="form-field">
              <text class="form-label">{{t.customPlanGoal}}</text>
              <input class="form-input" value="{{planCustomGoal}}" bindinput="onPlanCustomGoalInput" placeholder="{{t.customPlanGoal}}" />
            </view>
