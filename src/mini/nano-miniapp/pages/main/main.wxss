/* ── Layout ── */

.main {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: radial-gradient(ellipse at 50% 0%, #142847 0%, #0B1C2E 70%);
  overflow: hidden;
}

.tab-hidden { display: none !important; }

/* ── App Header ── */

.status-bar-spacer {
  flex-shrink: 0;
  background: rgba(11, 28, 46, 0.85);
  position: relative;
}

.coach-back-pill {
  position: absolute;
  left: 24rpx;
  bottom: 8rpx;
  font-size: 20rpx;
  color: rgba(99, 117, 236, 0.6);
  letter-spacing: 1rpx;
  pointer-events: none;
}

.app-header {
  background: rgba(11, 28, 46, 0.85);
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 16rpx 36rpx 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-logo-img {
  width: 56rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.header-title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #EEF2FF;
  flex-shrink: 0;
}

.header-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(99, 117, 236, 0.25);
  flex-shrink: 0;
}

.header-user {
  font-size: 28rpx;
  color: #A6C4E5;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.header-logo-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

/* ── Logo menu ── */

.menu-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
}

.menu-dropdown {
  position: absolute;
  left: 24rpx;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
  min-width: 240rpx;
}

.menu-divider {
  height: 1rpx;
  background: rgba(99, 117, 236, 0.15);
  margin: 0 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
}

.menu-item-icon {
  font-size: 28rpx;
  color: #A6C4E5;
}

.menu-item-label {
  font-size: 28rpx;
  color: #EEF2FF;
  font-weight: 500;
}

/* ── Tab content container ── */

.tab-content {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-height: 0;
}

.chat-tab,
.health-tab,
.dots-tab,
.store-tab {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
}

/* ── Tab bar ── */

.tab-bar {
  flex-shrink: 0;
  display: flex;
  background: rgba(8, 18, 32, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0 24rpx;
  position: relative;
}

.tab-line {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6375EC, #8B9FFF);
  border-radius: 0 0 6rpx 6rpx;
}

.tab-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.35;
}
.tab-active .tab-icon-img { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: rgba(166, 196, 229, 0.4);
}

.tab-active .tab-label { color: #6375EC; }

/* ── Chat messages ── */

.chat-messages {
  flex: 1;
  height: 0;
}

.chat-inner {
  padding: 24rpx 28rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.msg-row { display: flex; }
.msg-row-user { justify-content: flex-end; }
.msg-row-ai   { justify-content: flex-start; }

.message-bubble {
  max-width: 90%;
  padding: 18rpx 24rpx;
  border-radius: 28rpx;
}

.message-user {
  background: linear-gradient(135deg, #6375EC 0%, #7B8FFF 100%);
  color: #fff;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 117, 236, 0.45);
}

.message-ai {
  background: #162E4A;
  color: #EEF2FF;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-bottom-left-radius: 6rpx;
}

.message-coach {
  background: rgba(16, 185, 129, 0.12);
  color: #EEF2FF;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
  border-bottom-left-radius: 6rpx;
}

.msg-coach-label {
  font-size: 20rpx;
  color: #10b981;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.msg-bubble-image {
  padding: 0;
  overflow: hidden;
}

.msg-image {
  width: 480rpx;
  border-radius: 16rpx;
  display: block;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.msg-action-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 32rpx;
  background: linear-gradient(135deg, rgba(99, 117, 236, 0.18), rgba(99, 117, 236, 0.08));
  border: 1rpx solid rgba(99, 117, 236, 0.45);
  border-radius: 28rpx;
  border-bottom-left-radius: 6rpx;
  max-width: 72%;
}

.msg-action-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #A0B4FF;
  flex: 1;
}

.msg-action-arrow {
  font-size: 40rpx;
  color: #6375EC;
  line-height: 1;
}

/* Typing indicator */

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 26rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6375EC;
  opacity: 0.6;
  animation: dot-bounce 1.2s infinite ease-in-out;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dot-bounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.35; }
  40%            { transform: scale(1.2); opacity: 1; }
}

/* ── Onboarding bars ── */

.ob-bar {
  flex-shrink: 0;
  padding: 24rpx 28rpx;
  background: rgba(11, 28, 46, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.name-bar {
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.ob-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  border-radius: 24rpx;
  color: #EEF2FF;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 80rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
}

.ob-ph { color: rgba(166, 196, 229, 0.4); }

.ob-confirm {
  background: #6375EC;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 36rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.ob-confirm-off { opacity: 0.35; box-shadow: none; }

.conditions-bar { gap: 20rpx; }

.cond-other-input { width: 100%; box-sizing: border-box; }

.cond-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.cond-chip {
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.08);
  color: rgba(166, 196, 229, 0.7);
  font-size: 26rpx;
  font-weight: 500;
}

.cond-chip-on {
  border-color: #6375EC;
  background: rgba(99, 117, 236, 0.28);
  color: #EEF2FF;
}

.health-cond-chip {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  background: rgba(99, 117, 236, 0.1);
  color: #A6C4E5;
  font-size: 24rpx;
  font-weight: 500;
}

.gender-bar {
  flex-direction: row;
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  background: rgba(99, 117, 236, 0.12);
  color: #EEF2FF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.birthday-bar { gap: 16rpx; }

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  border-radius: 24rpx;
  padding: 22rpx 28rpx;
}

.picker-val  { font-size: 28rpx; color: #EEF2FF; }
.picker-arrow { font-size: 36rpx; color: rgba(166, 196, 229, 0.4); }

.body-bar { gap: 24rpx; }

.slider-row { display: flex; flex-direction: column; gap: 12rpx; }

.slider-labels {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.slider-key {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.slider-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #EEF2FF;
}

.slider-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(166, 196, 229, 0.4);
}

/* ── Chat input area ── */

.input-container {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}

.toolbox-panel {
  background: rgba(11, 28, 46, 0.96);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 24rpx 16rpx;
}

.toolbox-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.28);
  border-radius: 20rpx;
  padding: 18rpx 28rpx;
  min-width: 148rpx;
}

.tool-item-icon {
  font-size: 30rpx;
  color: #6375EC;
  line-height: 1;
}

.tool-item-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #EEF2FF;
  text-align: center;
}

.plus-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(99, 117, 236, 0.12);
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus-btn-open {
  background: rgba(99, 117, 236, 0.3);
  border-color: #6375EC;
}

.plus-icon {
  font-size: 40rpx;
  color: #A6C4E5;
  line-height: 1;
}

.plus-btn-open .plus-icon {
  color: #8B9FFF;
}

.input-area {
  flex-shrink: 0;
  background: rgba(11, 28, 46, 0.92);
  border-top: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.chat-textarea {
  flex: 1;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.22);
  border-radius: 24rpx;
  font-size: 28rpx;
  padding: 18rpx 24rpx;
  color: #EEF2FF;
  min-height: 80rpx;
  max-height: 200rpx;
  line-height: 1.45;
}

.textarea-ph { color: rgba(166, 196, 229, 0.4); }

.send-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(99, 117, 236, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-active {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.send-icon {
  font-size: 36rpx;
  color: #fff;
}

/* ── Health tab ── */

.health-scroll {
  flex: 1;
  height: 0;
}

.center-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 80rpx 0;
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6375EC;
  animation: pulse-dot 1.2s ease-in-out infinite;
}

.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse-dot { 0%, 80%, 100% { opacity: 0.2; } 40% { opacity: 1; } }

/* Health hero */

.health-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 40rpx 72rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.1);
  gap: 36rpx;
  overflow: hidden;
}

.health-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(99, 117, 236, 0.18) 0%, transparent 70%);
  pointer-events: none;
}

/* Health tab personal greeting */
.health-greeting {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
  width: 100%;
}

.health-avatar-container {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.health-avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  opacity: 0;
  z-index: 1;
}

.health-avatar-btn::after { border: none; }

.health-avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  border: 5rpx solid transparent;
  border-top-color: #6375EC;
  border-right-color: #6375EC;
  box-sizing: border-box;
  animation: avatar-spin 0.8s linear infinite;
  pointer-events: none;
}

.health-avatar-wrap {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(99, 117, 236, 0.45);
  box-shadow: 0 0 28rpx rgba(99, 117, 236, 0.22);
}

.health-avatar-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
}

.health-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: #0F2540;
  display: flex;
  align-items: center;
  justify-content: center;
}

.health-avatar-letter {
  font-size: 88rpx;
  font-weight: 700;
  color: #A6C4E5;
}

.health-greeting-name {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(166, 196, 229, 0.85);
  letter-spacing: 1rpx;
}

.bio-row {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  position: relative;
  width: 100%;
}

/* BioAge — primary hero chip */
.bio-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.25);
  border-radius: 28rpx;
  padding: 28rpx 24rpx 22rpx;
}

.bio-chip-primary {
  border-color: rgba(99, 117, 236, 0.55);
  box-shadow: 0 0 40rpx rgba(99, 117, 236, 0.18);
  flex: 1.4;
}

.bio-chip-dim {
  background: rgba(11, 28, 46, 0.5);
  flex: 1;
}

/* BioAge number — the hero figure */
.bio-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.bio-num-primary {
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1;
}

.bio-num-chrono {
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
  color: #A6C4E5;
}

.bio-unit {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.65);
  margin-top: 10rpx;
}

/* Bio-age comparison bars */

.bio-bars {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bio-bar-item { width: 100%; }

.bio-bar-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.bio-bar-label {
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.4rpx;
  color: rgba(166, 196, 229, 0.6);
}

.bio-bar-val {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.bio-bar-track {
  height: 10rpx;
  background: rgba(15, 37, 64, 0.9);
  border-radius: 5rpx;
  position: relative;
  overflow: visible;
}

.bio-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: 5rpx;
  opacity: 0.75;
}

.bio-bar-ref {
  position: absolute;
  left: 50%;
  top: -6rpx;
  height: calc(100% + 12rpx);
  width: 2rpx;
  background: rgba(166, 196, 229, 0.35);
  transform: translateX(-50%);
}

/* Sub-age grid — supporting detail, visually subordinate */

.sub-age-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  width: 100%;
  position: relative;
}

.sub-age-card {
  background: rgba(15, 37, 64, 0.6);
  border: 1rpx solid rgba(99, 117, 236, 0.12);
  border-radius: 20rpx;
  padding: 16rpx 16rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  text-align: center;
}

.sub-age-val {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.1;
}

.sub-age-label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.6);
  margin-top: 4rpx;
}

.sub-age-desc {
  font-size: 17rpx;
  color: rgba(166, 196, 229, 0.35);
  line-height: 1.35;
  margin-top: 4rpx;
}

/* Health sections */

.health-section {
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.health-section:last-child { border-bottom: none; }

.section-title {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
  margin-bottom: 28rpx;
  display: block;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.section-title-row .section-title { margin-bottom: 0; }

.section-badge {
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(99, 117, 236, 0.12);
  color: #A6C4E5;
  border: 1rpx solid rgba(99, 117, 236, 0.2);
  border-radius: 40rpx;
  padding: 4rpx 16rpx;
}

.profile-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(99, 117, 236, 0.08);
  border: 1rpx solid rgba(99, 117, 236, 0.18);
}

.profile-toggle-text { font-size: 22rpx; color: #A6C4E5; font-weight: 600; }
.profile-toggle-arrow { font-size: 18rpx; color: rgba(166, 196, 229, 0.5); }

.info-grid {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 16rpx 24rpx;
}

.info-grid-extra { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(99, 117, 236, 0.08); }

.info-key { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }
.info-val { font-size: 24rpx; color: #EEF2FF; font-weight: 500; }
.info-val-weight { font-size: 32rpx; font-weight: 700; color: #EEF2FF; }

.weight-val-row { display: flex; align-items: center; gap: 16rpx; }
.weight-sparkline { width: 80rpx; height: 28rpx; flex-shrink: 0; }

.wchart-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 120;
  background: rgba(6, 15, 25, 0.75);
  display: flex;
  align-items: flex-end;
}
.wchart-sheet {
  width: 100%;
  background: #0D1E35;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 20rpx 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.wchart-handle {
  width: 64rpx; height: 6rpx;
  border-radius: 3rpx;
  background: rgba(166, 196, 229, 0.2);
  margin-bottom: 24rpx;
}
.wchart-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.wchart-title { font-size: 30rpx; font-weight: 600; color: #EEF2FF; }
.wchart-close { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; color: rgba(166, 196, 229, 0.5); font-size: 28rpx; }
.weight-chart-full { width: 100%; height: 200px; }

.health-empty { font-size: 24rpx; color: rgba(166, 196, 229, 0.4); }

/* Biomarker list */

.bm-list { display: flex; flex-direction: column; }

.bm-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.07);
}

.bm-row:last-child { border-bottom: none; }

.bm-dot  { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.bm-label { font-size: 26rpx; color: #A6C4E5; flex: 1; }
.bm-val  { font-size: 30rpx; font-weight: 700; }
.bm-unit { font-size: 20rpx; color: rgba(166, 196, 229, 0.4); min-width: 96rpx; text-align: right; }

/* Trend grid */

.trend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.trend-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 24rpx 24rpx 20rpx;
}

.trend-label {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  color: rgba(166, 196, 229, 0.4);
  text-transform: uppercase;
  margin-bottom: 8rpx;
  display: block;
}

.trend-val-row { display: flex; align-items: baseline; gap: 6rpx; }
.trend-val     { font-size: 32rpx; font-weight: 800; }
.trend-unit    { font-size: 18rpx; color: rgba(166, 196, 229, 0.4); }

.spark-row {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 36rpx;
  margin-top: 14rpx;
}

.spark-bar {
  flex: 1;
  border-radius: 4rpx;
  opacity: 0.55;
  min-height: 6rpx;
}

.spark-bar-empty {
  opacity: 0.15;
}

/* ── Dots tab ── */

/* Cartridge panel */
.cart-section {
  flex-shrink: 0;
  padding: 36rpx 36rpx 0;
}

.cart-section-hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.cart-section-title {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.cart-sim-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(99, 117, 236, 0.15);
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-sim-btn-icon {
  font-size: 32rpx;
  font-weight: 300;
  color: #6375EC;
  line-height: 1;
  margin-top: -2rpx;
}

.cart-loading {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  height: 160rpx;
}

/* 9 slots per row, 2 rows.
   Usable width = 750 - 72 (padding) = 678rpx.
   8 gaps × 6rpx = 48rpx  →  slot = (678-48)/9 = 70rpx */
.cart-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 6rpx;
}

.cart-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  width: 70rpx;
}

.cart-slot-empty {
  opacity: 0.35;
}

.ink-bar-wrap {
  width: 44rpx;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 10rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.ink-bar-fill {
  width: 100%;
  border-radius: 8rpx;
  min-height: 4rpx;
  transition: height 0.4s ease;
}

.cart-key {
  font-size: 17rpx;
  font-weight: 700;
  color: #A6C4E5;
  letter-spacing: 0.5rpx;
}

.cart-remaining {
  font-size: 15rpx;
  color: rgba(166, 196, 229, 0.4);
}

.cart-empty {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.35);
  padding: 16rpx 0 8rpx;
  line-height: 1.6;
}

.dots-header {
  flex-shrink: 0;
  padding: 28rpx 36rpx 20rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.dots-week-label {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.5);
  font-weight: 500;
}

.dots-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.dots-scroll {
  flex-shrink: 0;
  padding: 0 0 20rpx;
}

.dots-days {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 28rpx;
}

.day-card {
  flex-shrink: 0;
  width: 70vw;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
}

.day-today {
  border-color: rgba(99, 117, 236, 0.55);
  background: rgba(99, 117, 236, 0.08);
}

.day-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #A6C4E5;
  margin-bottom: 20rpx;
  display: block;
}

.day-today .day-label { color: #6375EC; }

.meal-slot { margin-bottom: 16rpx; }
.meal-slot:last-child { margin-bottom: 0; }
.meal-slot-active {
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.35);
  border-radius: 16rpx;
  padding: 12rpx 14rpx;
  margin-left: -14rpx;
  margin-right: -14rpx;
}

.meal-name {
  font-size: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  color: rgba(166, 196, 229, 0.4);
  display: block;
  margin-bottom: 10rpx;
}

.dot-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dot-chip {
  flex: 0 0 100rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  padding: 5rpx 8rpx;
}

.dot-swatch {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-key   { font-size: 18rpx; font-weight: 700; color: #EEF2FF; letter-spacing: 0.3rpx; }
.dot-count { font-size: 18rpx; color: rgba(166, 196, 229, 0.4); }

.dots-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 56rpx;
  font-size: 26rpx;
  color: rgba(166, 196, 229, 0.4);
  line-height: 1.6;
  text-align: center;
}

/* ── Dispense section ──────────────────────────────────────────────────── */
.dispense-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 28rpx 16rpx;
}
.dispense-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #7B8FF5 0%, #5A6AE8 50%, #4352D1 100%);
  box-shadow: 0 8rpx 32rpx rgba(99, 117, 236, 0.45), 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
  position: relative;
  overflow: hidden;
}
.dispense-btn-gloss {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 48rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0) 100%);
  border-radius: 24rpx 24rpx 0 0;
}
.dispense-btn-loading {
  opacity: 0.55;
  box-shadow: none;
}
.dispense-btn-done {
  background: linear-gradient(135deg, #4CD98A 0%, #27AE60 100%);
  box-shadow: 0 8rpx 32rpx rgba(46, 204, 113, 0.4), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
.dispense-btn-error {
  background: linear-gradient(135deg, #F06060 0%, #C0392B 100%);
  box-shadow: 0 8rpx 32rpx rgba(231, 76, 60, 0.4), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
.dispense-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

/* ── Store tab ── */

.store-header {
  flex-shrink: 0;
  padding: 36rpx 36rpx 20rpx;
}

.store-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(166, 196, 229, 0.4);
}

.store-scroll {
  flex: 1;
  height: 0;
}

.store-list {
  padding: 8rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.store-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  position: relative;
  overflow: hidden;
}

.store-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #6375EC, #8B9FFF);
  border-bottom-left-radius: 16rpx;
  padding: 8rpx 20rpx;
}

.store-tag-text {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #fff;
}

.store-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #EEF2FF;
  display: block;
  margin-bottom: 12rpx;
  padding-right: 100rpx;
}

.store-card-desc {
  font-size: 24rpx;
  color: rgba(166, 196, 229, 0.55);
  line-height: 1.5;
  display: block;
  margin-bottom: 32rpx;
}

.store-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.store-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.store-price {
  font-size: 44rpx;
  font-weight: 800;
  color: #EEF2FF;
  line-height: 1;
}

.store-unit {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.4);
}

.store-buy-btn {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  border-radius: 24rpx;
  padding: 22rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(99, 117, 236, 0.45);
}

.store-buy-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5rpx;
}

/* ── Store subtabs ── */

.store-subtab-row {
  flex-shrink: 0;
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx 20rpx;
}

.store-subtab-btn {
  padding: 14rpx 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.06);
  color: rgba(166, 196, 229, 0.5);
  font-size: 24rpx;
  font-weight: 600;
}

.store-subtab-active {
  background: linear-gradient(135deg, #6375EC 0%, #8B9FFF 100%);
  border-color: transparent;
  color: #fff;
}

/* ── Order cards ── */

.order-card {
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.order-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #EEF2FF;
  flex: 1;
}

.order-status {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.order-status-pending   { background: rgba(245,158,11,0.15); color: #f59e0b; }
.order-status-confirmed { background: rgba(59,130,246,0.15); color: #60a5fa; }
.order-status-shipped   { background: rgba(139,92,246,0.15); color: #a78bfa; }
.order-status-delivered { background: rgba(16,185,129,0.15); color: #34d399; }
.order-status-cancelled { background: rgba(100,116,139,0.12); color: #94a3b8; }

.order-card-mid {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.order-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #EEF2FF;
}

.order-meta {
  font-size: 22rpx;
  color: rgba(166, 196, 229, 0.4);
}

.order-date {
  font-size: 20rpx;
  color: rgba(166, 196, 229, 0.3);
}

/* ── Kino chip scan ── */

.kino-scan-bar {
  flex-direction: row;
  align-items: center;
  justify-content: center;
  position: relative;
}

.kino-scan-close {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 32rpx;
}

.kino-scan-btn {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #6375EC;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 56rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 117, 236, 0.5);
}

.kino-scan-icon {
  font-size: 36rpx;
}

.kino-scan-label {
  font-size: 30rpx;
  font-weight: 600;
}

/* ── Cartridge Sim Overlay ── */

.csim-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(6, 15, 25, 0.75);
  display: flex;
  align-items: flex-end;
}

.csim-sheet {
  width: 100%;
  background: #0D1E35;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 20rpx 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.csim-handle {
  width: 64rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(166, 196, 229, 0.2);
  margin-bottom: 32rpx;
}

.csim-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #EEF2FF;
  margin-bottom: 8rpx;
}

.csim-subtitle {
  font-size: 20rpx;
  color: rgba(166, 196, 229, 0.4);
  margin-bottom: 36rpx;
  letter-spacing: 0.5rpx;
}

.csim-sets {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.csim-set-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid transparent;
  border-radius: 20rpx;
  overflow: hidden;
}

.csim-set-accent {
  width: 8rpx;
  flex-shrink: 0;
}

.csim-set-body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.csim-set-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #EEF2FF;
}

.csim-set-desc {
  font-size: 20rpx;
  color: rgba(166, 196, 229, 0.5);
}

.csim-dot-badges {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.csim-dot-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  padding: 5rpx 12rpx 5rpx 10rpx;
}

.csim-badge-key {
  font-size: 17rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
}

.csim-badge-name {
  font-size: 17rpx;
  color: rgba(166, 196, 229, 0.55);
  letter-spacing: 0.5rpx;
}

.csim-loading {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.csim-cancel {
  margin-top: 4rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: rgba(166, 196, 229, 0.4);
}

/* ── Kino Passcode Overlay ── */

.kpass-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 101;
  background: rgba(6, 15, 25, 0.96);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.kpass-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 80rpx;
}

.kpass-logo {
  font-size: 72rpx;
  color: #6375EC;
  margin-bottom: 20rpx;
}

.kpass-title {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #A6C4E5;
  margin-bottom: 48rpx;
}

.kpass-dots {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.kpass-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(99, 117, 236, 0.5);
  background: transparent;
  margin: 0 18rpx;
  transition: background 0.15s;
}

.kpass-dot-filled {
  background: #6375EC;
  border-color: #6375EC;
}

.kpass-dot-error {
  background: #E86060;
  border-color: #E86060;
  animation: kpass-shake 0.4s ease;
}

.kpass-error {
  font-size: 24rpx;
  color: #E86060;
  height: 36rpx;
  line-height: 36rpx;
}

.kpass-numpad {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  width: 100%;
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}

.kpass-key {
  width: 160rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 8rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(99, 117, 236, 0.1);
  border: 1rpx solid rgba(99, 117, 236, 0.2);
  font-size: 40rpx;
  font-weight: 500;
  color: #EEF2FF;
}

.kpass-key-empty {
  background: transparent;
  border-color: transparent;
}

.kpass-key-del {
  background: rgba(99, 117, 236, 0.06);
}

.kpass-del-icon {
  font-size: 36rpx;
  color: #A6C4E5;
}

.kpass-cancel {
  font-size: 26rpx;
  color: rgba(166, 196, 229, 0.4);
  padding: 16rpx 40rpx;
}

@keyframes kpass-shake {
  0%, 100% { transform: translateX(0); }
  20%       { transform: translateX(-8rpx); }
  60%       { transform: translateX(8rpx); }
}

/* ── Kino Simulator Overlay ── */

.ksm-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: radial-gradient(ellipse at 50% 0%, #1a3155 0%, #0B1C2E 65%);
  display: flex;
  flex-direction: column;
}

.ksm-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.ksm-header {
  background: rgba(11, 28, 46, 0.7);
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
  padding: 20rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.ksm-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #EEF2FF;
}

.ksm-serial {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #4a5568;
  margin-top: 4rpx;
}

.ksm-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(99, 117, 236, 0.3);
  background: rgba(99, 117, 236, 0.1);
  color: #A6C4E5;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* scroll-view must not have flex/gap — use an inner wrapper instead */
.ksm-body {
  flex: 1;
}

.ksm-body-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 44rpx 48rpx;
}

/* ── Device ring ── */

.ksm-ring-row {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
}

.ksm-device-wrap {
  position: relative;
  width: 340rpx;
  height: 340rpx;
  flex-shrink: 0;
}

.ksm-ring-track {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  background: conic-gradient(
    #6375EC 0deg,
    #A6C4E5 90deg,
    rgba(15, 37, 64, 0.6) 180deg,
    #6375EC 360deg
  );
  animation: ksm-ring-spin 10s linear infinite;
}

.ksm-state-analyzing .ksm-ring-track {
  animation-duration: 1.8s;
  background: conic-gradient(
    #6375EC 0deg,
    #c0caff 60deg,
    #6375EC 120deg,
    rgba(15, 37, 64, 0.3) 200deg,
    #6375EC 360deg
  );
}

.ksm-state-complete .ksm-ring-track {
  animation-duration: 5s;
  background: conic-gradient(
    #1A8A6A 0deg,
    #6FDFB8 80deg,
    rgba(15, 37, 64, 0.5) 180deg,
    #1A8A6A 360deg
  );
}

.ksm-state-failed .ksm-ring-track {
  animation: none;
  background: conic-gradient(
    #E86060 0deg,
    #FFB3B3 60deg,
    rgba(15, 37, 64, 0.5) 160deg,
    #E86060 360deg
  );
}

.ksm-ring-face {
  position: absolute;
  top: 16rpx; left: 16rpx; right: 16rpx; bottom: 16rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 24rpx rgba(99, 117, 236, 0.06),
              0 8rpx 48rpx rgba(99, 117, 236, 0.18);
}

.ksm-state-analyzing .ksm-ring-face {
  animation: ksm-face-pulse 1.8s ease-in-out infinite;
}

.ksm-face-static,
.ksm-face-slide {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ksm-face-slide {
  opacity: 0;
  transition: opacity 0.3s ease;
}

.ksm-slide-visible { opacity: 1; }

.ksm-face-label {
  font-size: 16rpx;
  letter-spacing: 6rpx;
  color: rgba(26, 62, 95, 0.4);
  margin-bottom: 4rpx;
}

.ksm-face-status {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3E5F;
}

.ksm-face-status-analyzing { color: #6375EC; animation: ksm-text-pulse 1.8s ease-in-out infinite; }
.ksm-face-status-complete  { color: #1A8A6A; }
.ksm-face-status-failed    { color: #E86060; }

.ksm-face-patient-label {
  font-size: 14rpx;
  letter-spacing: 4rpx;
  color: rgba(26, 62, 95, 0.35);
  margin-top: 10rpx;
  margin-bottom: 2rpx;
}

.ksm-face-user {
  font-size: 22rpx;
  color: #6375EC;
  font-weight: 500;
  margin-top: 10rpx;
}

.ksm-slide-index {
  font-size: 16rpx;
  letter-spacing: 2rpx;
  color: rgba(26, 62, 95, 0.35);
  margin-bottom: 6rpx;
}

.ksm-slide-label {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(26, 62, 95, 0.5);
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.ksm-slide-val {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A8A6A;
  line-height: 1;
}

.ksm-slide-unit {
  font-size: 18rpx;
  color: rgba(26, 62, 95, 0.4);
  margin-top: 4rpx;
}

/* ── Results panel ── */

.ksm-results {
  width: 100%;
  background: #0F2540;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}

.ksm-tabs {
  display: flex;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.18);
}

.ksm-tab {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(166, 196, 229, 0.4);
}

.ksm-tab-active {
  color: #6375EC;
  background: rgba(99, 117, 236, 0.06);
  border-bottom: 4rpx solid #6375EC;
}

.ksm-tab-content {
  padding: 24rpx 28rpx;
}

.ksm-bioage-row {
  display: flex;
  margin-bottom: 20rpx;
}

.ksm-bioage-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #162E4A;
  border: 1rpx solid rgba(99, 117, 236, 0.18);
  border-radius: 18rpx;
  padding: 20rpx 8rpx 16rpx;
  margin-right: 14rpx;
}

.ksm-bioage-chip:last-child { margin-right: 0; }

.ksm-bioage-chip-dim { background: rgba(11, 28, 46, 0.5); }

.ksm-bioage-num {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.ksm-bioage-chip-label {
  font-size: 14rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: rgba(166, 196, 229, 0.4);
  margin-top: 10rpx;
}

.ksm-sub-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.ksm-sub-row:last-child { border-bottom: none; }

.ksm-sub-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.ksm-sub-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #A6C4E5;
  flex: 1;
}

.ksm-sub-val {
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ksm-bm-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(99, 117, 236, 0.08);
}

.ksm-bm-row:last-child { border-bottom: none; }

.ksm-bm-label {
  font-size: 24rpx;
  color: #A6C4E5;
  flex: 1;
}

.ksm-bm-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #EEF2FF;
}

.ksm-bm-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: rgba(166, 196, 229, 0.4);
}

/* ── Action button ── */

.ksm-btn {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #6375EC 0%, #7B8FFF 100%);
  box-shadow: 0 8rpx 40rpx rgba(99, 117, 236, 0.45);
}

.ksm-btn-complete {
  background: linear-gradient(135deg, #1A8A6A 0%, #2DBF8A 100%);
  box-shadow: 0 8rpx 40rpx rgba(26, 138, 106, 0.45);
}

.ksm-btn-failed {
  background: linear-gradient(135deg, #C03030 0%, #E86060 100%);
  box-shadow: 0 8rpx 40rpx rgba(232, 96, 96, 0.45);
}

.ksm-btn-analyzing { opacity: 0.7; }

.ksm-quit-btn {
  margin-top: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(166, 196, 229, 0.5);
}

.ksm-dots-row {
  display: flex;
  align-items: center;
}

.ksm-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  animation: ksm-dot-bounce 1.2s ease-in-out infinite;
  margin-right: 10rpx;
}

.ksm-dot:last-child { margin-right: 0; }
.ksm-dot:nth-child(2) { animation-delay: 0.2s; }
.ksm-dot:nth-child(3) { animation-delay: 0.4s; }

/* ── Animations ── */

@keyframes ksm-ring-spin {
  to { transform: rotate(360deg); }
}

@keyframes ksm-face-pulse {
  0%, 100% { box-shadow: inset 0 4rpx 24rpx rgba(99,117,236,0.08), 0 8rpx 64rpx rgba(99,117,236,0.35); }
  50%       { box-shadow: inset 0 4rpx 24rpx rgba(99,117,236,0.08), 0 8rpx 100rpx rgba(99,117,236,0.35); }
}

@keyframes ksm-text-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.45; }
}

@keyframes ksm-dot-bounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%            { transform: scale(1.2); opacity: 1; }
}

