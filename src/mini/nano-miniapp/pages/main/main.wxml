<view class="main {{theme === 'light' ? 'theme-light' : ''}}" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">

  <!-- ── Status bar spacer ── -->
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- ── Header ── -->
  <view class="app-header" style="padding-right: {{capsuleRightPad}}px;" bindtap="toggleMenu">
    <view class="header-logo-btn">
      <image class="header-logo-img" src="{{channel.logo_url || '/assets/waven-logo-icon.png'}}" mode="aspectFit" />
      <text class="header-title">{{channel.name || 'NANO'}}</text>
    </view>
    <view class="header-divider"></view>
    <text class="header-user">{{isGuest ? t.guestHeaderName : (user.nickname || 'User')}}</text>
  </view>

  <!-- ── Logo menu ── -->
  <view wx:if="{{menuOpen}}" class="menu-mask" bindtap="closeMenu">
    <view class="menu-dropdown" catchtap="noop" style="top: {{menuTop}}px;">
      <view wx:if="{{!isGuest && creditBalance > 0}}" class="menu-credit-row" bindtap="openReferral">
        <text class="menu-credit-label">{{lang === 'zh' ? '积分余额' : 'Credits'}}</text>
        <text class="menu-credit-value">{{creditBalance}} pts</text>
      </view>
      <view wx:if="{{!isGuest && creditBalance > 0}}" class="menu-divider"></view>
      <view wx:if="{{isCoach}}" class="menu-item" bindtap="openCoach">
        <text class="menu-item-icon">👨‍⚕️</text>
        <text class="menu-item-label">{{t.coachMenu}}</text>
      </view>
      <view wx:if="{{isAdmin}}" class="menu-divider"></view>
      <view wx:if="{{isAdmin}}" class="menu-item" bindtap="openAdmin">
        <text class="menu-item-icon">⚙</text>
        <text class="menu-item-label">{{t.adminMenu}}</text>
      </view>
      <view wx:if="{{isSuperadmin}}" class="menu-divider"></view>
      <view wx:if="{{isSuperadmin}}" class="menu-item" bindtap="openSuperadmin">
        <text class="menu-item-icon">🌐</text>
        <text class="menu-item-label">{{t.superadminMenu}}</text>
      </view>
      <view wx:if="{{!isGuest}}" class="menu-divider"></view>
      <view wx:if="{{!isGuest}}" class="menu-item" bindtap="openReferral">
        <text class="menu-item-icon">★</text>
        <text class="menu-item-label">{{t.referralMenu}}</text>
      </view>
      <view wx:if="{{!isGuest}}" class="menu-divider"></view>
      <view wx:if="{{!isGuest}}" class="menu-item" bindtap="openKinoSim">
        <text class="menu-item-icon">⬡</text>
        <text class="menu-item-label">{{t.kinoSimMenu}}</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="toggleTheme">
        <text class="menu-item-icon">{{theme === 'dark' ? '☀' : '🌑'}}</text>
        <text class="menu-item-label">{{theme === 'dark' ? t.lightMode : t.darkMode}}</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="toggleLang">
        <text class="menu-item-icon">{{lang === 'zh' ? '🇺🇸' : '🇨🇳'}}</text>
        <text class="menu-item-label">{{lang === 'zh' ? 'English' : '中文'}}</text>
      </view>
      <view class="menu-divider"></view>
      <view wx:if="{{!isGuest}}" class="menu-item" bindtap="handleLogout">
        <text class="menu-item-icon">↪</text>
        <text class="menu-item-label">{{t.logout}}</text>
      </view>
      <view wx:if="{{isGuest}}" class="menu-item" bindtap="openGuestSheet">
        <text class="menu-item-icon">✦</text>
        <text class="menu-item-label">{{t.guestMenuSignUp}}</text>
      </view>
    </view>
  </view>

  <!-- ── Tab Content ── -->
  <view class="tab-content">

    <!-- ════ CHAT ════ -->
    <view class="chat-tab{{tab !== 'chat' ? ' tab-hidden' : ''}}">

      <scroll-view
        class="chat-messages"
        scroll-y="true"
        scroll-top="{{scrollTop}}"
        scroll-with-animation="false"
        enhanced="true"
        bounces="false"
      >
        <view class="chat-inner">

          <view
            wx:for="{{messages}}"
            wx:key="id"
            id="msg{{index}}"
            class="msg-row {{item.role === 'user' ? 'msg-row-user' : 'msg-row-ai'}}"
          >
            <block wx:if="{{item.role === 'action'}}">
              <button
                wx:if="{{item.action === 'bind_phone'}}"
                class="msg-action-card msg-phone-btn"
                open-type="getPhoneNumber"
                bindgetphonenumber="handleBindPhone"
              ><text class="msg-action-label">{{item.label}}</text><text class="msg-action-arrow">›</text></button>
              <view
                wx:else
                class="msg-action-card"
                bindtap="handleMsgAction"
                data-action="{{item.action}}"
              >
                <text class="msg-action-label">{{item.label}}</text>
                <text class="msg-action-arrow">›</text>
              </view>
            </block>
            <view wx:elif="{{item.role === 'coach'}}" class="message-bubble message-coach">
              <text class="msg-coach-label">Coach</text>
              <text class="msg-text" selectable="true">{{item.content}}</text>
            </view>
            <view wx:else class="message-bubble {{item.role === 'user' ? 'message-user' : 'message-ai'}} {{item.imageUrl ? 'msg-bubble-image' : ''}}">
              <image
                wx:if="{{item.imageUrl}}"
                class="msg-image"
                src="{{item.imageUrl}}"
                mode="widthFix"
                show-menu-by-longpress="{{true}}"
              />
              <text wx:elif="{{item.role === 'user'}}" class="msg-text" selectable="true">{{item.content}}</text>
              <mp-html wx:elif="{{item.content}}" content="{{item.content}}" selectable="{{true}}" class="msg-html" /></view>
          </view>

          <view wx:if="{{typing}}" class="msg-row msg-row-ai">
            <view class="message-bubble message-ai typing-indicator">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
          </view>

          <view style="height: 16px;"></view>
        </view>
      </scroll-view>

      <!-- Onboarding: text input -->
      <view wx:if="{{obQuestion && obQuestion.input_type === 'text'}}" class="ob-bar name-bar">
        <input
          class="ob-input"
          placeholder="{{obQuestion.config.placeholder_zh || obQuestion.config.placeholder_en || ''}}"
          placeholder-class="ob-ph"
          value="{{obName}}"
          bindinput="onObNameInput"
          bindconfirm="handleSubmitName"
          focus="{{tab === 'chat' && obQuestion.input_type === 'text'}}"
          adjust-position="true"
        />
        <view class="ob-confirm" bindtap="handleSubmitName">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: button select -->
      <view wx:if="{{obQuestion && obQuestion.input_type === 'button_select' && !typing}}" class="ob-bar gender-bar">
        <view
          wx:for="{{obQuestion.config.options}}"
          wx:key="value"
          class="quick-btn"
          bindtap="handleSelectButton"
          data-value="{{item.value}}"
        >
          <text>{{lang === 'zh' ? item.label_zh : item.label_en}}</text>
        </view>
      </view>

      <!-- Onboarding: date picker -->
      <view wx:if="{{obQuestion && obQuestion.input_type === 'date_picker'}}" class="ob-bar birthday-bar">
        <picker
          mode="date"
          value="{{obBirthday}}"
          start="{{obQuestion.config.min_date || '1920-01-01'}}"
          end="{{obQuestion.config.max_date || '2099-12-31'}}"
          bindchange="onBirthdayChange"
        >
          <view class="picker-row">
            <text class="picker-val">{{obBirthday || t.selectBirthday}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
        <view class="ob-confirm {{obBirthday ? '' : 'ob-confirm-off'}}" bindtap="handleSubmitBirthday">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: slider group -->
      <view wx:if="{{obQuestion && obQuestion.input_type === 'slider_group'}}" class="ob-bar body-bar">
        <view
          wx:for="{{obQuestion.config.sliders}}"
          wx:key="key"
          class="slider-row"
        >
          <view class="slider-labels">
            <text class="slider-key">{{lang === 'zh' ? item.label_zh : item.label_en}}</text>
            <text class="slider-val">{{obSliderDisplay[item.key] || obSliders[item.key]}} <text class="slider-unit">{{item.unit}}</text></text>
          </view>
          <slider
            min="{{item.min}}" max="{{item.max}}" value="{{obSliders[item.key]}}" step="{{item.step}}"
            activeColor="#6375EC" backgroundColor="#162E4A" block-color="#6375EC"
            bindchange="onSliderChange" bindchanging="onSliderChange"
            data-key="{{item.key}}" data-step="{{item.step}}"
            block-size="20"
          />
        </view>
        <view class="ob-confirm" bindtap="handleSubmitBody">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Onboarding: multi select -->
      <view wx:if="{{obQuestion && obQuestion.input_type === 'multi_select'}}" class="ob-bar conditions-bar">
        <view class="cond-chips">
          <view
            wx:for="{{obConditionList}}"
            wx:key="key"
            class="cond-chip {{item.selected ? 'cond-chip-on' : ''}}"
            bindtap="handleToggleCondition"
            data-key="{{item.key}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
        <input
          wx:if="{{obOtherSelected}}"
          class="ob-input cond-other-input"
          placeholder="{{t.obConditionsOtherPh}}"
          placeholder-class="ob-ph"
          value="{{obConditionsOther}}"
          bindinput="onObConditionsOtherInput"
          focus="{{obOtherSelected}}"
          adjust-position="true"
        />
        <view class="ob-confirm" bindtap="handleSubmitConditions">
          <text>{{t.confirm}}</text>
        </view>
      </view>

      <!-- Kino chip scan button -->
      <view wx:if="{{kinoScanPending}}" class="ob-bar kino-scan-bar">
        <view class="kino-scan-btn" bindtap="handleKinoScan">
          <text class="kino-scan-icon">⬡</text>
          <text class="kino-scan-label">{{t.kinoScanBtn}}</text>
        </view>
        <view class="kino-scan-close" bindtap="cancelKinoScan">✕</view>
      </view>

      <!-- Guest CTA bar -->
      <view wx:if="{{isGuest}}" class="guest-cta-bar" bindtap="openGuestSheet">
        <text class="guest-cta-text">{{t.guestChatCtaText}}</text>
        <view class="guest-cta-btn">
          <text>{{t.guestChatCtaBtn}}</text>
        </view>
      </view>

      <!-- AI disclaimer -->
      <view wx:if="{{obStep === 'done' || isGuest}}" class="ai-disclaimer">
        <text class="ai-disclaimer-text">本服务为AI生成内容，结果仅供参考</text>
      </view>

      <!-- Normal chat input -->
      <view wx:if="{{obStep === 'done'}}" class="input-container">
        <toolbox wx:if="{{toolboxOpen}}" tools="{{toolList}}" disabled="{{typing}}" bind:toolaction="handleToolAction" />
        <view class="input-area">
          <view class="plus-btn {{toolboxOpen ? 'plus-btn-open' : ''}}" bindtap="toggleToolbox">
            <text class="plus-icon">+</text>
          </view>
          <textarea
            class="chat-textarea"
            placeholder="{{t.inputPh}}"
            placeholder-class="textarea-ph"
            value="{{chatInput}}"
            bindinput="onChatInput"
            auto-height="true"
            maxlength="500"
            adjust-position="true"
            fixed="true"
            cursor-spacing="12"
            show-confirm-bar="false"
          />
          <view class="send-btn {{chatInput ? 'send-active' : ''}}" bindtap="handleSend">
            <text class="send-icon">↑</text>
          </view>
        </view>
      </view>

    </view>
    <!-- end CHAT -->

    <!-- ════ HEALTH ════ -->
    <view class="health-tab{{tab !== 'health' ? ' tab-hidden' : ''}}">
      <user-health id="health-comp"
        user="{{user}}"
        user-id="{{user.user_id}}"
        lang="{{lang}}"
        mode="self"
        is-guest="{{isGuest}}"
        theme="{{theme}}"
        bindchooseavatar="handleHealthChooseAvatar"
        bindguesttap="openGuestSheet"
        bind:profileUpdated="onProfileUpdated">
      </user-health>
    </view>
    <!-- end HEALTH -->

    <!-- ════ DOTS ════ -->
    <view class="dots-tab{{tab !== 'dots' ? ' tab-hidden' : ''}}">

      <!-- ── Cartridge panel ─────────────────────────────────────────── -->
      <view wx:if="{{!isGuest}}" class="cart-section">
        <view class="cart-section-hdr">
          <text class="cart-section-title">{{t.cartridgeTitle}}</text>
          <view class="cart-sim-btn" bindtap="openCartSim">
            <text class="cart-sim-btn-icon">+</text>
          </view>
        </view>

        <view wx:if="{{cartridgesLoading}}" class="cart-loading">
          <view class="pulse-dot"></view>
          <view class="pulse-dot"></view>
          <view class="pulse-dot"></view>
        </view>

        <view wx:elif="{{cartridges.length > 0}}" class="cart-grid">
          <view
            wx:for="{{cartridges}}"
            wx:key="id"
            class="cart-slot{{item.isEmpty ? ' cart-slot-empty' : ''}}"
          >
            <view class="ink-bar-wrap">
              <view class="ink-bar-fill" style="height:{{item.percent}}%;background:{{item.barColor}};"></view>
            </view>
            <text class="cart-key">{{item.dotKey}}</text>
            <text class="cart-remaining">{{item.remaining}}</text>
          </view>
        </view>

        <view wx:else class="cart-empty">
          <text>{{t.noCartridges}}</text>
        </view>
      </view>

      <!-- ── Weekly plan ─────────────────────────────────────────────── -->
      <view class="dots-header">
        <text class="dots-title">{{t.dotsTitle}}</text>
        <text wx:if="{{weekLabel}}" class="dots-week-label">{{weekLabel}}</text>
      </view>

      <!-- Guest lock -->
      <view wx:if="{{isGuest}}" class="guest-lock-card" bindtap="openGuestSheet">
        <text class="guest-lock-icon">◉</text>
        <text class="guest-lock-title">{{t.guestDotsCta}}</text>
        <view class="guest-lock-btn"><text>{{t.guestJoinBtn}}</text></view>
      </view>

      <view wx:elif="{{dotsLoading}}" class="center-wrap">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>

      <block wx:elif="{{dotsDays.length > 0}}">
        <scroll-view class="dots-scroll" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" scroll-left="{{todayScrollLeft}}">
          <view class="dots-days">
            <view
              wx:for="{{dotsDays}}"
              wx:key="label"
              class="day-card {{item.isToday ? 'day-today' : ''}}"
            >
              <text class="day-label">{{item.label}}</text>

              <view wx:if="{{item.morning.length > 0}}" class="meal-slot{{item.isToday && dispenseSlot === 'morning_cup' ? ' meal-slot-active' : ''}}">
                <text class="meal-name">{{t.morning}}</text>
                <view class="dot-chips">
                  <view
                    wx:for="{{item.morning}}"
                    wx:key="displayKey"
                    wx:for-item="dot"
                    class="dot-chip"
                  >
                    <view class="dot-swatch" style="background: {{dot.color}}"></view>
                    <text class="dot-key">{{dot.displayKey}}</text>
                    <text class="dot-count">×{{dot.count}}</text>
                  </view>
                </view>
              </view>

              <view wx:if="{{item.evening.length > 0}}" class="meal-slot{{item.isToday && dispenseSlot === 'evening_cup' ? ' meal-slot-active' : ''}}">
                <text class="meal-name">{{t.evening}}</text>
                <view class="dot-chips">
                  <view
                    wx:for="{{item.evening}}"
                    wx:key="displayKey"
                    wx:for-item="dot"
                    class="dot-chip"
                  >
                    <view class="dot-swatch" style="background: {{dot.color}}"></view>
                    <text class="dot-key">{{dot.displayKey}}</text>
                    <text class="dot-count">×{{dot.count}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view style="width: 8rpx; flex-shrink: 0;"></view>
          </view>
        </scroll-view>

        <!-- ── Dispense section ─────────────────────────────────────────── -->
        <view wx:if="{{dispenseHasToday}}" class="dispense-section">
          <view
            class="dispense-btn{{dispenseStatus === 'done' ? ' dispense-btn-done' : dispenseStatus === 'error' ? ' dispense-btn-error' : dispenseStatus === 'loading' ? ' dispense-btn-loading' : ''}}"
            bindtap="dispenseToday"
          >
            <view class="dispense-btn-gloss"></view>
            <text class="dispense-btn-text">{{dispenseStatus === 'loading' ? t.dispensing : dispenseStatus === 'done' ? t.dispenseOk : dispenseStatus === 'error' ? t.dispenseErr : t.dispenseBtn}}</text>
          </view>
        </view>
      </block>

      <view wx:elif="{{!dotsLoading}}" class="dots-empty">
        <text>{{t.noPlan}}</text>
      </view>

    </view>
    <!-- end DOTS -->

    <!-- ════ PLANS ════ -->
    <view class="plans-tab{{tab !== 'plans' ? ' tab-hidden' : ''}}">

      <!-- Guest lock -->
      <view wx:if="{{isGuest}}" class="guest-lock-card" bindtap="openGuestSheet">
        <text class="guest-lock-icon">🔒</text>
        <text class="guest-lock-text">{{t.guestLockMsg}}</text>
      </view>

      <!-- Loading -->
      <view wx:elif="{{plansLoading}}" class="plans-loading">
        <text class="loading-dots">···</text>
      </view>

      <block wx:else>
        <scroll-view class="plans-scroll" scroll-y="true">

          <!-- Header row -->
          <view class="plans-header">
            <text class="plans-title">{{t.plansTitle}}</text>
            <view class="plans-browse-btn" bindtap="openPlanBrowse">
              <text class="plans-browse-btn-text">+ {{t.plansBrowse}}</text>
            </view>
          </view>

          <!-- Empty state -->
          <view wx:if="{{activePlans.length === 0}}" class="plans-empty">
            <text class="plans-empty-text">{{t.plansEmpty}}</text>
            <view class="plans-browse-cta" bindtap="openPlanBrowse">
              <text class="plans-browse-cta-text">{{t.plansBrowse}}</text>
            </view>
          </view>

          <!-- Active plan cards -->
          <view wx:for="{{activePlans}}" wx:key="id" class="plan-card" bindtap="openPlanDetail" data-plan="{{item}}">
            <view class="plan-card-header">
              <view class="plan-type-badge plan-type-{{item.plan_type}}">
                <text class="plan-type-text">{{item.plan_type === 'primary' ? t.plansPrimary : t.plansSecondary}}</text>
              </view>
              <text class="plan-card-name">{{lang === 'zh' ? item.name_zh : item.name_en}}</text>
            </view>
            <view class="plan-progress-bar-track">
              <view class="plan-progress-bar-fill" style="width: {{item.progressPct}}%;"></view>
            </view>
            <view class="plan-card-meta-row">
              <text class="plan-meta-item">{{t.plansAdherence}}: {{item.adherencePct}}%</text>
              <text class="plan-meta-item">{{item.weeksDone}}/{{item.totalWeeks}} {{t.plansWeeks}}</text>
            </view>
            <!-- Daily task chips + progress bar -->
            <view class="plan-daily-section">
              <view class="plan-daily-tasks">
                <view wx:for="{{item.todayTasks}}" wx:key="key" wx:for-item="task"
                      class="plan-task-chip {{task.done ? 'plan-task-done' : ''}}"
                      catchtap="handlePlanTask" data-plan-id="{{item.id}}" data-task="{{task.key}}">
                  <text class="plan-task-label">{{lang === 'zh' ? task.labelZh : task.labelEn}}</text>
                  <text class="plan-task-check">{{task.done ? '✓' : '○'}}</text>
                </view>
              </view>
              <view class="plan-daily-bar-row">
                <view class="plan-daily-bar-track">
                  <view class="plan-daily-bar-fill {{item.todayDoneCount === item.todayTasks.length ? 'plan-daily-complete' : ''}}"
                        style="width: {{item.todayProgressPct}}%;"></view>
                </view>
                <text class="plan-daily-count">{{item.todayDoneCount}}/{{item.todayTasks.length}} {{t.todayProgress}}</text>
              </view>
            </view>
          </view>

          <!-- Upcoming Reminders Section -->
          <view wx:if="{{!plansLoading}}" class="reminders-section">
            <text class="reminders-section-title">{{t.remindersTitle}}</text>
            <view wx:if="{{remindersLoading}}" class="reminders-empty"><text class="reminder-date">···</text></view>
            <view wx:elif="{{upcomingReminders.length === 0}}" class="reminders-empty">
              <text class="reminder-date">{{t.remindersEmpty}}</text>
            </view>
            <view wx:for="{{upcomingReminders}}" wx:key="id" class="reminder-card">
              <view class="reminder-card-top">
                <text class="reminder-content">{{item.content}}</text>
                <view class="reminder-source-badge reminder-source-{{item.isCoach ? 'coach' : 'ai'}}">
                  <text class="reminder-source-text">{{item.isCoach ? t.reminderSourceCoach : t.reminderSourceAi}}</text>
                </view>
              </view>
              <view class="reminder-card-bottom">
                <text class="reminder-date">{{item.dateLabel}}</text>
                <view wx:if="{{item.recurrenceLabel}}" class="reminder-recur-badge">
                  <text class="reminder-recur-text">{{item.recurrenceLabel}}</text>
                </view>
              </view>
            </view>
          </view>

          <view style="height: 48rpx;"></view>
        </scroll-view>

      </block>

    </view>
    <!-- end PLANS -->

    <!-- Weight entry modal -->
    <view wx:if="{{planWeightOpen}}" class="modal-overlay" catchtouchmove="noop">
      <view class="modal-sheet" catchtap="noop" style="margin-bottom: {{planWeightKeyboard}}px;">
        <text class="modal-title">{{t.taskWeightTitle}}</text>
        <input class="modal-input" type="digit" placeholder="{{t.taskWeightPlaceholder}}"
               value="{{planWeightInput}}" bindinput="handleWeightInput"
               adjust-position="{{false}}" bindfocus="handleWeightFocus" bindblur="handleWeightBlur" />
        <view class="modal-actions">
          <view class="modal-btn modal-btn-cancel" bindtap="closeWeightTask"><text>{{t.taskWeightCancel}}</text></view>
          <view class="modal-btn modal-btn-confirm" bindtap="handleWeightSubmit"><text>{{t.taskWeightConfirm}}</text></view>
        </view>
      </view>
    </view>

    <!-- Daily questions modal -->
    <view wx:if="{{planQuestionsOpen}}" class="modal-overlay" catchtouchmove="noop">
      <view class="modal-sheet" catchtap="noop">
        <text class="modal-title">{{t.taskQuestionsTitle}}</text>
        <view class="q-row">
          <text class="q-label">{{t.taskQEnergy}}</text>
          <slider min="1" max="5" step="1" value="{{planQuestionsData.energy}}" show-value
                  bindchange="handleQuestionChange" data-key="energy" block-size="20" activeColor="#6375EC" />
        </view>
        <view class="q-row">
          <text class="q-label">{{t.taskQSleep}}</text>
          <slider min="1" max="5" step="1" value="{{planQuestionsData.sleep}}" show-value
                  bindchange="handleQuestionChange" data-key="sleep" block-size="20" activeColor="#6375EC" />
        </view>
        <view class="q-row">
          <text class="q-label">{{t.taskQMood}}</text>
          <slider min="1" max="5" step="1" value="{{planQuestionsData.mood}}" show-value
                  bindchange="handleQuestionChange" data-key="mood" block-size="20" activeColor="#6375EC" />
        </view>
        <view class="modal-actions">
          <view class="modal-btn modal-btn-cancel" bindtap="closeQuestionsTask"><text>{{t.taskQCancel}}</text></view>
          <view class="modal-btn modal-btn-confirm" bindtap="handleQuestionsSubmit"><text>{{t.taskQSubmit}}</text></view>
        </view>
      </view>
    </view>

    <!-- Plan Detail Sheet -->
    <view wx:if="{{planDetailOpen}}" class="overlay-mask" catchtouchmove="noop">
      <view class="overlay-panel" catchtap="noop">

        <view class="overlay-header">
          <text class="overlay-title">{{lang === 'zh' ? planDetailData.name_zh : planDetailData.name_en}}</text>
          <view class="overlay-close" bindtap="closePlanDetail"><text class="close-x">✕</text></view>
        </view>

        <!-- Sub-tab bar -->
        <view class="detail-tabs">
          <view class="detail-tab {{planSubTab === 'overview' ? 'detail-tab-active' : ''}}" bindtap="switchPlanSubTab" data-tab="overview">
            <text class="detail-tab-text">{{t.plansSubTabOverview}}</text>
          </view>
          <view class="detail-tab {{planSubTab === 'progress' ? 'detail-tab-active' : ''}}" bindtap="switchPlanSubTab" data-tab="progress">
            <text class="detail-tab-text">{{t.plansSubTabProgress}}</text>
          </view>
          <view class="detail-tab {{planSubTab === 'activities' ? 'detail-tab-active' : ''}}" bindtap="switchPlanSubTab" data-tab="activities">
            <text class="detail-tab-text">{{t.plansSubTabActivities}}</text>
          </view>
          <view class="detail-tab {{planSubTab === 'guidance' ? 'detail-tab-active' : ''}}" bindtap="switchPlanSubTab" data-tab="guidance">
            <text class="detail-tab-text">{{t.plansSubTabGuidance}}</text>
          </view>
        </view>

        <!-- Overview sub-tab -->
        <scroll-view wx:if="{{planSubTab === 'overview'}}" scroll-y class="overlay-scroll">
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansGoal}}</text>
            <text class="plan-detail-value">{{lang === 'zh' ? planDetailData.goal_zh : planDetailData.goal_en}}</text>
          </view>
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansStartDate}}</text>
            <text class="plan-detail-value">{{planDetailData.start_date}}</text>
          </view>
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansDuration}}</text>
            <text class="plan-detail-value">{{planDetailData.totalWeeks}} {{t.plansWeeks}}</text>
          </view>
          <view wx:if="{{planDetailData.target_sub_ages && planDetailData.target_sub_ages.length > 0}}" class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansTargetSubAges}}</text>
            <view class="plan-chips-row">
              <view wx:for="{{planDetailData.target_sub_ages}}" wx:key="*this" class="plan-chip">
                <text class="plan-chip-text">{{item}}</text>
              </view>
            </view>
          </view>
          <!-- Reminders -->
          <view class="plan-detail-section">
            <text class="plan-detail-label plan-section-label">{{t.planReminders}}</text>
            <view wx:if="{{!planDetailData.reminders || planDetailData.reminders.length === 0}}" class="plan-empty-hint">
              <text>{{t.planNoReminders}}</text>
            </view>
            <view wx:for="{{planDetailData.reminders}}" wx:key="id" class="plan-reminder-row">
              <view class="plan-reminder-info">
                <text class="plan-reminder-time">{{item.timeDisplay}}</text>
                <text class="plan-reminder-content">{{item.content}}</text>
              </view>
              <view class="plan-reminder-toggle {{item.status === 'paused' ? 'reminder-paused' : 'reminder-active'}}"
                    bindtap="handleTogglePlanReminder"
                    data-reminder-id="{{item.id}}"
                    data-current-status="{{item.status}}">
                <text>{{item.status === 'paused' ? t.planReminderResume : t.planReminderPause}}</text>
              </view>
            </view>
          </view>
          <!-- Actions -->
          <view class="plan-actions-row">
            <view class="plan-action-btn plan-action-switch" bindtap="handleSwitchPlanType" data-plan-id="{{planDetailData.id}}" data-current-type="{{planDetailData.plan_type}}">
              <text>{{t.plansSwitch}}</text>
            </view>
            <view class="plan-action-btn plan-action-abandon" bindtap="handleAbandonPlan" data-plan-id="{{planDetailData.id}}">
              <text>{{t.plansAbandon}}</text>
            </view>
          </view>
        </scroll-view>

        <!-- Progress sub-tab -->
        <scroll-view wx:elif="{{planSubTab === 'progress'}}" scroll-y class="overlay-scroll">
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansAdherence}}</text>
            <text class="plan-detail-value">{{planDetailData.adherencePct}}% ({{planDetailData.checkin_count || 0}} {{lang === 'zh' ? '次打卡' : 'check-ins'}})</text>
          </view>
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansWeeks}}</text>
            <text class="plan-detail-value">{{planDetailData.weeksDone}}/{{planDetailData.totalWeeks}}</text>
          </view>
          <view class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansNoMilestones}}</text>
          </view>
        </scroll-view>

        <!-- Activities sub-tab (offline events) -->
        <scroll-view wx:elif="{{planSubTab === 'activities'}}" scroll-y class="overlay-scroll">
          <view wx:if="{{eventsLoading}}" class="panel-center" style="padding:60rpx 0">
            <text class="empty-text">{{t.eventsLoading}}</text>
          </view>
          <view wx:elif="{{events.length === 0}}" class="panel-center" style="padding:60rpx 0">
            <text class="empty-text">{{t.eventsEmpty}}</text>
          </view>
          <view wx:else class="events-list">
            <view wx:for="{{events}}" wx:key="id" class="event-card">
              <view class="event-card-header">
                <text class="event-title">{{item.title}}</text>
                <view wx:if="{{mySignupEventIds.indexOf(item.id) > -1}}" class="event-badge-signed">
                  <text>{{t.eventsSignedUp}}</text>
                </view>
              </view>
              <text class="event-meta">📅 {{item.scheduled_at_display}}</text>
              <text wx:if="{{item.location}}" class="event-meta">📍 {{item.location}}</text>
              <text wx:if="{{item.description}}" class="event-desc">{{item.description}}</text>
              <text wx:if="{{item.capacity}}" class="event-meta">{{t.eventsCapacity}}: {{item.remaining}}/{{item.capacity}}</text>
              <view class="event-card-actions">
                <view wx:if="{{mySignupEventIds.indexOf(item.id) > -1}}"
                      class="event-btn event-btn-cancel"
                      catchtap="handleEventCancelSignup"
                      data-event-id="{{item.id}}">
                  <text>{{t.eventsCancel}}</text>
                </view>
                <view wx:elif="{{item.is_full}}"
                      class="event-btn event-btn-disabled">
                  <text>{{t.eventsFull}}</text>
                </view>
                <view wx:else
                      class="event-btn event-btn-signup"
                      catchtap="handleEventSignUp"
                      data-event-id="{{item.id}}">
                  <text>{{t.eventsSignUp}}</text>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- Guidance sub-tab -->
        <scroll-view wx:elif="{{planSubTab === 'guidance'}}" scroll-y class="overlay-scroll">
          <view class="plan-detail-section">
            <text class="plan-detail-value">{{lang === 'zh' ? (planDetailData.desc_zh || planDetailData.goal_zh) : (planDetailData.desc_en || planDetailData.goal_en)}}</text>
          </view>
          <view wx:if="{{planDetailData.recommended_dot_ids && planDetailData.recommended_dot_ids.length > 0}}" class="plan-detail-section">
            <text class="plan-detail-label">{{t.plansRecommendedDots}}</text>
            <view class="plan-chips-row">
              <view wx:for="{{planDetailData.recommended_dot_ids}}" wx:key="*this" class="plan-chip plan-chip-dot">
                <text class="plan-chip-text">DOT{{item}}</text>
              </view>
            </view>
          </view>
        </scroll-view>

      </view>
    </view>

    <!-- Plan Browse Sheet -->
    <view wx:if="{{planBrowseOpen}}" class="overlay-mask" catchtouchmove="noop">
      <view class="overlay-panel" catchtap="noop">
        <view class="overlay-header">
          <text class="overlay-title">{{t.plansTemplates}}</text>
          <view class="overlay-close" bindtap="closePlanBrowse"><text class="close-x">✕</text></view>
        </view>
        <scroll-view scroll-y class="overlay-scroll">
          <view wx:for="{{planTemplates}}" wx:key="id" class="browse-tpl-card">
            <text class="browse-tpl-name">{{lang === 'zh' ? item.name_zh : item.name_en}}</text>
            <text class="browse-tpl-goal">{{lang === 'zh' ? item.goal_zh : item.goal_en}}</text>
            <text class="browse-tpl-meta">{{item.duration_weeks}} {{t.plansWeeks}} · {{item.sub_ages_display}}</text>
            <view class="browse-tpl-actions">
              <view wx:if="{{item.alreadyEnrolled}}" class="browse-enrolled-badge">
                <text>{{t.plansAlreadyEnrolled}}</text>
              </view>
              <block wx:else>
                <view class="browse-join-btn{{item.canJoinPrimary ? '' : ' browse-join-disabled'}}" bindtap="{{item.canJoinPrimary ? 'handleJoinPlan' : 'noop'}}" data-template-id="{{item.id}}" data-plan-type="primary">
                  <text>{{t.plansJoinPrimary}}</text>
                </view>
                <view class="browse-join-btn browse-join-secondary{{item.canJoinSecondary ? '' : ' browse-join-disabled'}}" bindtap="{{item.canJoinSecondary ? 'handleJoinPlan' : 'noop'}}" data-template-id="{{item.id}}" data-plan-type="secondary">
                  <text>{{t.plansJoinSecondary}}</text>
                </view>
              </block>
            </view>
          </view>
          <view style="height: 48rpx;"></view>
        </scroll-view>
      </view>
    </view>

    <!-- ════ STORE ════ -->
    <view class="store-tab{{tab !== 'store' ? ' tab-hidden' : ''}}">

      <view class="store-header">
        <text class="store-title">{{t.storeTitle}}</text>
        <view wx:if="{{cartCount > 0}}" class="store-cart-icon" bindtap="handleOpenCart">
          <text class="store-cart-badge">{{cartCount}}</text>
        </view>
      </view>

      <!-- Subtab toggle -->
      <view wx:if="{{!storeLoading}}" class="store-subtab-row">
        <view class="store-subtab-btn{{storeSubTab === 'products' ? ' store-subtab-active' : ''}}" bindtap="switchStoreTab" data-tab="products">
          <text>{{t.storeSubProducts}}</text>
        </view>
        <view class="store-subtab-btn{{storeSubTab === 'orders' ? ' store-subtab-active' : ''}}" bindtap="switchStoreTab" data-tab="orders">
          <text>{{t.storeSubOrders}}</text>
        </view>
      </view>

      <!-- Loading -->
      <view wx:if="{{storeLoading}}" class="center-wrap">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>

      <!-- Products subtab -->
      <scroll-view wx:elif="{{storeSubTab === 'products' && storeItems.length > 0}}" class="store-scroll" scroll-y="true" refresher-enabled="{{true}}" refresher-triggered="{{storeRefreshing}}" bindrefresherrefresh="onStoreRefresh">
        <view class="store-list">
          <view wx:for="{{storeItems}}" wx:key="id" class="store-card">
            <view wx:if="{{item.tagLabel}}" class="store-tag">
              <text class="store-tag-text">{{item.tagLabel}}</text>
            </view>
            <text class="store-card-name">{{item.name}}</text>
            <text class="store-card-desc">{{item.desc}}</text>
            <view class="store-card-footer">
              <view class="store-price-wrap">
                <text class="store-price">{{item.price}}</text>
                <text class="store-unit">/ {{item.unit}}</text>
              </view>
              <view wx:if="{{!cartMap[item.id]}}" class="store-buy-btn" bindtap="handleAddToCart" data-item="{{item}}">
                <text class="store-buy-label">{{t.storeAddToCart}}</text>
              </view>
              <view wx:else class="cart-stepper">
                <view class="stepper-btn" bindtap="handleCartQtyChange" data-id="{{item.id}}" data-delta="{{-1}}"><text class="stepper-sym">－</text></view>
                <text class="stepper-qty">{{cartMap[item.id]}}</text>
                <view class="stepper-btn" bindtap="handleCartQtyChange" data-id="{{item.id}}" data-delta="{{1}}"><text class="stepper-sym">＋</text></view>
              </view>
            </view>
          </view>
          <view style="height: {{cartCount > 0 ? '140rpx' : '32rpx'}};"></view>
        </view>
      </scroll-view>

      <view wx:elif="{{storeSubTab === 'products'}}" class="dots-empty">
        <text>{{t.storeEmpty}}</text>
      </view>

      <!-- Cart bottom bar -->
      <view wx:if="{{cartCount > 0 && storeSubTab === 'products' && !storeLoading}}" class="cart-bar" bindtap="handleOpenCart">
        <text class="cart-bar-label">{{t.storeCartTotal}} · {{cartCount}}{{t.storeCartItems}}</text>
        <view class="cart-bar-right">
          <text class="cart-bar-total">{{cartTotal}}</text>
          <view class="cart-bar-btn" catchtap="handleCheckout">
            <text class="cart-bar-btn-text">{{t.storeCartCheckout}}</text>
          </view>
        </view>
      </view>

      <!-- Orders subtab -->
      <scroll-view wx:if="{{!storeLoading && storeSubTab === 'orders' && storeOrders.length > 0}}" class="store-scroll" scroll-y="true" refresher-enabled="{{true}}" refresher-triggered="{{storeRefreshing}}" bindrefresherrefresh="onStoreRefresh">
        <view class="store-list">
          <view wx:for="{{storeOrders}}" wx:key="id" class="order-card">
            <view class="order-card-top">
              <text class="order-name">{{item.name}}</text>
              <view class="order-status order-status-{{item.status}}">
                <text>{{t.orderStatus[item.status] || item.status}}</text>
              </view>
            </view>
            <view class="order-card-mid">
              <text class="order-price">{{item.price}}</text>
              <text class="order-meta"> · {{item.unit}} · ×{{item.quantity}}</text>
            </view>
            <view class="order-date-row">
              <text class="order-date">{{item.createdAt}}</text>
            </view>
            
            <!-- Delivery Details -->
            <view wx:if="{{item.shippingName}}" class="order-delivery-info">
              <view class="delivery-row">
                <text class="delivery-label">{{lang === 'zh' ? '收货人' : 'Recipient'}}</text>
                <text class="delivery-val">{{item.shippingName}} ({{item.shippingPhone}})</text>
              </view>
              <view class="delivery-row">
                <text class="delivery-label">{{lang === 'zh' ? '收货地址' : 'Address'}}</text>
                <text class="delivery-val">{{item.shippingAddress}}</text>
              </view>
              
              <!-- Courier Tracking Details -->
              <view wx:if="{{item.trackingNumber}}" class="delivery-row tracking-section">
                <text class="delivery-label">{{lang === 'zh' ? '快递单号' : 'Tracking'}}</text>
                <view class="tracking-val-wrap">
                  <text class="delivery-val bold">{{item.shippingCarrier}} {{item.trackingNumber}}</text>
                  <view class="copy-badge" bindtap="handleCopyTracking" data-tracking="{{item.trackingNumber}}">
                    <text>{{lang === 'zh' ? '复制' : 'Copy'}}</text>
                  </view>
                </view>
              </view>
            </view>
            
            <!-- Actions Section -->
            <view wx:if="{{item.status === 'pending'}}" class="order-actions">
              <view class="cancel-order-btn" bindtap="handleCancelOrder" data-id="{{item.id}}">
                <text>{{lang === 'zh' ? '取消订单' : 'Cancel Order'}}</text>
              </view>
            </view>
          </view>
          <view style="height: 32px;"></view>
        </view>
      </scroll-view>

      <view wx:if="{{!storeLoading && storeSubTab === 'orders' && storeOrders.length === 0}}" class="dots-empty">
        <text>{{t.noOrders}}</text>
      </view>

      <!-- Cart modal -->
      <view wx:if="{{cartOpen}}" class="cart-overlay" catchtap="handleCloseCart">
        <view class="cart-sheet" catchtap="">
          <view class="cart-sheet-header">
            <text class="cart-sheet-title">{{t.storeCart}}</text>
            <view class="cart-close-btn" bindtap="handleCloseCart"><text class="cart-close-sym">✕</text></view>
          </view>
          <scroll-view class="cart-sheet-scroll" scroll-y="true">
            <view wx:if="{{cart.length === 0}}" class="cart-empty-row">
              <text class="cart-empty-text">{{t.storeCartEmpty}}</text>
            </view>
            <view wx:for="{{cart}}" wx:key="id" class="cart-item-row">
              <view class="cart-item-info">
                <text class="cart-item-name">{{item.name}}</text>
                <text class="cart-item-price">{{item.price}} / {{item.unit}}</text>
              </view>
              <view class="cart-stepper cart-stepper-sm">
                <view class="stepper-btn" bindtap="handleCartQtyChange" data-id="{{item.id}}" data-delta="{{-1}}"><text class="stepper-sym">－</text></view>
                <text class="stepper-qty">{{item.quantity}}</text>
                <view class="stepper-btn" bindtap="handleCartQtyChange" data-id="{{item.id}}" data-delta="{{1}}"><text class="stepper-sym">＋</text></view>
              </view>
            </view>
          </scroll-view>
          <view class="cart-sheet-footer">
            <text class="cart-total-text">{{t.storeCartTotal}}  {{cartTotal}}</text>
            <view wx:if="{{cart.length > 0}}" class="cart-checkout-btn" bindtap="handleCheckout">
              <text class="cart-checkout-text">{{t.storeCartCheckout}}</text>
            </view>
          </view>
        </view>
      </view>

    </view>
    <!-- end STORE -->

  </view>
  <!-- end tab-content -->

  <!-- ── Cartridge Sim Overlay ── -->
  <view wx:if="{{simCartOpen}}" class="csim-overlay" bindtap="closeCartSim">
    <view class="csim-sheet" catchtap="noop">
      <view class="csim-handle"></view>
      <text class="csim-title">{{t.simCartTitle}}</text>
      <text class="csim-subtitle">{{t.simCartSubtitle}}</text>

      <view class="csim-sets">
        <view
          wx:for="{{simCartSets}}"
          wx:key="key"
          class="csim-set-card"
          style="border-color: {{item.color}}22;"
          bindtap="{{simCartLoading ? '' : 'handleSelectCartSet'}}"
          data-dots-raw="{{item.dots_raw}}"
        >
          <view class="csim-set-accent" style="background: {{item.color}};"></view>
          <view class="csim-set-body">
            <text class="csim-set-name">{{item.name}}</text>
            <text class="csim-set-desc">{{item.desc}}</text>
            <view class="csim-dot-badges">
              <view
                wx:for="{{item.dotItems}}"
                wx:key="displayKey"
                wx:for-item="di"
                class="csim-dot-badge"
              >
                <text class="csim-badge-key" style="color:{{item.color}};">{{di.displayKey}}</text>
                <text class="csim-badge-name">{{di.dotName}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{simCartLoading}}" class="csim-loading">
        <view class="pulse-dot"></view><view class="pulse-dot"></view><view class="pulse-dot"></view>
      </view>

      <view class="csim-cancel" bindtap="closeCartSim">
        <text>{{t.simCartCancel}}</text>
      </view>
    </view>
  </view>

  <!-- ── Kino Passcode Overlay ── -->
  <view wx:if="{{kinoPassOpen}}" class="kpass-overlay">
    <view class="kpass-box" style="margin-top: {{statusBarHeight + 44}}px;">

      <view class="kpass-logo">⬡</view>
      <text class="kpass-title">{{t.kinoSimPassTitle}}</text>

      <!-- 4-dot indicator -->
      <view class="kpass-dots">
        <view class="kpass-dot {{kinoPassInput.length > 0 ? 'kpass-dot-filled' : ''}} {{kinoPassError ? 'kpass-dot-error' : ''}}"></view>
        <view class="kpass-dot {{kinoPassInput.length > 1 ? 'kpass-dot-filled' : ''}} {{kinoPassError ? 'kpass-dot-error' : ''}}"></view>
        <view class="kpass-dot {{kinoPassInput.length > 2 ? 'kpass-dot-filled' : ''}} {{kinoPassError ? 'kpass-dot-error' : ''}}"></view>
        <view class="kpass-dot {{kinoPassInput.length > 3 ? 'kpass-dot-filled' : ''}} {{kinoPassError ? 'kpass-dot-error' : ''}}"></view>
      </view>

      <text wx:if="{{kinoPassError}}" class="kpass-error">{{t.kinoSimPassError}}</text>
      <view wx:else style="height: 36rpx;"></view>

      <!-- Numpad -->
      <view class="kpass-numpad">
        <view wx:for="{{[1,2,3,4,5,6,7,8,9]}}" wx:key="*this"
          class="kpass-key" bindtap="handlePassKey" data-digit="{{item}}">
          <text>{{item}}</text>
        </view>
        <view class="kpass-key kpass-key-empty"></view>
        <view class="kpass-key" bindtap="handlePassKey" data-digit="0"><text>0</text></view>
        <view class="kpass-key kpass-key-del" bindtap="handlePassDelete">
          <text class="kpass-del-icon">⌫</text>
        </view>
      </view>

      <view class="kpass-cancel" bindtap="closeKinoPass">
        <text>{{t.logout}}</text>
      </view>

    </view>
  </view>

  <!-- ── Kino Simulator Overlay ── -->
  <view wx:if="{{kinoSimOpen}}" class="ksm-overlay">
    <view class="ksm-container">

      <view class="ksm-header" style="padding-top: {{statusBarHeight}}px;">
        <view>
          <text class="ksm-title">{{t.kinoSimTitle}}</text>
          <text class="ksm-serial">S/N: KNA2-00000</text>
        </view>
        <view class="ksm-close" bindtap="closeKinoSim">✕</view>
      </view>

      <scroll-view class="ksm-body" scroll-y="true">
      <view class="ksm-body-inner">

        <!-- Device ring -->
        <view class="ksm-ring-row">
        <view class="ksm-device-wrap ksm-state-{{kinoSimStatus}}">
          <view class="ksm-ring-track"></view>
          <view class="ksm-ring-face">
            <view wx:if="{{kinoSimStatus === 'complete' && kinoSimBmList.length > 0}}"
              class="ksm-face-slide {{kinoSimSlideVisible ? 'ksm-slide-visible' : ''}}">
              <text class="ksm-slide-index">{{kinoSimSlideIndex + 1}} / {{kinoSimBmList.length}}</text>
              <text class="ksm-slide-label">{{kinoSimBmList[kinoSimSlideIndex].label}}</text>
              <text class="ksm-slide-val">{{kinoSimBmList[kinoSimSlideIndex].value !== null ? kinoSimBmList[kinoSimSlideIndex].value : '—'}}</text>
              <text class="ksm-slide-unit">{{kinoSimBmList[kinoSimSlideIndex].unit}}</text>
            </view>
            <view wx:else class="ksm-face-static">
              <text class="ksm-face-label">STATUS</text>
              <text class="ksm-face-status ksm-face-status-{{kinoSimStatus}}">
                {{kinoSimStatus === 'ready' ? t.kinoSimStatusReady : kinoSimStatus === 'analyzing' ? t.kinoSimStatusAnalyzing : kinoSimStatus === 'complete' ? t.kinoSimStatusComplete : t.kinoSimStatusFailed}}
              </text>
              <text wx:if="{{kinoSimScannedUserName}}" class="ksm-face-patient-label">{{t.kinoSimPatientLabel}}</text>
              <text class="ksm-face-user">{{kinoSimScannedUserName || '—'}}</text>
            </view>
          </view>
        </view>
        </view>

        <!-- Results panel -->
        <view wx:if="{{kinoSimStatus === 'complete' && kinoSimBmList.length > 0}}" class="ksm-results">
          <view class="ksm-tabs">
            <view class="ksm-tab {{kinoSimActiveTab === 'bioage' ? 'ksm-tab-active' : ''}}"
              bindtap="onKinoSimTabChange" data-tab="bioage">
              <text>{{t.kinoSimTabBioAge}}</text>
            </view>
            <view class="ksm-tab {{kinoSimActiveTab === 'biomarkers' ? 'ksm-tab-active' : ''}}"
              bindtap="onKinoSimTabChange" data-tab="biomarkers">
              <text>{{t.kinoSimTabBm}}</text>
            </view>
          </view>

          <view wx:if="{{kinoSimActiveTab === 'bioage'}}" class="ksm-tab-content">
            <view class="ksm-bioage-row">
              <view class="ksm-bioage-chip">
                <text class="ksm-bioage-num" style="color: {{kinoSimBioAgeColor}}">{{kinoSimBioAge}}</text>
                <text class="ksm-bioage-chip-label">{{t.kinoSimBioAgeLabel}}</text>
              </view>
              <view class="ksm-bioage-chip ksm-bioage-chip-dim">
                <text class="ksm-bioage-num" style="color: #A6C4E5">{{kinoSimChronoAge}}</text>
                <text class="ksm-bioage-chip-label">{{t.kinoSimChronoLabel}}</text>
              </view>
            </view>
            <view wx:for="{{kinoSimSubAgeList}}" wx:key="key" class="ksm-sub-row">
              <view class="ksm-sub-dot" style="background: {{item.color}}"></view>
              <text class="ksm-sub-label">{{item.label}}</text>
              <text class="ksm-sub-val" style="color: {{item.color}}">{{item.value}}</text>
            </view>
          </view>

          <view wx:if="{{kinoSimActiveTab === 'biomarkers'}}" class="ksm-tab-content">
            <view wx:for="{{kinoSimBmList}}" wx:key="key" class="ksm-bm-row">
              <text class="ksm-bm-label">{{item.label}}</text>
              <text class="ksm-bm-val">{{item.value !== null ? item.value : '—'}}<text class="ksm-bm-unit"> {{item.unit}}</text></text>
            </view>
          </view>
        </view>

        <!-- Action button -->
        <view class="ksm-btn ksm-btn-{{kinoSimStatus}}" bindtap="handleKinoSimStart">
          <view wx:if="{{kinoSimStatus === 'analyzing'}}" class="ksm-dots-row">
            <view class="ksm-dot"></view>
            <view class="ksm-dot"></view>
            <view class="ksm-dot"></view>
          </view>
          <text wx:elif="{{kinoSimStatus === 'complete'}}">{{t.kinoSimBtnRunAnother}}</text>
          <text wx:else>{{t.kinoSimBtnStart}}</text>
        </view>

        <view class="ksm-quit-btn" bindtap="closeKinoSim">
          <text>✕  {{t.kinoSimQuit}}</text>
        </view>

        <view class="ksm-debug-toggle" bindtap="toggleKinoSimDebug">
          <text class="ksm-debug-toggle-text">{{kinoSimDebug ? '▲ DEBUG' : '▼ DEBUG'}}</text>
        </view>

        <view wx:if="{{kinoSimDebug && kinoSimError}}" class="ksm-debug-box">
          <text class="ksm-debug-label">ERROR</text>
          <text class="ksm-debug-msg" user-select="true">{{kinoSimError}}</text>
        </view>
        <view wx:elif="{{kinoSimDebug}}" class="ksm-debug-box">
          <text class="ksm-debug-msg">No errors.</text>
        </view>

        <view style="height: 48rpx;"></view>
      </view>
      </scroll-view>

    </view>
  </view>

  <!-- ── Bottom Tab Bar ── -->
  <view class="tab-bar">
    <view class="tab-btn {{tab === 'chat' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="chat">
      <view wx:if="{{tab === 'chat'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/chat.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabChat}}</text>
    </view>
    <view class="tab-btn {{tab === 'health' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="health">
      <view wx:if="{{tab === 'health'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/health.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabHealth}}</text>
    </view>
    <view class="tab-btn {{tab === 'plans' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="plans">
      <view wx:if="{{tab === 'plans'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/plans.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabPlans}}</text>
    </view>
    <view class="tab-btn {{tab === 'dots' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="dots">
      <view wx:if="{{tab === 'dots'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/dots.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabDots}}</text>
    </view>
    <view wx:if="{{!isGuest}}" class="tab-btn {{tab === 'store' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="store">
      <view wx:if="{{tab === 'store'}}" class="tab-line"></view>
      <image class="tab-icon-img" src="/assets/icons/store.svg" mode="aspectFit" />
      <text class="tab-label">{{t.tabStore}}</text>
    </view>
  </view>

  <!-- ── Guest Join Sheet ── -->
  <view wx:if="{{guestSheetOpen}}" class="guest-sheet-mask" bindtap="closeGuestSheet">
    <view class="guest-sheet" catchtap="noop" style="{{guestKeyboardHeight > 0 ? 'padding-bottom:' + guestKeyboardHeight + 'px;' : ''}}">
      <view class="guest-sheet-handle"></view>

      <block wx:if="{{guestSheetStep === 'phone'}}">
        <text class="guest-sheet-title">{{t.guestPhoneTitle}}</text>
        <text class="guest-sheet-desc">{{t.guestPhoneDesc}}</text>

        <!-- Avatar consent row -->
        <button
          class="consent-row {{guestAvatarReady ? 'consent-row-done' : ''}}"
          open-type="chooseAvatar"
          bindchooseavatar="handleGuestChooseAvatar"
        >
          <view class="consent-check {{guestAvatarReady ? 'consent-check-done' : ''}}">
            <text wx:if="{{guestAvatarReady}}" class="consent-check-icon">✓</text>
          </view>
          <text class="consent-label">{{t.guestAvatarLabel}}</text>
          <view wx:if="{{guestPendingAvatar}}" class="consent-avatar-wrap">
            <image class="consent-avatar-preview" src="{{guestPendingAvatar}}" mode="aspectFill" />
            <view wx:if="{{guestAvatarUploading || (guestAvatarReady && guestInviteBusy)}}" class="avatar-saving-ring"></view>
          </view>
        </button>

        <!-- Phone consent row -->
        <button
          class="consent-row {{guestPhoneDone ? 'consent-row-done' : ''}}"
          open-type="getPhoneNumber"
          bindgetphonenumber="handleGuestPhone"
          disabled="{{guestInviteBusy || guestPhoneDone}}"
        >
          <view class="consent-check {{guestPhoneDone ? 'consent-check-done' : ''}}">
            <text wx:if="{{guestPhoneDone}}" class="consent-check-icon">✓</text>
          </view>
          <text class="consent-label">{{guestResolvedPhone || t.guestPhoneLabel}}</text>
        </button>

        <!-- Error -->
        <view wx:if="{{guestInviteError}}" class="guest-sheet-error">
          <text>{{guestInviteError}}</text>
        </view>

        <!-- Continue -->
        <view
          class="guest-sheet-btn {{(!guestAvatarReady || guestAvatarUploading || !guestResolvedPhone || guestInviteBusy) ? 'guest-sheet-btn-disabled' : ''}}"
          bindtap="proceedGuestSignup"
        >
          <text>{{guestInviteBusy ? t.guestActivating : t.guestContinueBtn}}</text>
        </view>

        <!-- Quit -->
        <view class="guest-sheet-skip" bindtap="cancelGuestSignup">
          <text>{{t.guestCancelSignup}}</text>
        </view>
      </block>

      <block wx:else>
        <text class="guest-sheet-title">{{t.guestJoinTitle}}</text>
        <text class="guest-sheet-desc">{{t.guestJoinDesc}}</text>
        <view class="pin-field">
          <view class="pin-boxes">
            <view
              wx:for="{{guestInviteDigits}}"
              wx:key="index"
              class="pin-box {{item ? 'pin-filled' : ''}} {{!item && index === guestInviteCode.length ? 'pin-active' : ''}}"
            >
              <text class="pin-digit">{{item}}</text>
            </view>
          </view>
          <input
            class="pin-capture"
            type="number"
            value="{{guestInviteCode}}"
            bindinput="onGuestInviteInput"
            bindkeyboardheightchange="onGuestKeyboardHeightChange"
            focus="{{guestSheetOpen}}"
            adjust-position="{{false}}"
            maxlength="6"
          />
        </view>
        <view wx:if="{{guestInviteError}}" class="guest-sheet-error">
          <text>{{guestInviteError}}</text>
        </view>
        <view class="guest-sheet-btn {{guestInviteBusy ? 'guest-sheet-btn-disabled' : ''}}" bindtap="submitGuestInvite">
          <text>{{guestInviteBusy ? t.guestActivating : t.guestJoinBtn}}</text>
        </view>
      </block>
    </view>
  </view>

</view>
