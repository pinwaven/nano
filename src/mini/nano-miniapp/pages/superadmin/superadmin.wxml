<view class="sa-page">
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>

  <!-- Header -->
  <view class="sa-header">
    <view class="header-back" bindtap="handleBack">
      <text class="back-arrow">‹</text>
    </view>
    <text class="header-title">{{t.title}}</text>
    <view class="header-refresh" bindtap="handleRefresh">
      <text class="refresh-icon">↻</text>
    </view>
  </view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view wx:for="{{['channels','users','coaches','dots','invites']}}" wx:key="*this"
          class="tab-item {{tab === item ? 'tab-active' : ''}}"
          bindtap="switchTab" data-tab="{{item}}">
      <text class="tab-text">{{t.tabs[item]}}</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-row">
    <text class="loading-text">{{t.loading}}</text>
  </view>

  <!-- ════ Channels Tab ════ -->
  <view wx:elif="{{tab === 'channels'}}" class="tab-content">
    <view class="add-row">
      <view class="add-btn" bindtap="openAddChannel">
        <text class="add-btn-text">+ {{t.add}}</text>
      </view>
    </view>
    <view wx:if="{{channels.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.empty.channels}}</text>
    </view>
    <view wx:for="{{channels}}" wx:key="id" class="list-card">
      <view class="card-main">
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-sub">{{item.key_name}} · {{item.user_count}} {{t.channel.users}} · {{item.coach_count}} {{t.channel.coaches}}</text>
        </view>
        <view class="card-actions">
          <view class="action-btn role-btn" bindtap="generateInviteForChannel" data-channel="{{item}}">
            <text class="action-text">+ {{t.invite.generate}}</text>
          </view>
          <view class="action-btn edit-btn" bindtap="openEditChannel" data-channel="{{item}}">
            <text class="action-text">{{t.edit}}</text>
          </view>
          <view class="action-btn del-btn" bindtap="deleteChannel" data-channel="{{item}}">
            <text class="action-text del-text">{{t.delete}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ════ Users Tab ════ -->
  <view wx:elif="{{tab === 'users'}}" class="tab-content">
    <view wx:if="{{users.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.empty.users}}</text>
    </view>
    <view wx:for="{{users}}" wx:key="user_id" class="list-card">
      <view class="card-main">
        <view class="user-avatar">
          <text class="avatar-letter">{{item._avatar}}</text>
        </view>
        <view class="card-info">
          <text class="card-name">{{item.nickname || '—'}}</text>
          <text class="card-sub">{{item._channelName}} · {{item._rolesLabel}}</text>
          <text class="card-sub2">{{t.user.joined}}: {{item._joinedFmt}}</text>
        </view>
        <view class="card-actions">
          <view class="action-btn role-btn" bindtap="openRoles" data-user="{{item}}">
            <text class="action-text">{{t.user.roles}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ════ Coaches Tab ════ -->
  <view wx:elif="{{tab === 'coaches'}}" class="tab-content">
    <view wx:if="{{coaches.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.empty.coaches}}</text>
    </view>
    <view wx:for="{{coaches}}" wx:key="id" class="list-card">
      <view class="card-main">
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-sub">{{item._channelName}} · {{item.user_count}} {{t.coach.users}}</text>
          <text wx:if="{{item.user_id}}" class="card-sub2">{{t.coach.linkedUser}}: {{item.user_id}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ════ Dots Tab ════ -->
  <view wx:elif="{{tab === 'dots'}}" class="tab-content">
    <view class="add-row">
      <view class="add-btn" bindtap="openAddDot">
        <text class="add-btn-text">+ {{t.add}}</text>
      </view>
    </view>
    <view wx:if="{{dots.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.empty.dots}}</text>
    </view>
    <view wx:for="{{dots}}" wx:key="id" class="list-card">
      <view class="card-main">
        <view class="dot-swatch" style="background: {{item.color_hex || '#6375EC'}};"></view>
        <view class="card-info">
          <view class="dot-name-row">
            <text class="card-name">{{lang === 'zh' && item.name_zh ? item.name_zh : item.name}}</text>
            <view class="dot-timing-tag dot-timing-{{item.timing === 'Evening' ? 'eve' : 'morn'}}">
              <text class="dot-timing-text">{{item._timingLabel}}</text>
            </view>
          </view>
          <text class="card-sub">{{item.key_name}} · {{item._subAgeLabel}}</text>
          <view wx:if="{{item._groupLabel}}" class="dot-group-pill dot-group-{{item._groupKey}}">
            <text class="dot-group-text">{{item._groupLabel}}</text>
          </view>
        </view>
        <view class="card-actions">
          <view class="action-btn edit-btn" catchtap="openEditDot" data-dot="{{item}}">
            <text class="action-text">{{t.edit}}</text>
          </view>
          <view class="action-btn del-btn" catchtap="handleDeleteDot" data-dot="{{item}}">
            <text class="action-text del-text">{{t.delete}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{item.description}}" class="dot-desc">
        <text class="dot-desc-text">{{item.description}}</text>
      </view>
    </view>
  </view>

  <!-- ════ Invites Tab ════ -->
  <view wx:elif="{{tab === 'invites'}}" class="tab-content">
    <view wx:if="{{invites.length === 0}}" class="empty-state">
      <text class="empty-text">{{t.empty.invites}}</text>
    </view>
    <view wx:for="{{invites}}" wx:key="id" class="list-card">
      <view class="card-main">
        <view class="card-info">
          <text class="card-name invite-code-text">{{item.code}}</text>
          <text class="card-sub">{{item.channel_name || '—'}} · {{t.invite.uses}}: {{item.use_count}}</text>
          <text wx:if="{{item.creator_name}}" class="card-sub2">{{t.invite.creator}}: {{item.creator_name}}</text>
        </view>
        <view class="card-actions">
          <view class="action-btn role-btn" catchtap="copyInvite" data-invite="{{item}}">
            <text class="action-text">{{t.invite.copy}}</text>
          </view>
          <view wx:if="{{item.is_active}}" class="action-btn del-btn" catchtap="deactivateInvite" data-invite="{{item}}">
            <text class="action-text del-text">{{t.invite.deactivate}}</text>
          </view>
          <view wx:else class="action-btn" style="opacity:0.4;">
            <text class="action-text">{{t.invite.inactive}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ════ Channel Modal ════ -->
  <view wx:if="{{channelModalOpen}}" class="modal-mask" catchtouchmove="noop">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">{{channelModalTitle}}</text>
        <view class="modal-close" bindtap="closeChannelModal"><text class="close-x">✕</text></view>
      </view>
      <scroll-view scroll-y class="modal-scroll">
        <view class="modal-body">
          <view class="form-row">
            <text class="form-label">{{t.channel.key}}</text>
            <input class="form-input" value="{{channelForm.key_name}}" bindinput="onChannelFormInput" data-key="key_name" placeholder="nanovate" disabled="{{channelModalMode === 'edit'}}" />
          </view>
          <view class="form-row">
            <text class="form-label">{{t.channel.name}}</text>
            <input class="form-input" value="{{channelForm.name}}" bindinput="onChannelFormInput" data-key="name" placeholder="Nanovate" />
          </view>
          <view class="form-row">
            <text class="form-label">{{t.channel.logo}}</text>
            <view class="logo-picker {{channelLogoUploading ? 'logo-picker-busy' : ''}}" bindtap="pickChannelLogo">
              <image wx:if="{{channelForm.logo_url && !channelLogoUploading}}" src="{{channelForm.logo_url}}" class="logo-preview" mode="aspectFill" />
              <text wx:elif="{{channelLogoUploading}}" class="logo-placeholder-text">{{t.uploading}}</text>
              <text wx:else class="logo-placeholder-text">{{t.channel.uploadLogo}}</text>
            </view>
          </view>
          <view wx:if="{{channelModalError}}" class="modal-error">
            <text class="error-text">{{channelModalError}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="footer-btn cancel-btn" bindtap="closeChannelModal"><text class="btn-text">{{t.cancel}}</text></view>
        <view class="footer-btn save-btn {{channelModalBusy ? 'btn-busy' : ''}}" bindtap="saveChannel">
          <text class="btn-text">{{channelModalBusy ? t.saving : t.save}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ════ Roles Modal ════ -->
  <view wx:if="{{rolesModalOpen}}" class="modal-mask" catchtouchmove="noop">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">{{rolesTarget.nickname || '—'}} — {{t.roles.label}}</text>
        <view class="modal-close" bindtap="closeRolesModal"><text class="close-x">✕</text></view>
      </view>
      <view class="modal-body">
        <view wx:for="{{['user','coach','admin','superadmin']}}" wx:key="*this" class="role-row" bindtap="toggleRole" data-idx="{{index}}">
          <view class="role-check {{rolesChecked[index] ? 'checked' : ''}}">
            <text wx:if="{{rolesChecked[index]}}" class="check-mark">✓</text>
          </view>
          <text class="role-label">{{t.roles[item]}}</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="footer-btn cancel-btn" bindtap="closeRolesModal"><text class="btn-text">{{t.cancel}}</text></view>
        <view class="footer-btn save-btn" bindtap="saveRoles"><text class="btn-text">{{t.roles.saveRoles}}</text></view>
      </view>
    </view>
  </view>

  <!-- ════ Dot Modal ════ -->
  <view wx:if="{{dotModalOpen}}" class="modal-mask" catchtouchmove="noop">
    <view class="modal-panel modal-panel-tall" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">{{dotModalTitle}}</text>
        <view wx:if="{{!dotModalBusy}}" class="modal-close" bindtap="closeDotModal"><text class="close-x">✕</text></view>
      </view>
      <scroll-view scroll-y class="modal-scroll">
        <view class="modal-body">

          <view class="form-row">
            <text class="form-label">{{t.dot.key}} *</text>
            <input class="form-input" value="{{dotForm.key_name}}" bindinput="onDotFormInput" data-key="key_name" placeholder="e.g. omega3" placeholder-class="form-ph" />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.nameEn}} *</text>
            <input class="form-input" value="{{dotForm.name_en}}" bindinput="onDotFormInput" data-key="name_en" placeholder-class="form-ph" />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.nameZh}}</text>
            <input class="form-input" value="{{dotForm.name_zh}}" bindinput="onDotFormInput" data-key="name_zh" placeholder-class="form-ph" />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.color}}</text>
            <input class="form-input" value="{{dotForm.color}}" bindinput="onDotFormInput" data-key="color" placeholder="e.g. Ocean Blue" placeholder-class="form-ph" />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.colorZh}}</text>
            <input class="form-input" value="{{dotForm.color_zh}}" bindinput="onDotFormInput" data-key="color_zh" placeholder-class="form-ph" />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.colorHex}}</text>
            <view class="color-hex-row">
              <view class="color-hex-preview" style="background: {{dotForm.color_hex || '#6375EC'}};"></view>
              <input class="form-input-hex" value="{{dotForm.color_hex}}" bindinput="onDotFormInput" data-key="color_hex" placeholder="#4A5D7B" placeholder-class="form-ph" />
            </view>
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.timing}}</text>
            <picker range="{{t.timingOptions}}" value="{{formTimingIdx}}" bindchange="onPickerTiming">
              <view class="form-picker">
                <text class="form-picker-val">{{t.timingOptions[formTimingIdx]}}</text>
                <text class="form-picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.group}}</text>
            <picker range="{{t.groupOptions}}" value="{{formGroupIdx}}" bindchange="onPickerGroup">
              <view class="form-picker">
                <text class="form-picker-val">{{t.groupOptions[formGroupIdx]}}</text>
                <text class="form-picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.subAge}}</text>
            <picker range="{{t.subAgeOptions}}" value="{{formSubAgeIdx}}" bindchange="onPickerSubAge">
              <view class="form-picker">
                <text class="form-picker-val">{{t.subAgeOptions[formSubAgeIdx]}}</text>
                <text class="form-picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.type}}</text>
            <picker range="{{t.typeOptions}}" value="{{formTypeIdx}}" bindchange="onPickerType">
              <view class="form-picker">
                <text class="form-picker-val">{{t.typeOptions[formTypeIdx]}}</text>
                <text class="form-picker-arrow">›</text>
              </view>
            </picker>
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.desc}}</text>
            <textarea class="form-textarea" value="{{dotForm.description}}" bindinput="onDotFormInput" data-key="description" placeholder-class="form-ph" auto-height />
          </view>

          <view class="form-row">
            <text class="form-label">{{t.dot.ingrSummary}}</text>
            <textarea class="form-textarea" value="{{dotForm.ingredients_summary}}" bindinput="onDotFormInput" data-key="ingredients_summary" placeholder-class="form-ph" auto-height />
          </view>

          <!-- Ingredients EN -->
          <text class="form-label" style="display:block; margin-top:16px; margin-bottom:8px;">{{t.dot.ingrEn}}</text>
          <view wx:for="{{formIngredients}}" wx:key="index" class="ingr-row">
            <input class="ingr-name" value="{{item.name}}" bindinput="onIngredientInput" data-zh="{{false}}" data-idx="{{index}}" data-field="name" placeholder="{{t.dot.ingrName}}" placeholder-class="form-ph" />
            <input class="ingr-value" value="{{item.mg}}" bindinput="onIngredientInput" data-zh="{{false}}" data-idx="{{index}}" data-field="mg" type="digit" placeholder="{{t.dot.ingrMg}}" placeholder-class="form-ph" />
            <view class="ingr-del" bindtap="removeIngredient" data-zh="{{false}}" data-idx="{{index}}"><text>−</text></view>
          </view>
          <view class="ingr-add" bindtap="addIngredient" data-zh="{{false}}">
            <text>{{t.dot.addIngr}}</text>
          </view>

          <!-- Ingredients ZH -->
          <text class="form-label" style="display:block; margin-top:16px; margin-bottom:8px;">{{t.dot.ingrZh}}</text>
          <view wx:for="{{formIngredientsZh}}" wx:key="index" class="ingr-row">
            <input class="ingr-name" value="{{item.name}}" bindinput="onIngredientInput" data-zh="{{true}}" data-idx="{{index}}" data-field="name" placeholder="{{t.dot.ingrName}}" placeholder-class="form-ph" />
            <input class="ingr-value" value="{{item.mg}}" bindinput="onIngredientInput" data-zh="{{true}}" data-idx="{{index}}" data-field="mg" type="digit" placeholder="{{t.dot.ingrMg}}" placeholder-class="form-ph" />
            <view class="ingr-del" bindtap="removeIngredient" data-zh="{{true}}" data-idx="{{index}}"><text>−</text></view>
          </view>
          <view class="ingr-add" bindtap="addIngredient" data-zh="{{true}}">
            <text>{{t.dot.addIngr}}</text>
          </view>

          <text wx:if="{{dotModalError}}" class="modal-error-text">{{dotModalError}}</text>

        </view>
      </scroll-view>
      <view class="modal-footer">
        <view wx:if="{{!dotModalBusy}}" class="footer-btn cancel-btn" bindtap="closeDotModal"><text class="btn-text">{{t.cancel}}</text></view>
        <view class="footer-btn save-btn {{dotModalBusy ? 'btn-busy' : ''}}" bindtap="saveDot">
          <text class="btn-text">{{dotModalBusy ? t.saving : t.save}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
